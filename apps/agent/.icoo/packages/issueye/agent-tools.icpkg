{
  "version": 1,
  "kind": "package",
  "entry": "src/tools/package.ic",
  "root_alias": "@",
  "package_name": "issueye/agent-tools",
  "package_version": "0.1.2",
  "export": "src/tools/package.ic",
  "modules": {
    "src/tools/create_skill.ic": "import std.io.fs as fs\r\nimport std.sys.os as os\r\nimport std.core.object as object\r\n\r\nexport class CreateSkill {\r\n  init(skillCatalog) {\r\n    this.skillCatalog = skillCatalog\r\n  }\r\n\r\n  run(config, input) {\r\n    let skillId = object.get(input, \"skill\")\r\n    if this.skillCatalog.isValidSkillId(skillId) != true {\r\n      return {\r\n        ok: false,\r\n        error: \"createSkill requires a safe skill id\"\r\n      }\r\n    }\r\n\r\n    if this.skillCatalog.findById(config, skillId) != null {\r\n      return {\r\n        ok: false,\r\n        error: \"skill already exists: \" + skillId\r\n      }\r\n    }\r\n\r\n    let description = object.get(input, \"description\")\r\n    if typeOf(description) != \"string\" || description == \"\" {\r\n      return {\r\n        ok: false,\r\n        error: \"createSkill requires non-empty description\"\r\n      }\r\n    }\r\n\r\n    let baseDir = this.skillCatalog.primaryDir(config)\r\n    if typeOf(baseDir) != \"string\" || baseDir == \"\" {\r\n      return {\r\n        ok: false,\r\n        error: \"no skill directory configured\"\r\n      }\r\n    }\r\n\r\n    let skillDir = fs.join(baseDir, skillId)\r\n    let skillFile = fs.join(skillDir, \"SKILL.md\")\r\n    let content = object.get(input, \"content\")\r\n    if typeOf(content) != \"string\" || content == \"\" {\r\n      content = this.skillCatalog.buildSkillDocument(\r\n        skillId,\r\n        object.get(input, \"name\"),\r\n        description,\r\n        object.get(input, \"body\")\r\n      )\r\n    }\r\n\r\n    os.mkdirAll(skillDir)\r\n    fs.writeFile(skillFile, content)\r\n\r\n    return {\r\n      ok: true,\r\n      created: skillId,\r\n      meta: {\r\n        dir: skillDir,\r\n        skillFile: skillFile\r\n      }\r\n    }\r\n  }\r\n}\r\n",
    "src/tools/exec_command.ic": "import std.sys.exec as exec\r\nimport std.core.object as object\r\nimport \"@/src/tools/tool_path.ic\" as toolPath\r\n\r\n// 执行命令工具\r\nexport class ExecCommand {\r\n  init(toolPath) {\r\n    this.toolPath = toolPath\r\n  }\r\n\r\n  // 执行命令\r\n  run(config, input) {\r\n    let command = object.get(input, \"command\")\r\n    let args = object.get(input, \"args\", [])\r\n    let cwd = object.get(input, \"cwd\", config.workspace)\r\n    let shell = object.get(input, \"shell\", false)\r\n    let env = object.get(input, \"env\", {})\r\n\r\n    if command == null || command == \"\" {\r\n      return {\r\n        ok: false,\r\n        error: \"execCommand requires non-empty command\"\r\n      }\r\n    }\r\n\r\n    cwd = this.toolPath.resolve(config, cwd)\r\n\r\n    // `std.sys.exec` 在 shell 模式下只消费 command，本层禁止同时传 args，\r\n    // 避免模型误以为 shell + argv 会一起生效。\r\n    if shell == true \u0026\u0026 typeOf(args) == \"array\" \u0026\u0026 len(args) \u003e 0 {\r\n      return {\r\n        ok: false,\r\n        error: \"execCommand does not support args when shell=true\"\r\n      }\r\n    }\r\n\r\n    let result = exec.run({\r\n      command: command,\r\n      args: args,\r\n      cwd: cwd,\r\n      shell: shell,\r\n      env: env\r\n    })\r\n\r\n    return {\r\n      ok: result.ok,\r\n      content: {\r\n        stdout: result.stdout,\r\n        stderr: result.stderr\r\n      },\r\n      meta: {\r\n        command: result.command,\r\n        exitCode: result.exitCode,\r\n        cwd: cwd,\r\n        shell: shell\r\n      },\r\n      error: result.ok == true ? null : result.stderr\r\n    }\r\n  }\r\n}\r\n",
    "src/tools/executor.ic": "import std.core.object as object\r\nimport std.data.json as json\r\n\r\nexport class ToolExecutor {\r\n  init(toolRegistry) {\r\n    this.toolRegistry = toolRegistry\r\n  }\r\n\r\n  parseArguments(rawArguments) {\r\n    if typeOf(rawArguments) == \"object\" {\r\n      return {\r\n        ok: true,\r\n        value: rawArguments\r\n      }\r\n    }\r\n    if typeOf(rawArguments) != \"string\" || rawArguments == \"\" {\r\n      return {\r\n        ok: false,\r\n        error: \"tool arguments must be a non-empty JSON string\"\r\n      }\r\n    }\r\n\r\n    try {\r\n      return {\r\n        ok: true,\r\n        value: json.decode(rawArguments)\r\n      }\r\n    } catch err {\r\n      return {\r\n        ok: false,\r\n        error: \"invalid tool arguments JSON\"\r\n      }\r\n    }\r\n  }\r\n\r\n  run(config, name, input) {\r\n    let tool = this.toolRegistry.get(name)\r\n    if tool == null {\r\n      return {\r\n        ok: false,\r\n        error: \"unknown tool: \" + name\r\n      }\r\n    }\r\n\r\n    let handler = object.get(tool, \"handler\")\r\n    return handler(config, input)\r\n  }\r\n\r\n  runCall(config, call) {\r\n    let callId = object.get(call, \"id\", \"\")\r\n    let fnDef = object.get(call, \"function\", {})\r\n    let name = object.get(fnDef, \"name\", \"\")\r\n    let parsedArgs = this.parseArguments(object.get(fnDef, \"arguments\"))\r\n    if parsedArgs.ok != true {\r\n      return {\r\n        ok: false,\r\n        toolCallId: callId,\r\n        name: name,\r\n        error: parsedArgs.error,\r\n        output: {\r\n          ok: false,\r\n          error: parsedArgs.error\r\n        }\r\n      }\r\n    }\r\n\r\n    let result = this.run(config, name, parsedArgs.value)\r\n    return {\r\n      ok: result.ok,\r\n      toolCallId: callId,\r\n      name: name,\r\n      input: parsedArgs.value,\r\n      output: result,\r\n      error: object.get(result, \"error\")\r\n    }\r\n  }\r\n}\r\n",
    "src/tools/list_dir.ic": "import std.io.fs as fs\r\nimport std.core.object as object\r\n\r\n// ListDir 是一个列出工作区目录内容的工具。\r\nexport class ListDir {\r\n  init(toolPath) {\r\n    this.toolPath = toolPath\r\n  }\r\n\r\n  // run 列出工作区目录内容。\r\n  run(config, input) {\r\n    let path = object.get(input, \"path\")\r\n    if path == null || path == \"\" {\r\n      return {\r\n        ok: false,\r\n        error: \"listDir requires non-empty path\"\r\n      }\r\n    }\r\n\r\n    path = this.toolPath.resolve(config, path)\r\n    if fs.exists(path) != true {\r\n      return {\r\n        ok: false,\r\n        error: \"directory not found: \" + path\r\n      }\r\n    }\r\n    let info = fs.stat(path)\r\n    if info.isDir != true {\r\n      return {\r\n        ok: false,\r\n        error: \"path is not a directory: \" + path\r\n      }\r\n    }\r\n\r\n    let entries = fs.readDir(path).map(fn(entry) {\r\n      return {\r\n        name: entry.name,\r\n        path: entry.path,\r\n        isDir: entry.isDir\r\n      }\r\n    })\r\n\r\n    return {\r\n      ok: true,\r\n      content: entries,\r\n      meta: {\r\n        path: path,\r\n        count: len(entries)\r\n      }\r\n    }\r\n  }\r\n}\r\n",
    "src/tools/list_skills.ic": "export class ListSkills {\r\n  init(skillCatalog) {\r\n    this.skillCatalog = skillCatalog\r\n  }\r\n\r\n  run(config, input) {\r\n    let items = this.skillCatalog.list(config)\r\n    return {\r\n      ok: true,\r\n      content: items,\r\n      meta: {\r\n        count: len(items),\r\n        configuredDirs: this.skillCatalog.configuredDirs(config)\r\n      }\r\n    }\r\n  }\r\n}\r\n",
    "src/tools/package.ic": "import \"@/src/tools/executor.ic\" as executor\nimport \"@/src/tools/registry.ic\" as registry\nimport \"@/src/tools/tool_path.ic\" as toolPath\nimport \"@/src/tools/web_common.ic\" as webCommon\n\nexport {\n  ToolExecutor: executor.ToolExecutor,\n  ToolRegistry: registry.ToolRegistry,\n  ToolPath: toolPath.ToolPath,\n  WebCommon: webCommon.WebCommon\n}\n",
    "src/tools/read_file.ic": "import std.io.fs as fs\r\nimport std.core.object as object\r\n\r\n// ReadFile 是一个读取工作区文本文件的工具。\r\nexport class ReadFile {\r\n  init(toolPath) {\r\n    this.toolPath = toolPath\r\n  }\r\n\r\n  // run 读取工作区中的文本文件。\r\n  run(config, input) {\r\n    let path = object.get(input, \"path\")\r\n    if path == null || path == \"\" {\r\n      return {\r\n        ok: false,\r\n        error: \"readFile requires non-empty path\"\r\n      }\r\n    }\r\n\r\n    path = this.toolPath.resolve(config, path)\r\n    if fs.exists(path) != true {\r\n      return {\r\n        ok: false,\r\n        error: \"file not found: \" + path\r\n      }\r\n    }\r\n    let info = fs.stat(path)\r\n    if info.isFile != true {\r\n      return {\r\n        ok: false,\r\n        error: \"path is not a file: \" + path\r\n      }\r\n    }\r\n\r\n    return {\r\n      ok: true,\r\n      content: fs.readFile(path),\r\n      meta: {\r\n        path: path\r\n      }\r\n    }\r\n  }\r\n}\r\n",
    "src/tools/read_skill.ic": "import std.io.fs as fs\r\nimport std.core.object as object\r\n\r\nexport class ReadSkill {\r\n  init(skillCatalog) {\r\n    this.skillCatalog = skillCatalog\r\n  }\r\n\r\n  run(config, input) {\r\n    let skillId = object.get(input, \"skill\")\r\n    if typeOf(skillId) != \"string\" || skillId == \"\" {\r\n      return {\r\n        ok: false,\r\n        error: \"readSkill requires non-empty skill\"\r\n      }\r\n    }\r\n\r\n    let skill = this.skillCatalog.findById(config, skillId)\r\n    if skill == null {\r\n      return {\r\n        ok: false,\r\n        error: \"skill not found: \" + skillId\r\n      }\r\n    }\r\n\r\n    return {\r\n      ok: true,\r\n      content: fs.readFile(skill.skillFile),\r\n      meta: skill\r\n    }\r\n  }\r\n}\r\n",
    "src/tools/registry.ic": "import std.core.object as object\r\nimport \"@/src/tools/exec_command.ic\" as execCommand\r\nimport \"@/src/tools/read_file.ic\" as readFile\r\nimport \"@/src/tools/list_dir.ic\" as listDir\r\nimport \"@/src/tools/search_text.ic\" as searchText\nimport \"@/src/tools/web_fetch.ic\" as webFetch\nimport \"@/src/tools/web_search.ic\" as webSearch\nimport \"@/src/tools/skill_tool.ic\" as skillTool\n\r\nexport class ToolRegistry {\r\n  init(toolPath, ignore, webCommon, skillCatalog) {\r\n    this.toolPath = toolPath\r\n    this.ignore = ignore\r\n    this.webCommon = webCommon\r\n    this.skillCatalog = skillCatalog\r\n    this.execCommand = execCommand.ExecCommand(this.toolPath)\r\n    this.readFile = readFile.ReadFile(this.toolPath)\r\n    this.listDir = listDir.ListDir(this.toolPath)\n    this.searchText = searchText.SearchText(this.toolPath, this.ignore)\n    this.webFetch = webFetch.WebFetch(this.webCommon)\n    this.webSearch = webSearch.WebSearch(this.webCommon)\n    this.skill = skillTool.SkillTool(this.skillCatalog)\n  }\r\n\r\n  build() {\r\n    return {\r\n      readFile: {\r\n        name: \"readFile\",\r\n        description: \"Read a UTF-8 text file from the local workspace.\",\r\n        parameters: {\r\n          type: \"object\",\r\n          properties: {\r\n            path: {\r\n              type: \"string\",\r\n              description: \"Workspace-relative path. Use @/ as the workspace root prefix.\"\r\n            }\r\n          },\r\n          required: [\"path\"]\r\n        },\r\n        handler: this.readFile.run\r\n      },\r\n      listDir: {\r\n        name: \"listDir\",\r\n        description: \"List files and directories under a workspace path.\",\r\n        parameters: {\r\n          type: \"object\",\r\n          properties: {\r\n            path: {\r\n              type: \"string\",\r\n              description: \"Workspace-relative directory path. Use @/ as the workspace root prefix.\"\r\n            }\r\n          },\r\n          required: [\"path\"]\r\n        },\r\n        handler: this.listDir.run\r\n      },\r\n      searchText: {\r\n        name: \"searchText\",\r\n        description: \"Search plain text files under a workspace path for a query string.\",\r\n        parameters: {\r\n          type: \"object\",\r\n          properties: {\r\n            path: {\r\n              type: \"string\",\r\n              description: \"Workspace-relative search root. Use @/ as the workspace root prefix.\"\r\n            },\r\n            query: {\r\n              type: \"string\",\r\n              description: \"The literal string to search for.\"\r\n            }\r\n          },\r\n          required: [\"path\", \"query\"]\r\n        },\r\n        handler: this.searchText.run\r\n      },\r\n      execCommand: {\r\n        name: \"execCommand\",\r\n        description: \"Execute a local command inside the workspace and return stdout/stderr.\",\r\n        parameters: {\r\n          type: \"object\",\r\n          properties: {\r\n            command: {\r\n              type: \"string\",\r\n              description: \"Executable or shell command text.\"\r\n            },\r\n            args: {\r\n              type: \"array\",\r\n              description: \"Optional argv list. Do not pass this when shell=true.\",\r\n              items: {\r\n                type: \"string\"\r\n              }\r\n            },\r\n            cwd: {\r\n              type: \"string\",\r\n              description: \"Optional working directory. Supports @/ as the workspace root prefix.\"\r\n            },\r\n            shell: {\r\n              type: \"boolean\",\r\n              description: \"Run command through the system shell. When true, omit args.\"\r\n            },\r\n            env: {\r\n              type: \"object\",\r\n              description: \"Optional environment variable overrides merged on top of the current host environment.\",\r\n              additionalProperties: {\r\n                type: \"string\"\r\n              }\r\n            }\r\n          },\r\n          required: [\"command\"]\r\n        },\r\n        handler: this.execCommand.run\r\n      },\r\n      webFetch: {\r\n        name: \"webFetch\",\r\n        description: \"Fetch a web page URL and return cleaned text content.\",\r\n        parameters: {\r\n          type: \"object\",\r\n          properties: {\r\n            url: {\r\n              type: \"string\",\r\n              description: \"Absolute HTTP or HTTPS URL to fetch.\"\r\n            },\r\n            maxChars: {\r\n              type: \"integer\",\r\n              description: \"Optional maximum number of characters to keep from the cleaned page text.\"\r\n            }\r\n          },\r\n          required: [\"url\"]\r\n        },\r\n        handler: this.webFetch.run\r\n      },\r\n      webSearch: {\r\n        name: \"webSearch\",\r\n        description: \"Search the web with DuckDuckGo and return a short result list.\",\r\n        parameters: {\r\n          type: \"object\",\r\n          properties: {\r\n            query: {\r\n              type: \"string\",\r\n              description: \"Search query text.\"\r\n            },\r\n            maxResults: {\r\n              type: \"integer\",\r\n              description: \"Optional maximum number of results to return.\"\r\n            }\r\n          },\r\n          required: [\"query\"]\r\n        },\r\n        handler: this.webSearch.run\r\n      },\r\n      skill: {\n        name: \"skill\",\n        description: \"Manage discovered agent skills with a single tool. Use action=list|read|create|update|remove.\",\n        parameters: {\n          type: \"object\",\n          properties: {\n            action: {\n              type: \"string\",\n              description: \"Required operation: list, read, create, update, or remove.\"\n            },\n            skill: {\n              type: \"string\",\n              description: \"Skill folder id or frontmatter name. Required for read, create, update, and remove.\"\n            },\n            name: {\n              type: \"string\",\n              description: \"Optional frontmatter skill name for create or update.\"\n            },\n            description: {\n              type: \"string\",\n              description: \"Description for create, or optional replacement description for update.\"\n            },\n            body: {\n              type: \"string\",\n              description: \"Optional markdown body for create or update.\"\n            },\n            content: {\n              type: \"string\",\n              description: \"Optional full SKILL.md content for create or update. Overrides name/description/body assembly.\"\n            }\n          },\n          required: [\"action\"]\n        },\n        handler: this.skill.run\n      }\n    }\n  }\n\r\n  get(name) {\r\n    let tools = this.build()\r\n    return object.get(tools, name)\r\n  }\r\n\r\n  definitions() {\n    let tools = this.build()\n    let names = [\"readFile\", \"listDir\", \"searchText\", \"execCommand\", \"webFetch\", \"webSearch\", \"skill\"]\n    let definitions = []\r\n    for i, name in names {\r\n      let tool = object.get(tools, name)\r\n      definitions = definitions.append({\r\n        type: \"function\",\r\n        function: {\r\n          name: tool.name,\r\n          description: tool.description,\r\n          parameters: tool.parameters\r\n        }\r\n      })\r\n    }\r\n    return definitions\r\n  }\r\n}\r\n",
    "src/tools/remove_skill.ic": "import std.sys.os as os\r\nimport std.core.object as object\r\n\r\nexport class RemoveSkill {\r\n  init(skillCatalog) {\r\n    this.skillCatalog = skillCatalog\r\n  }\r\n\r\n  run(config, input) {\r\n    let skillId = object.get(input, \"skill\")\r\n    if typeOf(skillId) != \"string\" || skillId == \"\" {\r\n      return {\r\n        ok: false,\r\n        error: \"removeSkill requires non-empty skill\"\r\n      }\r\n    }\r\n\r\n    let skill = this.skillCatalog.findById(config, skillId)\r\n    if skill == null {\r\n      return {\r\n        ok: false,\r\n        error: \"skill not found: \" + skillId\r\n      }\r\n    }\r\n\r\n    os.removeAll(skill.dir)\r\n\r\n    return {\r\n      ok: true,\r\n      removed: skill.id,\r\n      meta: skill\r\n    }\r\n  }\r\n}\r\n",
    "src/tools/search_text.ic": "import std.io.fs as fs\r\nimport std.core.object as object\r\nimport std.core.string as str\r\n\r\n// SearchText 是一个搜索工作区文本的工具。\r\nexport class SearchText {\r\n  init(toolPath, ignore) {\r\n    this.toolPath = toolPath\r\n    this.ignore = ignore\r\n  }\r\n\r\n  // isSearchable 判断文件是否适合文本搜索。\r\n  isSearchable(path) {\r\n    return (\r\n      str.hasSuffix(path, \".ic\") ||\r\n      str.hasSuffix(path, \".md\") ||\r\n      str.hasSuffix(path, \".txt\") ||\r\n      str.hasSuffix(path, \".json\") ||\r\n      str.hasSuffix(path, \".toml\") ||\r\n      str.hasSuffix(path, \".yaml\") ||\r\n      str.hasSuffix(path, \".yml\") ||\r\n      str.hasSuffix(path, \".go\") ||\r\n      str.hasSuffix(path, \".js\") ||\r\n      str.hasSuffix(path, \".ts\")\r\n    )\r\n  }\r\n\r\n  // scan 递归搜索目录或单文件。\r\n  scan(path, needle, matches) {\r\n    let info = fs.stat(path)\r\n    if info.isFile {\r\n      if this.isSearchable(path) != true {\r\n        return matches\r\n      }\r\n\r\n      let text = fs.readFile(path)\r\n      if str.contains(text, needle) == true {\r\n        return matches.append({\r\n          path: path\r\n        })\r\n      }\r\n      return matches\r\n    }\r\n\r\n    let entries = fs.readDir(path)\r\n    for i, entry in entries {\r\n      if this.ignore.shouldIgnoreName(entry.name) == true {\r\n        continue\r\n      }\r\n      matches = this.scan(entry.path, needle, matches)\r\n    }\r\n    return matches\r\n  }\r\n\r\n  // run 执行文本搜索工具。\r\n  run(config, input) {\r\n    let path = object.get(input, \"path\")\r\n    let query = object.get(input, \"query\")\r\n    if path == null || path == \"\" {\r\n      return {\r\n        ok: false,\r\n        error: \"searchText requires non-empty path\"\r\n      }\r\n    }\r\n    if query == null || query == \"\" {\r\n      return {\r\n        ok: false,\r\n        error: \"searchText requires non-empty query\"\r\n      }\r\n    }\r\n\r\n    path = this.toolPath.resolve(config, path)\r\n    if fs.exists(path) != true {\r\n      return {\r\n        ok: false,\r\n        error: \"search root not found: \" + path\r\n      }\r\n    }\r\n\r\n    let matches = this.scan(path, query, [])\r\n    return {\r\n      ok: true,\r\n      content: matches,\r\n      meta: {\r\n        path: path,\r\n        query: query,\r\n        count: len(matches)\r\n      }\r\n    }\r\n  }\r\n}\r\n",
    "src/tools/skill_tool.ic": "import std.core.object as object\nimport \"@/src/tools/list_skills.ic\" as listSkills\nimport \"@/src/tools/read_skill.ic\" as readSkill\nimport \"@/src/tools/remove_skill.ic\" as removeSkill\nimport \"@/src/tools/create_skill.ic\" as createSkill\nimport \"@/src/tools/update_skill.ic\" as updateSkill\n\nexport class SkillTool {\n  init(skillCatalog) {\n    this.skillCatalog = skillCatalog\n    this.listSkills = listSkills.ListSkills(this.skillCatalog)\n    this.readSkill = readSkill.ReadSkill(this.skillCatalog)\n    this.removeSkill = removeSkill.RemoveSkill(this.skillCatalog)\n    this.createSkill = createSkill.CreateSkill(this.skillCatalog)\n    this.updateSkill = updateSkill.UpdateSkill(this.skillCatalog)\n  }\n\n  run(config, input) {\n    let action = object.get(input, \"action\")\n    if typeOf(action) != \"string\" || action == \"\" {\n      return {\n        ok: false,\n        error: \"skill tool requires non-empty action\"\n      }\n    }\n\n    if action == \"list\" {\n      return this.listSkills.run(config, input)\n    }\n    if action == \"read\" {\n      return this.readSkill.run(config, input)\n    }\n    if action == \"create\" {\n      return this.createSkill.run(config, input)\n    }\n    if action == \"update\" {\n      return this.updateSkill.run(config, input)\n    }\n    if action == \"remove\" {\n      return this.removeSkill.run(config, input)\n    }\n\n    return {\n      ok: false,\n      error: \"unsupported skill action: \" + action\n    }\n  }\n}\n",
    "src/tools/tool_path.ic": "import std.io.fs as fs\nimport std.core.string as str\n\n// ToolPath 是一个解析工具路径的类。\nexport class ToolPath {\n  // resolve 解析工具路径。\n  // 如果路径以\"@/\"开头，则将其解析为工作空间路径的子路径。\n  // 否则，返回路径本身。\n  resolve(config, path) {\n    if path == null || path == \"\" {\n      return path\n    }\n    // 如果路径以\"@/\"开头，则将其解析为工作空间路径的子路径\n    if str.hasPrefix(path, \"@/\") {\n      let suffix = str.replace(path, \"@/\", \"\", 1)\n      return fs.join(config.workspace, suffix)\n    }\n    return path\n  }\n}\n\n",
    "src/tools/update_skill.ic": "import std.io.fs as fs\r\nimport std.core.object as object\r\n\r\nexport class UpdateSkill {\r\n  init(skillCatalog) {\r\n    this.skillCatalog = skillCatalog\r\n  }\r\n\r\n  run(config, input) {\r\n    let skillId = object.get(input, \"skill\")\r\n    if typeOf(skillId) != \"string\" || skillId == \"\" {\r\n      return {\r\n        ok: false,\r\n        error: \"updateSkill requires non-empty skill\"\r\n      }\r\n    }\r\n\r\n    let skill = this.skillCatalog.findById(config, skillId)\r\n    if skill == null {\r\n      return {\r\n        ok: false,\r\n        error: \"skill not found: \" + skillId\r\n      }\r\n    }\r\n\r\n    let content = object.get(input, \"content\")\r\n    if typeOf(content) != \"string\" || content == \"\" {\r\n      let existing = fs.readFile(skill.skillFile)\r\n      let parsed = this.skillCatalog.parseFrontmatter(existing)\r\n      let name = object.get(input, \"name\", skill.id)\r\n      let description = object.get(input, \"description\", parsed.description)\r\n      let body = object.get(input, \"body\")\r\n      if typeOf(body) != \"string\" || body == \"\" {\r\n        body = this.skillCatalog.extractBody(existing)\r\n      }\r\n      if typeOf(description) != \"string\" || description == \"\" {\r\n        return {\r\n          ok: false,\r\n          error: \"updateSkill requires description when the existing skill has none\"\r\n        }\r\n      }\r\n      content = this.skillCatalog.buildSkillDocument(skill.id, name, description, body)\r\n    }\r\n\r\n    fs.writeFile(skill.skillFile, content)\r\n\r\n    return {\r\n      ok: true,\r\n      updated: skill.id,\r\n      meta: skill\r\n    }\r\n  }\r\n}\r\n",
    "src/tools/web_common.ic": "import std.core.string as str\r\nimport std.data.json as json\r\n\r\n// WebCommon 是一个通用的Web工具类。\r\nexport class WebCommon {\r\n  // after 提取字符串中指定标记之后的内容。\r\n  after(text, marker) {\r\n    let parts = str.split(text, marker)\r\n    if len(parts) \u003c 2 {\r\n      return \"\"\r\n    }\r\n    return parts[1]\r\n  }\r\n\r\n  // between 提取字符串中两个标记之间的内容。\r\n  between(text, startMarker, endMarker) {\r\n    let tail = this.after(text, startMarker)\r\n    if tail == \"\" {\r\n      return \"\"\r\n    }\r\n    return str.split(tail, endMarker)[0]\r\n  }\r\n\r\n  // decodeEntities 解码HTML实体。\r\n  decodeEntities(text) {\r\n    text = str.replace(text, \"\u0026amp;\", \"\u0026\")\r\n    text = str.replace(text, \"\u0026lt;\", \"\u003c\")\r\n    text = str.replace(text, \"\u0026gt;\", \"\u003e\")\r\n    text = str.replace(text, \"\u0026quot;\", \"\\\"\")\r\n    text = str.replace(text, \"\u0026#39;\", \"'\")\r\n    text = str.replace(text, \"\u0026nbsp;\", \" \")\r\n    return text\r\n  }\r\n\r\n  // quoteChar 获取HTML实体中的引号。\r\n  quoteChar() {\r\n    return this.decodeEntities(\"\u0026quot;\")\r\n  }\r\n\r\n  // decodeJSONString 解码JSON字符串。\r\n  decodeJSONString(text) {\r\n    try {\r\n      let decoded = json.decode(text)\r\n      if typeOf(decoded) == \"string\" {\r\n        return decoded\r\n      }\r\n    } catch err {\r\n      return text\r\n    }\r\n    return text\r\n  }\r\n\r\n  // normalizeSpaces 规范化空格。\r\n  normalizeSpaces(text) {\r\n    text = str.replace(text, \"\\r\", \" \")\r\n    text = str.replace(text, \"\\n\", \" \")\r\n    text = str.replace(text, \"\\t\", \" \")\r\n\r\n    let parts = str.split(text, \" \")\r\n    let compact = []\r\n    for i, part in parts {\r\n      part = str.trimSpace(part)\r\n      if part == \"\" {\r\n        continue\r\n      }\r\n      compact = compact.append(part)\r\n    }\r\n    return str.join(compact, \" \")\r\n  }\r\n\r\n  // htmlToText 将HTML转换为文本。\r\n  htmlToText(html) {\r\n    html = this.decodeEntities(html)\r\n\r\n    let parts = str.split(html, \"\u003c\")\r\n    let chunks = []\r\n    for i, part in parts {\r\n      if i == 0 {\r\n        chunks = chunks.append(part)\r\n        continue\r\n      }\r\n\r\n      let inner = str.split(part, \"\u003e\")\r\n      let j = 1\r\n      while j \u003c len(inner) {\r\n        chunks = chunks.append(inner[j])\r\n        j = j + 1\r\n      }\r\n    }\r\n\r\n    return this.normalizeSpaces(str.join(chunks, \" \"))\r\n  }\r\n\r\n  // clipText 截取文本，确保不超过最大字符数。\r\n  clipText(text, maxChars) {\r\n    if typeOf(maxChars) != \"int\" || maxChars \u003c= 0 {\r\n      return text\r\n    }\r\n    if len(text) \u003c= maxChars {\r\n      return text\r\n    }\r\n\r\n    let parts = str.split(text, \" \")\r\n    let clipped = \"\"\r\n    for i, part in parts {\r\n      part = str.trimSpace(part)\r\n      if part == \"\" {\r\n        continue\r\n      }\r\n\r\n      let next = part\r\n      if clipped != \"\" {\r\n        next = clipped + \" \" + part\r\n      }\r\n      if len(next) \u003e maxChars {\r\n        break\r\n      }\r\n      clipped = next\r\n    }\r\n\r\n    if clipped == \"\" {\r\n      return text\r\n    }\r\n    return clipped\r\n  }\r\n\r\n  // extractTitle 从HTML中提取标题。\r\n  extractTitle(html) {\r\n    let title = this.between(html, \"\u003ctitle\u003e\", \"\u003c/title\u003e\")\r\n    if title == \"\" {\r\n      title = this.between(html, \"\u003cTITLE\u003e\", \"\u003c/TITLE\u003e\")\r\n    }\r\n    return this.normalizeSpaces(this.decodeEntities(title))\r\n  }\r\n\r\n  // extractSnippet 从HTML中提取片段。\r\n  extractSnippet(chunk) {\r\n    let tail = this.after(chunk, \"result__snippet\")\r\n    if tail == \"\" {\r\n      return \"\"\r\n    }\r\n\r\n    let parts = str.split(tail, \"\u003e\")\r\n    if len(parts) \u003c 2 {\r\n      return \"\"\r\n    }\r\n    return this.htmlToText(parts[1])\r\n  }\r\n  \r\n  // parseDuckDuckGoResults 解析DuckDuckGo搜索结果。\r\n  parseDuckDuckGoResults(html, maxResults) {\r\n    let results = []\r\n    let limit = maxResults\r\n    if typeOf(limit) != \"int\" || limit \u003c= 0 {\r\n      limit = 5\r\n    }\r\n\r\n    // DuckDuckGo HTML results are anchor-heavy. Split on `\u003ca ` first, then\r\n    // keep only anchors that carry the `result__a` class.\r\n    let parts = str.split(html, \"\u003ca \")\r\n    let i = 0\r\n    while i \u003c len(parts) \u0026\u0026 len(results) \u003c limit {\r\n      let chunk = parts[i]\r\n      if str.contains(chunk, \"result__a\") != true {\r\n        i = i + 1\r\n        continue\r\n      }\r\n\r\n      let hrefTail = this.after(chunk, \"href=\")\r\n      if hrefTail == \"\" {\r\n        i = i + 1\r\n        continue\r\n      }\r\n      let anchorParts = str.split(hrefTail, \"\u003e\")\r\n      if len(anchorParts) \u003c 2 {\r\n        i = i + 1\r\n        continue\r\n      }\r\n      let url = this.decodeJSONString(anchorParts[0])\r\n\r\n      let titleHtml = str.split(anchorParts[1], \"\u003c/a\u003e\")[0]\r\n      let title = this.htmlToText(titleHtml)\r\n      let snippet = this.extractSnippet(chunk)\r\n      if title != \"\" \u0026\u0026 url != \"\" {\r\n        results = results.append({\r\n          title: title,\r\n          url: url,\r\n          snippet: snippet\r\n        })\r\n      }\r\n      i = i + 1\r\n    }\r\n\r\n    return results\r\n  }\r\n}\r\n\r\n",
    "src/tools/web_fetch.ic": "import std.net.http.client as http\r\nimport std.core.object as object\r\n\r\n// WebFetch 是一个从URL获取文本的工具。\r\nexport class WebFetch {\r\n  init(webCommon) {\r\n    this.webCommon = webCommon\r\n  }\r\n\r\n  run(config, input) {\r\n    let url = object.get(input, \"url\")\r\n    let maxChars = object.get(input, \"maxChars\", 4000)\r\n    if url == null || url == \"\" {\r\n      return {\r\n        ok: false,\r\n        error: \"webFetch requires non-empty url\"\r\n      }\r\n    }\r\n\r\n    let response = http.request({\r\n      url: url,\r\n      method: \"GET\",\r\n      headers: {\r\n        Accept: \"text/html,application/xhtml+xml\",\r\n        \"User-Agent\": \"icoo-agent/1.0\"\r\n      },\r\n      followRedirects: true\r\n    })\r\n    if response.ok != true {\r\n      return {\r\n        ok: false,\r\n        error: \"webFetch http request failed: \" + response.statusText\r\n      }\r\n    }\r\n\r\n    let body = object.get(response, \"body\", \"\")\r\n    let title = this.webCommon.extractTitle(body)\r\n    let text = this.webCommon.clipText(\r\n      this.webCommon.htmlToText(body),\r\n      maxChars\r\n    )\r\n    return {\r\n      ok: true,\r\n      content: text,\r\n      meta: {\r\n        url: object.get(response, \"url\", url),\r\n        title: title,\r\n        status: response.status,\r\n        contentLength: response.contentLength\r\n      }\r\n    }\r\n  }\r\n}\r\n",
    "src/tools/web_search.ic": "import std.net.http.client as http\r\nimport std.core.object as object\r\n\r\n// WebSearch 是一个从DuckDuckGo搜索的工具。\r\nexport class WebSearch {\r\n  // init 初始化 WebSearch。\r\n  init(webCommon) {\r\n    this.webCommon = webCommon\r\n  }\r\n\r\n  // run 执行搜索。\r\n  run(config, input) {\r\n    let query = object.get(input, \"query\")\r\n    let maxResults = object.get(input, \"maxResults\", 5)\r\n    let endpoint = object.get(input, \"endpoint\", \"https://html.duckduckgo.com/html/\")\r\n    if query == null || query == \"\" {\r\n      return {\r\n        ok: false,\r\n        error: \"webSearch requires non-empty query\"\r\n      }\r\n    }\r\n\r\n    let response = http.request({\r\n      url: endpoint,\r\n      method: \"GET\",\r\n      query: {\r\n        q: query\r\n      },\r\n      headers: {\r\n        Accept: \"text/html,application/xhtml+xml\",\r\n        \"User-Agent\": \"icoo-agent/1.0\"\r\n      },\r\n      followRedirects: true\r\n    })\r\n    if response.ok != true {\r\n      return {\r\n        ok: false,\r\n        error: \"webSearch http request failed: \" + response.statusText\r\n      }\r\n    }\r\n\r\n    let body = object.get(response, \"body\", \"\")\r\n    let results = this.webCommon.parseDuckDuckGoResults(body, maxResults)\r\n    return {\r\n      ok: true,\r\n      content: results,\r\n      meta: {\r\n        engine: \"duckduckgo\",\r\n        query: query,\r\n        count: len(results),\r\n        url: object.get(response, \"url\", endpoint)\r\n      }\r\n    }\r\n  }\r\n}\r\n"
  }
}