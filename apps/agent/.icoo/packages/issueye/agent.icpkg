{
  "version": 1,
  "kind": "package",
  "entry": "src/main.ic",
  "entry_function": "main",
  "root_alias": "@",
  "package_name": "issueye/agent",
  "package_version": "0.1.2",
  "export": "src/app/app.ic",
  "modules": {
    "src/app/app.ic": "import std.io.console as io\nimport \"pkg:issueye/agent/pkg/config\" as agentConfig\nimport \"@/src/context/budget.ic\" as budget\nimport \"@/src/context/builder.ic\" as contextBuilder\nimport \"@/src/context/ignore.ic\" as ignore\nimport \"@/src/model/client.ic\" as modelClient\nimport \"@/src/model/messages.ic\" as modelMessages\nimport \"@/src/model/parser.ic\" as modelParser\nimport \"pkg:issueye/agent/pkg/session\" as agentSession\nimport \"@/src/runtime/runtime.ic\" as runtime\nimport \"@/src/skills/catalog.ic\" as skills\nimport \"pkg:issueye/agent/pkg/tools\" as agentTools\n\r\nexport class App {\n  init() {\n    this.argsConfig = agentConfig.ArgsConfig()\n    this.defaultsConfig = agentConfig.Defaults()\n    this.envConfig = agentConfig.EnvConfig()\n    this.configFile = agentConfig.ConfigFile()\n    this.mergeConfig = agentConfig.MergeConfig(\n      this.defaultsConfig,\n      this.argsConfig,\n      this.envConfig,\n      this.configFile\r\n    )\r\n\r\n    this.toolPath = agentTools.ToolPath()\n    this.ignore = ignore.Ignore()\n    this.webCommon = agentTools.WebCommon()\n    this.skillCatalog = skills.SkillCatalog()\n    this.toolRegistry = agentTools.ToolRegistry(\n      this.toolPath,\n      this.ignore,\n      this.webCommon,\n      this.skillCatalog\n    )\n    this.toolExecutor = agentTools.ToolExecutor(this.toolRegistry)\n\r\n    this.modelMessages = modelMessages.ModelMessages(this.toolRegistry)\r\n    this.modelParser = modelParser.ModelParser()\r\n    this.modelClient = modelClient.ModelClient(this.modelMessages, this.modelParser)\r\n\r\n    this.budget = budget.Budget()\r\n    this.contextBuilder = contextBuilder.ContextBuilder(this.ignore, this.budget, this.skillCatalog)\r\n    this.sessionSchema = agentSession.Schema()\n    this.sessionStore = agentSession.SessionStore(this.sessionSchema)\n    this.runtime = runtime.Runtime(\r\n      this.contextBuilder,\r\n      this.modelClient,\r\n      this.modelMessages,\r\n      this.sessionStore,\r\n      this.toolExecutor\r\n    )\r\n  }\r\n\r\n  loadConfig(overrides) {\r\n    return this.mergeConfig.loadConfig(overrides)\r\n  }\r\n\r\n  start(overrides) {\r\n    let loaded = this.loadConfig(overrides)\r\n    let cfg = loaded.config\r\n    if loaded.help == true {\r\n      io.println(loaded.helpText)\r\n      return {\r\n        ok: true,\r\n        help: true,\r\n        config: cfg\r\n      }\r\n    }\r\n    return this.runtime.start(cfg)\r\n  }\r\n\r\n  stop(runtimeApp) {\r\n    return runtimeApp\r\n  }\r\n\r\n  main() {\r\n    return this.start(null)\r\n  }\r\n}\r\n",
    "src/context/budget.ic": "// 上下文预算配置\r\nexport class Budget {\r\n  // 创建上下文预算\r\n  create(config) {\r\n    return {\r\n      maxFiles: config.maxFiles,\r\n      maxTotalBytes: config.maxTotalBytes,\r\n      maxDepth: 3\r\n    }\r\n  }\r\n}\r\n",
    "src/context/builder.ic": "import std.io.fs as fs\r\nimport std.core.string as str\r\nimport \"@/src/context/budget.ic\" as budget\r\nimport \"@/src/context/ignore.ic\" as ignore\r\n\r\nexport class ContextBuilder {\r\n  init(ignoreRule, contextBudget, skillCatalog) {\r\n    this.ignore = ignoreRule\r\n    this.budget = contextBudget\r\n    this.skillCatalog = skillCatalog\r\n  }\r\n\r\n  isPreviewable(path) {\r\n    return (\r\n      str.hasSuffix(path, \".ic\") ||\r\n      str.hasSuffix(path, \".md\") ||\r\n      str.hasSuffix(path, \".txt\") ||\r\n      str.hasSuffix(path, \".json\") ||\r\n      str.hasSuffix(path, \".toml\") ||\r\n      str.hasSuffix(path, \".yaml\") ||\r\n      str.hasSuffix(path, \".yml\") ||\r\n      str.hasSuffix(path, \".go\") ||\r\n      str.hasSuffix(path, \".js\") ||\r\n      str.hasSuffix(path, \".ts\")\r\n    )\r\n  }\r\n\r\n  fileItem(path, size, included, preview, omittedReason) {\r\n    return {\r\n      path: path,\r\n      size: size,\r\n      kind: \"file\",\r\n      included: included,\r\n      preview: preview,\r\n      omittedReason: omittedReason\r\n    }\r\n  }\r\n\r\n  pushOmitted(state, path, reason) {\r\n    state.omittedCount = state.omittedCount + 1\r\n    state.omitted = state.omitted.append({\r\n      path: path,\r\n      reason: reason\r\n    })\r\n  }\r\n\r\n  summarizeFile(path, info, state) {\r\n    if state.fileCount \u003e= state.budget.maxFiles {\r\n      return\r\n    }\r\n\r\n    state.fileCount = state.fileCount + 1\r\n\r\n    if state.totalBytes + info.size \u003e state.budget.maxTotalBytes {\r\n      this.pushOmitted(state, path, \"budget exceeded\")\r\n      state.files = state.files.append(this.fileItem(path, info.size, false, null, \"budget exceeded\"))\r\n      return\r\n    }\r\n\r\n    let preview = null\r\n    if this.isPreviewable(path) == true {\r\n      preview = fs.readFile(path)\r\n    }\r\n\r\n    state.totalBytes = state.totalBytes + info.size\r\n    state.files = state.files.append(this.fileItem(path, info.size, true, preview, null))\r\n  }\r\n\r\n  scan(path, depth, state) {\r\n    if depth \u003e state.budget.maxDepth {\r\n      this.pushOmitted(state, path, \"max depth reached\")\r\n      return\r\n    }\r\n    if state.fileCount \u003e= state.budget.maxFiles {\r\n      return\r\n    }\r\n\r\n    let info = fs.stat(path)\r\n    if info.isFile {\r\n      this.summarizeFile(path, info, state)\r\n      return\r\n    }\r\n\r\n    let entries = fs.readDir(path)\r\n    for i, entry in entries {\r\n      if state.fileCount \u003e= state.budget.maxFiles {\r\n        break\r\n      }\r\n      if this.ignore.shouldIgnoreName(entry.name) == true {\r\n        this.pushOmitted(state, entry.path, \"ignored by name\")\r\n        continue\r\n      }\r\n\r\n      if entry.isDir {\r\n        this.scan(entry.path, depth + 1, state)\r\n        continue\r\n      }\r\n\r\n      this.summarizeFile(entry.path, fs.stat(entry.path), state)\r\n    }\r\n  }\r\n\r\n  build(config) {\r\n    let state = {\r\n      budget: this.budget.create(config),\r\n      fileCount: 0,\r\n      totalBytes: 0,\r\n      omittedCount: 0,\r\n      files: [],\r\n      omitted: []\r\n    }\r\n\r\n    this.scan(config.workspace, 0, state)\r\n\r\n    return {\r\n      workspace: config.workspace,\r\n      summary: {\r\n        fileCount: state.fileCount,\r\n        totalBytes: state.totalBytes,\r\n        omittedCount: state.omittedCount,\r\n        maxFiles: state.budget.maxFiles,\r\n        maxTotalBytes: state.budget.maxTotalBytes,\r\n        maxDepth: state.budget.maxDepth\r\n      },\r\n      skillsSummary: this.skillCatalog.summary(config),\r\n      files: state.files,\r\n      omitted: state.omitted\r\n    }\r\n  }\r\n}\r\n",
    "src/context/ignore.ic": "import std.core.string as str\r\n\r\n// 忽略文件名\r\nexport class Ignore{\r\n  shouldIgnoreName(name) {\r\n    if name == \".git\" || name == \"node_modules\" || name == \"dist\" || name == \"build\" {\r\n      return true\r\n    }\r\n    if str.hasPrefix(name, \".\") {\r\n      return true\r\n    }\r\n    return false\r\n  }\r\n}\r\n",
    "src/main.ic": "import \"@/src/app/app.ic\" as appModule\r\n\r\nfn main() {\r\n  let app = appModule.App()\r\n  app.main()\r\n}\r\n",
    "src/model/client.ic": "import std.net.http.client as http\r\nimport std.io.console as io\r\nimport std.core.object as object\r\nimport std.core.string as str\r\nimport std.data.json as json\r\n\r\nexport class ModelClient {\r\n  init(modelMessages, modelParser) {\r\n    this.messages = modelMessages\r\n    this.parser = modelParser\r\n  }\r\n\r\n  shouldStreamFinalAnswer(config, builtMessages) {\r\n    if config.streamFinalAnswer != true {\r\n      return false\r\n    }\r\n\r\n    for i, message in builtMessages {\r\n      if message.role == \"tool\" {\r\n        return true\r\n      }\r\n    }\r\n    return false\r\n  }\r\n\r\n  tryParseStreamLine(line) {\r\n    if str.hasPrefix(line, \"data: \") != true {\r\n      return null\r\n    }\r\n    let raw = str.split(line, \"data: \")[1]\r\n    if raw == \"[DONE]\" {\r\n      return {\r\n        done: true\r\n      }\r\n    }\r\n\r\n    try {\r\n      return {\r\n        done: false,\r\n        json: json.decode(raw)\r\n      }\r\n    } catch err {\r\n      return null\r\n    }\r\n  }\r\n\r\n  requestRemoteStream(config, payload) {\r\n    let stream = http.requestStream({\r\n      url: config.baseUrl + \"/chat/completions\",\r\n      method: \"POST\",\r\n      headers: {\r\n        Authorization: \"Bearer \" + config.apiKey,\r\n        Accept: \"text/event-stream\",\r\n        \"Content-Type\": \"application/json\"\r\n      },\r\n      body: json.encode(payload)\r\n    })\r\n\r\n    let state = {\r\n      text: \"\",\r\n      reasoningContent: \"\",\r\n      toolCalls: [],\r\n      finishReason: null,\r\n      hasToolCalls: false,\r\n      deltaText: \"\"\r\n    }\r\n    let printed = false\r\n    let startedOutput = false\r\n\r\n    try {\r\n      let text = stream.readAll()\r\n      let lines = str.split(text, \"\\n\")\r\n      for i, rawLine in lines {\r\n        let line = str.trimSpace(rawLine)\r\n        if line == \"\" {\r\n          continue\r\n        }\r\n\r\n        let parsedLine = this.tryParseStreamLine(line)\r\n        if parsedLine == null {\r\n          continue\r\n        }\r\n        if parsedLine.done == true {\r\n          break\r\n        }\r\n\r\n        state = this.parser.parseStreamEvent(parsedLine.json, state)\r\n        if state.sawToolCallDelta == true {\r\n          panic(\"stream emitted tool_calls; fallback to non-streaming response\")\r\n        }\r\n        if state.deltaText != \"\" {\r\n          if startedOutput != true {\r\n            io.println(\"streaming final answer:\")\r\n            startedOutput = true\r\n          }\r\n          io.print(state.deltaText)\r\n          printed = true\r\n        }\r\n      }\r\n    } finally {\r\n      stream.close()\r\n    }\r\n\r\n    if printed == true {\r\n      io.println(\"\")\r\n    }\r\n\r\n    return {\r\n      mode: \"remote\",\r\n      text: state.text,\r\n      reasoningContent: state.reasoningContent,\r\n      raw: null,\r\n      toolCalls: state.toolCalls,\r\n      hasToolCalls: state.hasToolCalls,\r\n      finishReason: state.finishReason\r\n    }\r\n  }\r\n\r\n  localFallback(context) {\r\n    return {\r\n      mode: \"local\",\r\n      text:\r\n        \"Summary\\n\" +\r\n        \"- Remote model is disabled because no API key is configured.\\n\" +\r\n        \"- Workspace context was collected successfully.\\n\\n\" +\r\n        \"Risks\\n\" +\r\n        \"- This fallback does not yet perform model-grade reasoning.\\n\" +\r\n        \"- Tool-calling requires a remote OpenAI-compatible model endpoint.\\n\\n\" +\r\n        \"Next Steps\\n\" +\r\n        \"- Configure `ICOO_AGENTS_API_KEY` to enable remote model calls.\\n\" +\r\n        \"- Keep extending tool coverage and session persistence on top of the current runtime loop.\\n\\n\" +\r\n        \"Context Summary\\n\" +\r\n        context.summaryJson,\r\n      reasoningContent: null,\r\n      toolCalls: [],\r\n      hasToolCalls: false\r\n    }\r\n  }\r\n\r\n  requestRemote(config, payload) {\r\n    let response = http.requestJSON({\r\n      url: config.baseUrl + \"/chat/completions\",\r\n      method: \"POST\",\r\n      headers: {\r\n        Authorization: \"Bearer \" + config.apiKey\r\n      },\r\n      json: payload\r\n    })\r\n\r\n    let parsed = this.parser.parseResponse(response.json)\r\n    if parsed.ok == true {\r\n      return {\r\n        mode: \"remote\",\r\n        text: parsed.text,\r\n        reasoningContent: parsed.reasoningContent,\r\n        raw: response.json,\r\n        toolCalls: parsed.toolCalls,\r\n        hasToolCalls: parsed.hasToolCalls,\r\n        finishReason: parsed.finishReason\r\n      }\r\n    }\r\n\r\n    return {\r\n      mode: \"remote\",\r\n      text: json.encode(response.json),\r\n      raw: response.json,\r\n      reasoningContent: null,\r\n      toolCalls: [],\r\n      hasToolCalls: false,\r\n      finishReason: null\r\n    }\r\n  }\r\n\r\n  request(config, context) {\r\n    if config.apiKey == null || config.apiKey == \"\" {\r\n      return this.localFallback(context)\r\n    }\r\n\r\n    return this.requestRemote(config, {\r\n      model: config.model,\r\n      temperature: 0.2,\r\n      messages: this.messages.build(config, context),\r\n      tools: this.messages.toolDefinitions()\r\n    })\r\n  }\r\n\r\n  requestWithMessages(config, builtMessages) {\r\n    if config.apiKey == null || config.apiKey == \"\" {\r\n      return {\r\n        mode: \"local\",\r\n        text: \"Local fallback does not emulate multi-turn tool calling.\",\r\n        reasoningContent: null,\r\n        toolCalls: [],\r\n        hasToolCalls: false,\r\n        finishReason: null\r\n      }\r\n    }\r\n\r\n    let payload = {\r\n      model: config.model,\r\n      temperature: 0.2,\r\n      messages: builtMessages,\r\n      tools: this.messages.toolDefinitions()\r\n    }\r\n\r\n    if this.shouldStreamFinalAnswer(config, builtMessages) == true {\r\n      try {\r\n        return this.requestRemoteStream(config, object.merge(payload, {\r\n          stream: true\r\n        }))\r\n      } catch err {\r\n        return this.requestRemote(config, payload)\r\n      }\r\n    }\r\n\r\n    return this.requestRemote(config, payload)\r\n  }\r\n}\r\n",
    "src/model/messages.ic": "import std.data.json as json\r\nimport std.core.object as object\r\n\r\nexport class ModelMessages {\r\n  init(toolRegistry) {\r\n    this.toolRegistry = toolRegistry\r\n  }\r\n\r\n  systemPrompt() {\r\n    return \"You are an Icoo agent. Be concise, repository-aware, and action-oriented. Use tools when repository inspection is required before answering.\"\r\n  }\r\n\r\n  userPrompt(config, context) {\r\n    let text = \"\"\r\n    if config.task != null \u0026\u0026 config.task != \"\" {\r\n      text = text + \"Task:\\n\" + config.task + \"\\n\\n\"\r\n    } else {\r\n      text = text + \"Task:\\nSummarize the repository state and suggest the next concrete engineering step.\\n\\n\"\r\n    }\r\n    text = text + \"Workspace:\\n\" + context.workspace + \"\\n\\n\"\r\n    if typeOf(context.cliUnknownArgs) == \"array\" \u0026\u0026 len(context.cliUnknownArgs) \u003e 0 {\r\n      text = text + \"CLI Unknown Args:\\n\" + json.encode(context.cliUnknownArgs) + \"\\n\\n\"\r\n    }\r\n    let skillsSummary = object.get(context, \"skillsSummary\")\r\n    if typeOf(skillsSummary) == \"string\" \u0026\u0026 skillsSummary != \"\" {\r\n      text = text + skillsSummary + \"\\n\\n\"\r\n    }\r\n    text = text + \"Context Summary:\\n\" + context.summaryJson + \"\\n\"\r\n    return text\r\n  }\r\n\r\n  buildBase(config, context) {\r\n    return [\r\n      {\r\n        role: \"system\",\r\n        content: this.systemPrompt()\r\n      },\r\n      {\r\n        role: \"user\",\r\n        content: this.userPrompt(config, context)\r\n      }\r\n    ]\r\n  }\r\n\r\n  build(config, context) {\r\n    return this.buildBase(config, context)\r\n  }\r\n\r\n  toolDefinitions() {\r\n    return this.toolRegistry.definitions()\r\n  }\r\n\r\n  appendAssistantToolCalls(messages, toolCalls, content, reasoningContent) {\r\n    let assistantContent = content\r\n    if assistantContent == null {\r\n      assistantContent = \"\"\r\n    }\r\n    let assistantMessage = {\r\n      role: \"assistant\",\r\n      content: assistantContent,\r\n      tool_calls: toolCalls\r\n    }\r\n    if reasoningContent != null \u0026\u0026 reasoningContent != \"\" {\r\n      assistantMessage.reasoning_content = reasoningContent\r\n    }\r\n    return messages.append(assistantMessage)\r\n  }\r\n\r\n  appendToolResult(messages, toolCallId, name, output) {\r\n    return messages.append({\r\n      role: \"tool\",\r\n      tool_call_id: toolCallId,\r\n      name: name,\r\n      content: json.encode(output)\r\n    })\r\n  }\r\n}\r\n",
    "src/model/parser.ic": "import std.core.object as object\r\n\r\n// 模型消息解析器\r\nexport class ModelParser {\r\n  // 追加助手工具调用消息\r\n  appendDeltaToolCalls(toolCalls, rawToolCalls) {\r\n    if typeOf(rawToolCalls) != \"array\" {\r\n      return toolCalls\r\n    }\r\n\r\n    for i, rawCall in rawToolCalls {\r\n      if typeOf(rawCall) != \"object\" {\r\n        continue\r\n      }\r\n\r\n      let callId = object.get(rawCall, \"id\", \"\")\r\n      let callIndex = object.get(rawCall, \"index\", -1)\r\n      let matched = false\r\n      let nextCalls = []\r\n      for j, existing in toolCalls {\r\n        let existingId = object.get(existing, \"id\", \"\")\r\n        let existingIndex = object.get(existing, \"streamIndex\", -1)\r\n        let sameCall = false\r\n        if callId != \"\" \u0026\u0026 existingId == callId {\r\n          sameCall = true\r\n        }\r\n        if callId == \"\" \u0026\u0026 callIndex \u003e= 0 \u0026\u0026 existingIndex == callIndex {\r\n          sameCall = true\r\n        }\r\n\r\n        if sameCall != true {\r\n          nextCalls = nextCalls.append(existing)\r\n          continue\r\n        }\r\n\r\n        let existingFn = object.get(existing, \"function\", {})\r\n        let deltaFn = object.get(rawCall, \"function\", {})\r\n        nextCalls = nextCalls.append({\r\n          id: callId,\r\n          streamIndex: callIndex,\r\n          type: object.get(rawCall, \"type\", object.get(existing, \"type\", \"function\")),\r\n          function: {\r\n            name: object.get(deltaFn, \"name\", object.get(existingFn, \"name\", \"\")),\r\n            arguments:\r\n              object.get(existingFn, \"arguments\", \"\") +\r\n              object.get(deltaFn, \"arguments\", \"\")\r\n          }\r\n        })\r\n        matched = true\r\n      }\r\n\r\n      if matched == true {\r\n        toolCalls = nextCalls\r\n        continue\r\n      }\r\n\r\n      let fnDef = object.get(rawCall, \"function\", {})\r\n      toolCalls = toolCalls.append({\r\n        id: callId,\r\n        streamIndex: callIndex,\r\n        type: object.get(rawCall, \"type\", \"function\"),\r\n        function: {\r\n          name: object.get(fnDef, \"name\", \"\"),\r\n          arguments: object.get(fnDef, \"arguments\", \"\")\r\n        }\r\n      })\r\n    }\r\n\r\n    return toolCalls\r\n  }\r\n\r\n  // 归一化内容\r\n  normalizeContent(content) {\r\n    if typeOf(content) == \"string\" {\r\n      return content\r\n    }\r\n    if typeOf(content) == \"array\" {\r\n      let text = \"\"\r\n      for i, part in content {\r\n        if typeOf(part) == \"string\" {\r\n          text = text + part\r\n          continue\r\n        }\r\n        if typeOf(part) != \"object\" {\r\n          continue\r\n        }\r\n        if object.get(part, \"type\") == \"text\" {\r\n          text = text + object.get(part, \"text\", \"\")\r\n        }\r\n      }\r\n      return text\r\n    }\r\n    return \"\"\r\n  }\r\n\r\n  // 归一化工具调用消息\r\n  normalizeToolCalls(rawToolCalls) {\r\n    if typeOf(rawToolCalls) != \"array\" {\r\n      return []\r\n    }\r\n\r\n    let calls = []\r\n    for i, rawCall in rawToolCalls {\r\n      if typeOf(rawCall) != \"object\" {\r\n        continue\r\n      }\r\n      let fnDef = object.get(rawCall, \"function\", {})\r\n      calls = calls.append({\r\n        id: object.get(rawCall, \"id\", \"\"),\r\n        type: object.get(rawCall, \"type\", \"function\"),\r\n        function: {\r\n          name: object.get(fnDef, \"name\", \"\"),\r\n          arguments: object.get(fnDef, \"arguments\", \"\")\r\n        }\r\n      })\r\n    }\r\n    return calls\r\n  }\r\n\r\n  // 解析选择消息\r\n  parseChoiceMessage(message) {\r\n    let content = this.normalizeContent(object.get(message, \"content\"))\r\n    let toolCalls = this.normalizeToolCalls(object.get(message, \"tool_calls\"))\r\n    // 部分 provider 会返回 reasoning_content，并要求下一轮 assistant 消息原样回放。\r\n    let reasoningContent = object.get(message, \"reasoning_content\")\r\n    return {\r\n      ok: true,\r\n      text: content,\r\n      reasoningContent: reasoningContent,\r\n      finishReason: null,\r\n      toolCalls: toolCalls,\r\n      hasToolCalls: len(toolCalls) \u003e 0\r\n    }\r\n  }\r\n\r\n  // 解析模型响应\r\n  parseResponse(payload) {\r\n    let choices = object.get(payload, \"choices\")\r\n    if typeOf(choices) == \"array\" \u0026\u0026 len(choices) \u003e 0 {\r\n      let first = choices[0]\r\n      let message = object.get(first, \"message\")\r\n      if typeOf(message) == \"object\" {\r\n        let parsed = this.parseChoiceMessage(message)\r\n        parsed.finishReason = object.get(first, \"finish_reason\")\r\n        return parsed\r\n      }\r\n    }\r\n\r\n    let outputText = object.get(payload, \"output_text\")\r\n    if typeOf(outputText) == \"string\" {\r\n      return {\r\n        ok: true,\r\n        text: outputText,\r\n        reasoningContent: null,\r\n        finishReason: null,\r\n        toolCalls: [],\r\n        hasToolCalls: false\r\n      }\r\n    }\r\n\r\n    return {\r\n      ok: false,\r\n      text: null,\r\n      reasoningContent: null,\r\n      finishReason: null,\r\n      toolCalls: [],\r\n      hasToolCalls: false\r\n    }\r\n  }\r\n\r\n  // 解析模型流事件\r\n  parseStreamEvent(payload, state) {\r\n    let choices = object.get(payload, \"choices\")\r\n    if typeOf(choices) != \"array\" || len(choices) == 0 {\r\n      return state\r\n    }\r\n\r\n    let first = choices[0]\r\n    let delta = object.get(first, \"delta\", {})\r\n    let deltaContent = this.normalizeContent(object.get(delta, \"content\"))\r\n    let deltaReasoning = this.normalizeContent(object.get(delta, \"reasoning_content\"))\r\n    let rawToolCalls = object.get(delta, \"tool_calls\")\r\n    let nextToolCalls = this.appendDeltaToolCalls(\r\n      object.get(state, \"toolCalls\", []),\r\n      rawToolCalls\r\n    )\r\n\r\n    return {\r\n      text: object.get(state, \"text\", \"\") + deltaContent,\r\n      reasoningContent: object.get(state, \"reasoningContent\", \"\") + deltaReasoning,\r\n      toolCalls: nextToolCalls,\r\n      finishReason: object.get(first, \"finish_reason\"),\r\n      hasToolCalls: len(nextToolCalls) \u003e 0,\r\n      deltaText: deltaContent,\r\n      sawToolCallDelta: typeOf(rawToolCalls) == \"array\" \u0026\u0026 len(rawToolCalls) \u003e 0\r\n    }\r\n  }\r\n}\r\n\r\n",
    "src/runtime/runtime.ic": "import std.io.console as io\r\nimport std.data.json as json\r\n\r\nexport class Runtime {\r\n  init(contextBuilder, modelClient, modelMessages, sessionStore, toolExecutor) {\r\n    this.ctxBuilder = contextBuilder\r\n    this.modelClient = modelClient\r\n    this.modelMessages = modelMessages\r\n    this.sessionStore = sessionStore\r\n    this.toolExecutor = toolExecutor\r\n  }\r\n\r\n  printListPreview(label, items, limit) {\r\n    if typeOf(items) != \"array\" || len(items) == 0 {\r\n      io.println(label + \":\", \"[]\")\r\n      return\r\n    }\r\n\r\n    let preview = items.take(limit)\r\n    io.println(label + \":\", json.encode(preview))\r\n  }\r\n\r\n  appendToolResults(config, session, messages, toolCalls, toolRuns) {\r\n    for i, call in toolCalls {\r\n      let executed = this.toolExecutor.runCall(config, call)\r\n      toolRuns = toolRuns.append(executed)\r\n      this.sessionStore.appendToolMessage(config, session, executed)\r\n      messages = this.modelMessages.appendToolResult(\r\n        messages,\r\n        executed.toolCallId,\r\n        executed.name,\r\n        executed.output\r\n      )\r\n    }\r\n\r\n    return {\r\n      messages: messages,\r\n      toolRuns: toolRuns\r\n    }\r\n  }\r\n\r\n  runToolLoop(config, session, context) {\r\n    let userPrompt = this.modelMessages.userPrompt(config, context)\r\n    let builtContext = {\r\n      userPrompt: userPrompt\r\n    }\r\n    let messages = this.sessionStore.buildMessages(config, builtContext, session)\r\n    if len(session.turns) == 0 {\r\n      let userMessage = {\r\n        role: \"user\",\r\n        content: userPrompt\r\n      }\r\n      this.sessionStore.appendUserMessage(config, session, userMessage)\r\n      messages = this.sessionStore.buildMessages(config, builtContext, session)\r\n    }\r\n\r\n    let requests = []\r\n    let toolRuns = []\r\n    let finalResult = null\r\n    let stopReason = \"max turns reached\"\r\n    let turn = 0\r\n\r\n    while turn \u003c config.maxTurns {\r\n      turn = turn + 1\r\n      this.sessionStore.appendRequestSnapshot(config, session, messages)\r\n      let response = this.modelClient.requestWithMessages(config, messages)\r\n      this.sessionStore.appendAssistantMessage(config, session, response)\r\n      requests = requests.append(response)\r\n      finalResult = response\r\n\r\n      if response.hasToolCalls != true {\r\n        stopReason = \"assistant response completed\"\r\n        break\r\n      }\r\n\r\n      messages = this.modelMessages.appendAssistantToolCalls(\r\n        messages,\r\n        response.toolCalls,\r\n        response.text,\r\n        response.reasoningContent\r\n      )\r\n      let appended = this.appendToolResults(config, session, messages, response.toolCalls, toolRuns)\r\n      messages = appended.messages\r\n      toolRuns = appended.toolRuns\r\n    }\r\n\r\n    if len(requests) == 0 {\r\n      return {\r\n        first: null,\r\n        final: {\r\n          mode: \"local\",\r\n          text: \"No model request was executed.\",\r\n          reasoningContent: null,\r\n          toolCalls: [],\r\n          hasToolCalls: false,\r\n          finishReason: null\r\n        },\r\n        toolRuns: [],\r\n        requests: [],\r\n        turnsUsed: 0,\r\n        stopReason: \"no request\"\r\n      }\r\n    }\r\n\r\n    return {\r\n      first: requests.first(),\r\n      final: finalResult,\r\n      toolRuns: toolRuns,\r\n      requests: requests,\r\n      turnsUsed: len(requests),\r\n      stopReason: stopReason\r\n    }\r\n  }\r\n\r\n  start(config) {\r\n    let opened = this.sessionStore.open(config)\r\n    let session = opened.session\r\n    let context = this.ctxBuilder.build(config)\r\n    let modelContext = {\r\n      workspace: context.workspace,\r\n      summaryJson: json.encode(context.summary),\r\n      files: context.files,\r\n      omitted: context.omitted,\r\n      cliUnknownArgs: config.cliUnknownArgs\r\n    }\r\n    let modelLoop = this.runToolLoop(config, session, modelContext)\r\n    this.sessionStore.markCompleted(config, session, {\r\n      turnsUsed: modelLoop.turnsUsed,\r\n      stopReason: modelLoop.stopReason,\r\n      mode: modelLoop.final.mode\r\n    })\r\n\r\n    io.println(\"== \" + config.agentName + \" ==\")\r\n    io.println(\"workspace:\", config.workspace)\r\n    io.println(\"mode:\", config.mode)\r\n    io.println(\"model:\", config.model)\r\n    io.println(\"approval:\", config.approval)\r\n    io.println(\"session id:\", session.sessionId)\r\n    io.println(\"resume:\", config.resumeSession)\r\n    io.println(\"session dir:\", config.sessionDir)\r\n    io.println(\"session path:\", opened.path)\r\n    io.println(\"session resumed:\", opened.resumed)\r\n    io.println(\"log path:\", config.logPath)\r\n    io.println(\"max turns:\", config.maxTurns)\r\n    io.println(\"max files:\", config.maxFiles)\r\n    io.println(\"max total bytes:\", config.maxTotalBytes)\r\n    this.printListPreview(\"cli unknown args\", config.cliUnknownArgs, 6)\r\n    io.println(\"context summary:\", json.encode(context.summary))\r\n    this.printListPreview(\"context files\", context.files, 3)\r\n    this.printListPreview(\"context omitted\", context.omitted, 3)\r\n    io.println(\"\")\r\n    io.println(\"model mode:\", modelLoop.final.mode)\r\n    io.println(\"turns used:\", modelLoop.turnsUsed)\r\n    io.println(\"stop reason:\", modelLoop.stopReason)\r\n    io.println(\"tool calls:\", len(modelLoop.toolRuns))\r\n    io.println(\"session stored turns:\", len(session.turns))\r\n    if len(modelLoop.toolRuns) \u003e 0 {\r\n      this.printListPreview(\"tool run preview\", modelLoop.toolRuns, 2)\r\n    }\r\n    io.println(\"model output:\")\r\n    io.println(modelLoop.final.text)\r\n\r\n    return {\r\n      ok: true,\r\n      config: config,\r\n      session: session,\r\n      sessionPath: opened.path,\r\n      context: context,\r\n      model: modelLoop.final,\r\n      toolRuns: modelLoop.toolRuns,\r\n      firstModel: modelLoop.first,\r\n      modelRequests: modelLoop.requests,\r\n      turnsUsed: modelLoop.turnsUsed,\r\n      stopReason: modelLoop.stopReason\r\n    }\r\n  }\r\n}\r\n",
    "src/skills/catalog.ic": "import std.io.fs as fs\r\nimport std.sys.os as os\r\nimport std.core.string as str\r\n\r\nexport class SkillCatalog {\r\n  primaryDir(config) {\r\n    let dirs = this.configuredDirs(config)\r\n    if len(dirs) == 0 {\r\n      return null\r\n    }\r\n    return dirs[0]\r\n  }\r\n\r\n  defaultDir(config) {\r\n    let agentHome = os.getEnv(\"ICOO_AGENTS_HOME\")\r\n    if typeOf(agentHome) == \"string\" \u0026\u0026 agentHome != \"\" {\r\n      return fs.join(agentHome, \"skills\")\r\n    }\r\n\r\n    let userProfile = os.getEnv(\"USERPROFILE\")\r\n    if typeOf(userProfile) == \"string\" \u0026\u0026 userProfile != \"\" {\r\n      return fs.join(fs.join(userProfile, \".agents\"), \"skills\")\r\n    }\r\n\r\n    return fs.join(fs.join(config.workspace, \".agents\"), \"skills\")\r\n  }\r\n\r\n  configuredDirs(config) {\r\n    let dirs = []\r\n\r\n    let explicit = config.skillsDir\r\n    if typeOf(explicit) == \"string\" \u0026\u0026 explicit != \"\" {\r\n      dirs = dirs.append(explicit)\r\n    }\r\n\r\n    let workspaceDir = fs.join(fs.join(config.workspace, \".agents\"), \"skills\")\r\n    if this.hasDir(dirs, workspaceDir) != true {\r\n      dirs = dirs.append(workspaceDir)\r\n    }\r\n\r\n    let defaultDir = this.defaultDir(config)\r\n    if this.hasDir(dirs, defaultDir) != true {\r\n      dirs = dirs.append(defaultDir)\r\n    }\r\n\r\n    return dirs\r\n  }\r\n\r\n  hasDir(dirs, path) {\r\n    for i, dir in dirs {\r\n      if dir == path {\r\n        return true\r\n      }\r\n    }\r\n    return false\r\n  }\r\n\r\n  stripQuotes(value) {\r\n    if typeOf(value) != \"string\" {\r\n      return value\r\n    }\r\n    let text = str.trimSpace(value)\r\n    if len(text) \u003e= 2 \u0026\u0026 str.hasPrefix(text, \"\\\"\") \u0026\u0026 str.hasSuffix(text, \"\\\"\") {\r\n      let parts = str.split(text, \"\\\"\")\r\n      if len(parts) \u003e= 3 {\r\n        return str.join(parts.slice(1, len(parts) - 1), \"\\\"\")\r\n      }\r\n    }\r\n    if len(text) \u003e= 2 \u0026\u0026 str.hasPrefix(text, \"'\") \u0026\u0026 str.hasSuffix(text, \"'\") {\r\n      let parts = str.split(text, \"'\")\r\n      if len(parts) \u003e= 3 {\r\n        return str.join(parts.slice(1, len(parts) - 1), \"'\")\r\n      }\r\n    }\r\n    return text\r\n  }\r\n\r\n  extractQuoted(line, quote) {\r\n    let parts = str.split(line, quote)\r\n    if len(parts) \u003e= 3 {\r\n      return str.join(parts.slice(1, len(parts) - 1), quote)\r\n    }\r\n    return null\r\n  }\r\n\r\n  extractBody(content) {\r\n    let lines = str.split(content, \"\\n\")\r\n    if len(lines) == 0 || str.trimSpace(lines[0]) != \"---\" {\r\n      return content\r\n    }\r\n\r\n    let index = 1\r\n    while index \u003c len(lines) {\r\n      if str.trimSpace(lines[index]) == \"---\" {\r\n        let bodyLines = lines.slice(index + 1)\r\n        return str.join(bodyLines, \"\\n\")\r\n      }\r\n      index = index + 1\r\n    }\r\n\r\n    return content\r\n  }\r\n\r\n  isValidSkillId(skillId) {\r\n    if typeOf(skillId) != \"string\" || skillId == \"\" {\r\n      return false\r\n    }\r\n    if str.indexOf(skillId, \"/\") \u003e= 0 || str.indexOf(skillId, \"\\\\\") \u003e= 0 {\r\n      return false\r\n    }\r\n    if str.indexOf(skillId, \":\") \u003e= 0 || str.indexOf(skillId, \"..\") \u003e= 0 {\r\n      return false\r\n    }\r\n    if str.indexOf(skillId, \" \") \u003e= 0 || str.hasPrefix(skillId, \".\") {\r\n      return false\r\n    }\r\n    return true\r\n  }\r\n\r\n  buildSkillDocument(skillId, name, description, body) {\r\n    let finalName = name\r\n    if typeOf(finalName) != \"string\" || finalName == \"\" {\r\n      finalName = skillId\r\n    }\r\n\r\n    let finalBody = body\r\n    if typeOf(finalBody) != \"string\" || finalBody == \"\" {\r\n      finalBody = \"# \" + finalName + \"\\n\"\r\n    }\r\n\r\n    return (\r\n      \"---\\n\" +\r\n      \"name: \" + finalName + \"\\n\" +\r\n      \"description: \" + description + \"\\n\" +\r\n      \"---\\n\\n\" +\r\n      finalBody\r\n    )\r\n  }\r\n\r\n  parseFrontmatter(content) {\r\n    let lines = str.split(content, \"\\n\")\r\n    if len(lines) == 0 || str.trimSpace(lines[0]) != \"---\" {\r\n      return {\r\n        hasFrontmatter: false,\r\n        name: null,\r\n        description: null\r\n      }\r\n    }\r\n\r\n    let name = null\r\n    let description = null\r\n    let index = 1\r\n    while index \u003c len(lines) {\r\n      let line = str.trimSpace(lines[index])\r\n      if line == \"---\" {\r\n        break\r\n      }\r\n      if str.hasPrefix(line, \"name:\") {\r\n        let quoted = this.extractQuoted(line, \"\\\"\")\r\n        if quoted != null {\r\n          name = quoted\r\n        } else {\r\n          quoted = this.extractQuoted(line, \"'\")\r\n          if quoted != null {\r\n            name = quoted\r\n          } else {\r\n            let parts = str.split(line, \":\")\r\n            if len(parts) \u003e 1 {\r\n              name = this.stripQuotes(str.join(parts.slice(1, len(parts)), \":\"))\r\n            }\r\n          }\r\n        }\r\n      }\r\n      if str.hasPrefix(line, \"description:\") {\r\n        let quoted = this.extractQuoted(line, \"\\\"\")\r\n        if quoted != null {\r\n          description = quoted\r\n        } else {\r\n          quoted = this.extractQuoted(line, \"'\")\r\n          if quoted != null {\r\n            description = quoted\r\n          } else {\r\n            let parts = str.split(line, \":\")\r\n            if len(parts) \u003e 1 {\r\n              description = this.stripQuotes(str.join(parts.slice(1, len(parts)), \":\"))\r\n            }\r\n          }\r\n        }\r\n      }\r\n      index = index + 1\r\n    }\r\n\r\n    return {\r\n      hasFrontmatter: true,\r\n      name: name,\r\n      description: description\r\n    }\r\n  }\r\n\r\n  buildSkill(dirPath) {\r\n    let skillFile = fs.join(dirPath, \"SKILL.md\")\r\n    if fs.exists(skillFile) != true {\r\n      return null\r\n    }\r\n    let info = fs.stat(skillFile)\r\n    if info.isFile != true {\r\n      return null\r\n    }\r\n\r\n    let content = fs.readFile(skillFile)\r\n    let parsed = this.parseFrontmatter(content)\r\n    let slug = fs.base(dirPath)\r\n\r\n    return {\r\n      id: slug,\r\n      name: parsed.name,\r\n      description: parsed.description,\r\n      dir: dirPath,\r\n      skillFile: skillFile,\r\n      hasFrontmatter: parsed.hasFrontmatter\r\n    }\r\n  }\r\n\r\n  listDir(dirPath) {\r\n    if fs.exists(dirPath) != true {\r\n      return []\r\n    }\r\n    let info = fs.stat(dirPath)\r\n    if info.isDir != true {\r\n      return []\r\n    }\r\n\r\n    let skills = []\r\n    let entries = fs.readDir(dirPath)\r\n    for i, entry in entries {\r\n      if entry.isDir != true {\r\n        continue\r\n      }\r\n      let skill = this.buildSkill(entry.path)\r\n      if skill != null {\r\n        skills = skills.append(skill)\r\n      }\r\n    }\r\n    return skills\r\n  }\r\n\r\n  list(config) {\r\n    let items = []\r\n    let seen = []\r\n    let dirs = this.configuredDirs(config)\r\n    for i, dirPath in dirs {\r\n      let skills = this.listDir(dirPath)\r\n      for j, skill in skills {\r\n        if this.hasDir(seen, skill.skillFile) == true {\r\n          continue\r\n        }\r\n        seen = seen.append(skill.skillFile)\r\n        items = items.append(skill)\r\n      }\r\n    }\r\n    return items\r\n  }\r\n\r\n  findById(config, skillId) {\r\n    let items = this.list(config)\r\n    for i, skill in items {\r\n      if skill.id == skillId {\r\n        return skill\r\n      }\r\n      if skill.name == skillId {\r\n        return skill\r\n      }\r\n    }\r\n    return null\r\n  }\r\n\r\n  summary(config) {\r\n    let items = this.list(config)\r\n    if len(items) == 0 {\r\n      return \"Available Skills:\\n- none discovered\"\r\n    }\r\n\r\n    let text = \"Available Skills:\\n\"\r\n    for i, skill in items {\r\n      let label = skill.id\r\n      if typeOf(skill.name) == \"string\" \u0026\u0026 skill.name != \"\" {\r\n        label = label + \" (\" + skill.name + \")\"\r\n      }\r\n      text = text + \"- \" + label\r\n      if typeOf(skill.description) == \"string\" \u0026\u0026 skill.description != \"\" {\r\n        text = text + \": \" + skill.description\r\n      }\r\n      text = text + \"\\n\"\r\n    }\r\n    return text\r\n  }\r\n}\r\n"
  },
  "packages": {
    ".icoo/packages/issueye/agent/pkg/config.icpkg": {
      "version": 1,
      "kind": "package",
      "entry": "src/main.ic",
      "entry_function": "main",
      "root_alias": "@",
      "package_name": "issueye/agent/pkg/config",
      "package_version": "0.1.2",
      "export": "src/main.ic",
      "modules": {
        "src/args.ic": "import std.sys.cli as cli\r\nimport std.core.string as str\r\n\r\nexport class ArgsConfig {\r\n  argvList() {\r\n    return argv()\r\n  }\r\n\r\n  isHelpRequest() {\r\n    let values = this.argvList()\r\n    for i, value in values {\r\n      if value == \"--help\" || value == \"-h\" {\r\n        return true\r\n      }\r\n    }\r\n    return false\r\n  }\r\n\r\n  hasWorkspaceArg() {\r\n    let values = this.argvList()\r\n    let index = 0\r\n    while index \u003c len(values) {\r\n      let value = values[index]\r\n      if value == \"--workspace\" || value == \"--root\" {\r\n        return index + 1 \u003c len(values)\r\n      }\r\n      if str.hasPrefix(value, \"--workspace=\") || str.hasPrefix(value, \"--root=\") {\r\n        return true\r\n      }\r\n      index = index + 1\r\n    }\r\n    return false\r\n  }\r\n\r\n  defineApp() {\r\n    let app = cli.create({\r\n      name: \"icoo-agent\",\r\n      description: \"Pure Icoo agent entry with OpenAI-compatible tool-calling runtime\",\r\n      allowUnknownArgs: true\r\n    })\r\n\r\n    app.flagString({\r\n      name: \"workspace\",\r\n      aliases: [\"root\"],\r\n      description: \"Workspace root path for context collection\"\r\n    })\r\n    app.flagString({\r\n      name: \"mode\",\r\n      description: \"Runtime mode such as interactive or batch\"\r\n    })\r\n    app.flagString({\r\n      name: \"model\",\r\n      description: \"Remote model name\"\r\n    })\r\n    app.flagString({\r\n      name: \"base-url\",\r\n      aliases: [\"api-base\"],\r\n      description: \"OpenAI-compatible base URL\"\r\n    })\r\n    app.flagString({\r\n      name: \"api-key\",\r\n      description: \"Remote model API key\"\r\n    })\r\n    app.flagString({\r\n      name: \"task\",\r\n      description: \"Top-level engineering task prompt\"\r\n    })\r\n    app.flagString({\r\n      name: \"session\",\r\n      description: \"Explicit session id\"\r\n    })\r\n    app.flagString({\r\n      name: \"resume\",\r\n      description: \"Resume session id\"\r\n    })\r\n    app.flagString({\r\n      name: \"approval\",\r\n      description: \"Approval mode\"\r\n    })\r\n    app.flagString({\r\n      name: \"skills-dir\",\r\n      description: \"Skill directory to discover SKILL.md folders from\"\r\n    })\r\n    app.flagString({\r\n      name: \"session-dir\",\r\n      description: \"Directory for session files\"\r\n    })\r\n    app.flagString({\r\n      name: \"log-path\",\r\n      description: \"Runtime log path\"\r\n    })\r\n    app.flagInt({\r\n      name: \"max-turns\",\r\n      description: \"Maximum model request turns\"\r\n    })\r\n    app.flagInt({\r\n      name: \"max-files\",\r\n      description: \"Maximum context files\"\r\n    })\r\n    app.flagInt({\r\n      name: \"max-total-bytes\",\r\n      aliases: [\"context-bytes\"],\r\n      description: \"Maximum context bytes\"\r\n    })\r\n    app.flagString({\r\n      name: \"stream-final-answer\",\r\n      description: \"Enable or disable streaming for the final assistant answer\"\r\n    })\r\n    app.flagString({\r\n      name: \"agent-name\",\r\n      description: \"Display name for the agent runtime\"\r\n    })\r\n\r\n    return app\r\n  }\r\n\r\n  applyIfString(config, value, key) {\r\n    if typeOf(value) == \"string\" \u0026\u0026 value != \"\" {\r\n      config[key] = value\r\n    }\r\n    return config\r\n  }\r\n\r\n  applyIfInt(config, value, key) {\r\n    if typeOf(value) == \"int\" {\r\n      config[key] = value\r\n    }\r\n    return config\r\n  }\r\n\r\n  applyIfBoolString(config, value, key) {\r\n    if value == \"true\" {\r\n      config[key] = true\r\n    }\r\n    if value == \"false\" {\r\n      config[key] = false\r\n    }\r\n    return config\r\n  }\r\n\r\n  applyArgs(config) {\r\n    let app = this.defineApp()\r\n    if this.isHelpRequest() == true {\r\n      return {\r\n        config: config,\r\n        help: true,\r\n        helpText: app.help()\r\n      }\r\n    }\r\n    let parsed = app.run()\r\n\r\n    let flags = parsed.flags\r\n    config = this.applyIfString(config, flags.workspace, \"workspace\")\r\n    config = this.applyIfString(config, flags.mode, \"mode\")\r\n    config = this.applyIfString(config, flags.model, \"model\")\r\n    config = this.applyIfString(config, flags[\"base-url\"], \"baseUrl\")\r\n    config = this.applyIfString(config, flags[\"api-key\"], \"apiKey\")\r\n    config = this.applyIfString(config, flags.task, \"task\")\r\n    config = this.applyIfString(config, flags.session, \"sessionId\")\r\n    config = this.applyIfString(config, flags.resume, \"resumeSession\")\r\n    config = this.applyIfString(config, flags.approval, \"approval\")\r\n    config = this.applyIfString(config, flags[\"skills-dir\"], \"skillsDir\")\r\n    config = this.applyIfString(config, flags[\"session-dir\"], \"sessionDir\")\r\n    config = this.applyIfString(config, flags[\"log-path\"], \"logPath\")\r\n    config = this.applyIfInt(config, flags[\"max-turns\"], \"maxTurns\")\r\n    config = this.applyIfInt(config, flags[\"max-files\"], \"maxFiles\")\r\n    config = this.applyIfInt(config, flags[\"max-total-bytes\"], \"maxTotalBytes\")\r\n    config = this.applyIfBoolString(config, flags[\"stream-final-answer\"], \"streamFinalAnswer\")\r\n    config = this.applyIfString(config, flags[\"agent-name\"], \"agentName\")\r\n\r\n    if this.hasWorkspaceArg() != true {\r\n      panic(\"missing required flag: --workspace\")\r\n    }\r\n\r\n    config.cliUnknownArgs = parsed.unknown\r\n\r\n    return {\r\n      config: config,\r\n      help: false,\r\n      helpText: null\r\n    }\r\n  }\r\n\r\n  previewWorkspace(config) {\r\n    let values = this.argvList()\r\n    let index = 0\r\n    while index \u003c len(values) {\r\n      let value = values[index]\r\n      if value == \"--workspace\" || value == \"--root\" {\r\n        if index + 1 \u003c len(values) {\r\n          config.workspace = values[index + 1]\r\n        }\r\n        break\r\n      }\r\n      if str.hasPrefix(value, \"--workspace=\") {\r\n        let parts = str.split(value, \"=\")\r\n        if len(parts) \u003e 1 {\r\n          config.workspace = parts[1]\r\n        }\r\n        break\r\n      }\r\n      if str.hasPrefix(value, \"--root=\") {\r\n        let parts = str.split(value, \"=\")\r\n        if len(parts) \u003e 1 {\r\n          config.workspace = parts[1]\r\n        }\r\n        break\r\n      }\r\n      index = index + 1\r\n    }\r\n    return config\r\n  }\r\n}\r\n\r\nlet argsApi = ArgsConfig()\r\n\r\nexport {\r\n  applyArgs: argsApi.applyArgs,\r\n  previewWorkspace: argsApi.previewWorkspace,\r\n  ArgsConfig: ArgsConfig\r\n}\r\n",
        "src/defaults.ic": "import std.io.fs as fs\r\nimport std.sys.os as os\r\n\r\nexport class Defaults {\r\n  defaultConfig() {\r\n    let stateDir = fs.join(os.cwd(), \".agents\")\r\n    return {\r\n      workspace: os.cwd(),\r\n      mode: \"interactive\",\r\n      model: \"gpt-4.1-mini\",\r\n      baseUrl: \"https://api.openai.com/v1\",\r\n      apiKey: null,\r\n      task: null,\r\n      sessionId: null,\r\n      resumeSession: null,\r\n      approval: \"on-request\",\r\n      maxTurns: 12,\r\n      maxFiles: 24,\r\n      maxTotalBytes: 32768,\r\n      streamFinalAnswer: true,\r\n      agentName: \"icoo_agents\",\r\n      skillsDir: null,\r\n      sessionDir: fs.join(stateDir, \"sessions\"),\r\n      logPath: fs.join(stateDir, \"agent.log\"),\r\n      cliUnknownArgs: []\r\n    }\r\n  }\r\n}\r\n",
        "src/env.ic": "import std.sys.os as os\r\nimport std.math.basic as math\r\n\r\nexport class EnvConfig {\r\n  parseIntOr(value, fallback) {\r\n    try {\r\n      return math.parseInt(value)\r\n    } catch err {\r\n      return fallback\r\n    }\r\n  }\r\n\r\n  applyEnv(config) {\r\n    let workspace = os.getEnv(\"ICOO_AGENTS_WORKSPACE\")\r\n    if workspace != null {\r\n      config.workspace = workspace\r\n    }\r\n\r\n    let mode = os.getEnv(\"ICOO_AGENTS_MODE\")\r\n    if mode != null {\r\n      config.mode = mode\r\n    }\r\n\r\n    let model = os.getEnv(\"ICOO_AGENTS_MODEL\")\r\n    if model != null {\r\n      config.model = model\r\n    }\r\n\r\n    let baseUrl = os.getEnv(\"ICOO_AGENTS_BASE_URL\")\r\n    if baseUrl != null {\r\n      config.baseUrl = baseUrl\r\n    }\r\n\r\n    let apiKey = os.getEnv(\"ICOO_AGENTS_API_KEY\")\r\n    if apiKey != null {\r\n      config.apiKey = apiKey\r\n    }\r\n\r\n    let task = os.getEnv(\"ICOO_AGENTS_TASK\")\r\n    if task != null {\r\n      config.task = task\r\n    }\r\n\r\n    let sessionId = os.getEnv(\"ICOO_AGENTS_SESSION_ID\")\r\n    if sessionId != null {\r\n      config.sessionId = sessionId\r\n    }\r\n\r\n    let resumeSession = os.getEnv(\"ICOO_AGENTS_RESUME\")\r\n    if resumeSession != null {\r\n      config.resumeSession = resumeSession\r\n    }\r\n\r\n    let approval = os.getEnv(\"ICOO_AGENTS_APPROVAL\")\r\n    if approval != null {\r\n      config.approval = approval\r\n    }\r\n\r\n    let skillsDir = os.getEnv(\"ICOO_AGENTS_SKILLS_DIR\")\r\n    if skillsDir != null {\r\n      config.skillsDir = skillsDir\r\n    }\r\n\r\n    let sessionDir = os.getEnv(\"ICOO_AGENTS_SESSION_DIR\")\r\n    if sessionDir != null {\r\n      config.sessionDir = sessionDir\r\n    }\r\n\r\n    let logPath = os.getEnv(\"ICOO_AGENTS_LOG_PATH\")\r\n    if logPath != null {\r\n      config.logPath = logPath\r\n    }\r\n\r\n    let maxTurns = os.getEnv(\"ICOO_AGENTS_MAX_TURNS\")\r\n    if maxTurns != null {\r\n      config.maxTurns = this.parseIntOr(maxTurns, config.maxTurns)\r\n    }\r\n\r\n    let maxFiles = os.getEnv(\"ICOO_AGENTS_MAX_FILES\")\r\n    if maxFiles != null {\r\n      config.maxFiles = this.parseIntOr(maxFiles, config.maxFiles)\r\n    }\r\n\r\n    let maxTotalBytes = os.getEnv(\"ICOO_AGENTS_MAX_TOTAL_BYTES\")\r\n    if maxTotalBytes != null {\r\n      config.maxTotalBytes = this.parseIntOr(maxTotalBytes, config.maxTotalBytes)\r\n    }\r\n\r\n    return config\r\n  }\r\n}\r\n",
        "src/file.ic": "import std.core.object as object\r\nimport std.core.string as str\r\nimport std.data.toml as toml\r\nimport std.io.fs as fs\r\n\r\nexport class ConfigFile {\r\n  applyString(config, value, key) {\r\n    if typeOf(value) == \"string\" \u0026\u0026 value != \"\" {\r\n      config[key] = value\r\n    }\r\n    return config\r\n  }\r\n\r\n  applyInt(config, value, key) {\r\n    if typeOf(value) == \"int\" {\r\n      config[key] = value\r\n    }\r\n    return config\r\n  }\r\n\r\n  applyBool(config, value, key) {\r\n    if typeOf(value) == \"bool\" {\r\n      config[key] = value\r\n    }\r\n    return config\r\n  }\r\n\r\n  resolveConfigPath(config) {\r\n    let workspace = config.workspace\r\n    if typeOf(workspace) != \"string\" || workspace == \"\" {\r\n      return null\r\n    }\r\n\r\n    let normalized = workspace\r\n    if str.hasSuffix(normalized, \"/\") || str.hasSuffix(normalized, \"\\\\\") {\r\n      normalized = fs.dir(normalized + \"x\")\r\n    }\r\n    return fs.join(normalized, \"config.toml\")\r\n  }\r\n\r\n  isAbsolutePath(path) {\r\n    if typeOf(path) != \"string\" || path == \"\" {\r\n      return false\r\n    }\r\n    if str.hasPrefix(path, \"/\") || str.hasPrefix(path, \"\\\\\") {\r\n      return true\r\n    }\r\n    return str.indexOf(path, \":\") == 1\r\n  }\r\n\r\n  resolvePathValue(configDir, value) {\r\n    if typeOf(value) != \"string\" || value == \"\" {\r\n      return value\r\n    }\r\n    if this.isAbsolutePath(value) == true {\r\n      return value\r\n    }\r\n    return fs.join(configDir, value)\r\n  }\r\n\r\n  applyFile(config) {\r\n    let filePath = this.resolveConfigPath(config)\r\n    if filePath == null || fs.exists(filePath) != true {\r\n      return config\r\n    }\r\n    let configDir = fs.dir(filePath)\r\n\r\n    let loaded = toml.fromFile(filePath)\r\n    if typeOf(loaded) != \"object\" {\r\n      return config\r\n    }\r\n\r\n    config = this.applyString(config, object.get(loaded, \"workspace\"), \"workspace\")\r\n    config = this.applyString(config, object.get(loaded, \"mode\"), \"mode\")\r\n    config = this.applyString(config, object.get(loaded, \"model\"), \"model\")\r\n    config = this.applyString(config, object.get(loaded, \"base_url\"), \"baseUrl\")\r\n    config = this.applyString(config, object.get(loaded, \"api_key\"), \"apiKey\")\r\n    config = this.applyString(config, object.get(loaded, \"task\"), \"task\")\r\n    config = this.applyString(config, object.get(loaded, \"session\"), \"sessionId\")\r\n    config = this.applyString(config, object.get(loaded, \"resume\"), \"resumeSession\")\r\n    config = this.applyString(config, object.get(loaded, \"approval\"), \"approval\")\r\n    config = this.applyString(\r\n      config,\r\n      this.resolvePathValue(configDir, object.get(loaded, \"skills_dir\")),\r\n      \"skillsDir\"\r\n    )\r\n    config = this.applyString(\r\n      config,\r\n      this.resolvePathValue(configDir, object.get(loaded, \"session_dir\")),\r\n      \"sessionDir\"\r\n    )\r\n    config = this.applyString(\r\n      config,\r\n      this.resolvePathValue(configDir, object.get(loaded, \"log_path\")),\r\n      \"logPath\"\r\n    )\r\n    config = this.applyInt(config, object.get(loaded, \"max_turns\"), \"maxTurns\")\r\n    config = this.applyInt(config, object.get(loaded, \"max_files\"), \"maxFiles\")\r\n    config = this.applyInt(config, object.get(loaded, \"max_total_bytes\"), \"maxTotalBytes\")\r\n    config = this.applyBool(config, object.get(loaded, \"stream_final_answer\"), \"streamFinalAnswer\")\r\n    config = this.applyString(config, object.get(loaded, \"agent_name\"), \"agentName\")\r\n\r\n    return config\r\n  }\r\n}\r\n\r\nlet fileApi = ConfigFile()\r\n\r\nexport {\r\n  applyFile: fileApi.applyFile,\r\n  resolveConfigPath: fileApi.resolveConfigPath,\r\n  resolvePathValue: fileApi.resolvePathValue,\r\n  ConfigFile: ConfigFile\r\n}\r\n",
        "src/main.ic": "import \"./args.ic\" as args\nimport \"./defaults.ic\" as defaults\nimport \"./env.ic\" as env\nimport \"./file.ic\" as file\nimport \"./merge.ic\" as merge\n\nconst ArgsConfig = args.ArgsConfig\nconst Defaults = defaults.Defaults\nconst EnvConfig = env.EnvConfig\nconst ConfigFile = file.ConfigFile\nconst MergeConfig = merge.MergeConfig\n\nexport { ArgsConfig, Defaults, EnvConfig, ConfigFile, MergeConfig }\n\nfn main() {\n  return null\n}\n",
        "src/merge.ic": "import std.core.object as object\r\n\r\nexport class MergeConfig {\r\n  init(defaultsConfig, argsConfig, envConfig, configFile) {\r\n    this.defaults = defaultsConfig\r\n    this.argsConfig = argsConfig\r\n    this.envConfig = envConfig\r\n    this.configFile = configFile\r\n  }\r\n\r\n  loadConfig(overrides) {\r\n    let config = this.defaults.defaultConfig()\r\n    config = this.argsConfig.previewWorkspace(config)\r\n    config = this.configFile.applyFile(config)\r\n    config = this.envConfig.applyEnv(config)\r\n\r\n    let argResult = this.argsConfig.applyArgs(config)\r\n    config = argResult.config\r\n\r\n    if overrides != null {\r\n      config = object.merge(config, overrides)\r\n    }\r\n\r\n    return {\r\n      config: config,\r\n      help: argResult.help,\r\n      helpText: argResult.helpText\r\n    }\r\n  }\r\n}\r\n"
      }
    },
    ".icoo/packages/issueye/agent/pkg/session.icpkg": {
      "version": 1,
      "kind": "package",
      "entry": "src/main.ic",
      "entry_function": "main",
      "root_alias": "@",
      "package_name": "issueye/agent/pkg/session",
      "package_version": "0.1.2",
      "export": "src/main.ic",
      "modules": {
        "src/main.ic": "import \"./schema.ic\" as schema\nimport \"./store.ic\" as store\n\nconst Schema = schema.Schema\nconst SessionStore = store.SessionStore\n\nexport { Schema, SessionStore }\n\nfn main() {\n  return null\n}\n",
        "src/schema.ic": "import std.time.basic as time\r\n\r\n// 会话数据库 schema 定义\r\nexport class Schema {\r\n  // Session 数据库 schema 版本\r\n  sessionSchemaVersion() {\r\n    return 2\r\n  }\r\n\r\n  // 归一化会话 ID，确保唯一性\r\n  normalizeSessionId(config) {\r\n    if config.resumeSession != null \u0026\u0026 config.resumeSession != \"\" {\r\n      return config.resumeSession\r\n    }\r\n    if config.sessionId != null \u0026\u0026 config.sessionId != \"\" {\r\n      return config.sessionId\r\n    }\r\n    return \"s_\" + time.format(time.now(), \"YYYYMMDD-HHmmss\", \"UTC\")\r\n  }\r\n\r\n  // 创建新会话\r\n  newSession(config, sessionId) {\r\n    let now = time.now()\r\n\r\n    // Session 作为顶层状态容器，后续所有 turn / event / artifact 都挂在这里。\r\n    return {\r\n      sessionSchemaVersion: this.sessionSchemaVersion(),\r\n      sessionId: sessionId,\r\n      workspace: config.workspace,\r\n      mode: config.mode,\r\n      status: \"idle\",\r\n      createdAt: now,\r\n      updatedAt: now,\r\n      config: {\r\n        model: config.model,\r\n        baseUrl: config.baseUrl,\r\n        approval: config.approval,\r\n        maxTurns: config.maxTurns,\r\n        maxFiles: config.maxFiles,\r\n        maxTotalBytes: config.maxTotalBytes\r\n      },\r\n      turns: [],\r\n      events: [],\r\n      artifacts: [],\r\n      budgets: {\r\n        turnCount: 0,\r\n        toolCallCount: 0\r\n      },\r\n      approvals: []\r\n    }\r\n  }\r\n\r\n  // 创建新 turn\r\n  newTurn(kind, payload) {\r\n    let now = time.now()\r\n    return {\r\n      kind: kind,\r\n      createdAt: now,\r\n      payload: payload\r\n    }\r\n  }\r\n\r\n  // 创建新用户消息 turn\r\n  userMessage(message) {\r\n    return this.newTurn(\"user_message\", message)\r\n  }\r\n\r\n  // 创建新请求快照 turn\r\n  requestSnapshot(messages) {\r\n    return this.newTurn(\"request_snapshot\", {\r\n      messages: messages\r\n    })\r\n  }\r\n\r\n  // 创建新助手消息 turn\r\n  assistantMessage(response) {\r\n    return this.newTurn(\"assistant_message\", {\r\n      role: \"assistant\",\r\n      content: response.text,\r\n      reasoningContent: response.reasoningContent,\r\n      toolCalls: response.toolCalls,\r\n      hasToolCalls: response.hasToolCalls,\r\n      finishReason: response.finishReason,\r\n      mode: response.mode\r\n    })\r\n  }\r\n\r\n  // 创建新工具消息 turn\r\n  toolMessage(executed) {\r\n    return this.newTurn(\"tool_message\", {\r\n      role: \"tool\",\r\n      toolCallId: executed.toolCallId,\r\n      name: executed.name,\r\n      output: executed.output,\r\n      ok: executed.ok,\r\n      error: executed.error\r\n    })\r\n  }\r\n\r\n  // 创建新运行摘要 turn\r\n  runSummary(summary) {\r\n    return this.newTurn(\"run_summary\", summary)\r\n  }\r\n}\r\n",
        "src/store.ic": "import std.data.json as json\r\nimport std.io.fs as fs\r\nimport std.sys.os as os\r\nimport std.time.basic as time\r\n\r\nexport class SessionStore {\r\n  init(sessionSchema) {\r\n    this.schema = sessionSchema\r\n  }\r\n\r\n  validateTurnKinds(turns, filePath) {\r\n    let allowed = {\r\n      user_message: true,\r\n      request_snapshot: true,\r\n      assistant_message: true,\r\n      tool_message: true,\r\n      run_summary: true\r\n    }\r\n    let deprecated = {\r\n      user_prompt: true,\r\n      request_messages: true,\r\n      assistant_response: true,\r\n      tool_result: true\r\n    }\r\n\r\n    for i, turn in turns {\r\n      let kind = turn.kind\r\n      if deprecated[kind] == true {\r\n        panic(\"deprecated session turn kind: \" + kind + \" in \" + filePath)\r\n      }\r\n      if allowed[kind] != true {\r\n        panic(\"unknown session turn kind in \" + filePath)\r\n      }\r\n    }\r\n  }\r\n\r\n  sessionPath(config, sessionId) {\r\n    return fs.join(config.sessionDir, sessionId + \".json\")\r\n  }\r\n\r\n  save(config, session) {\r\n    os.mkdirAll(config.sessionDir)\r\n    session.updatedAt = time.now()\r\n    let filePath = this.sessionPath(config, session.sessionId)\r\n    json.saveToFile(filePath, session)\r\n    return filePath\r\n  }\r\n\r\n  load(config, sessionId) {\r\n    let filePath = this.sessionPath(config, sessionId)\r\n    if fs.exists(filePath) != true {\r\n      return null\r\n    }\r\n\r\n    let loaded = json.fromFile(filePath)\r\n    if loaded == null || typeOf(loaded) != \"object\" {\r\n      panic(\"invalid session file: \" + filePath)\r\n    }\r\n    if loaded.sessionId == null || loaded.sessionId == \"\" {\r\n      panic(\"invalid session schema: missing sessionId\")\r\n    }\r\n    if loaded.sessionSchemaVersion != this.schema.sessionSchemaVersion() {\r\n      panic(\"unsupported session schema version: \" + loaded.sessionSchemaVersion)\r\n    }\r\n    if typeOf(loaded.turns) != \"array\" {\r\n      loaded.turns = []\r\n    }\r\n    if typeOf(loaded.events) != \"array\" {\r\n      loaded.events = []\r\n    }\r\n    if typeOf(loaded.artifacts) != \"array\" {\r\n      loaded.artifacts = []\r\n    }\r\n    if typeOf(loaded.approvals) != \"array\" {\r\n      loaded.approvals = []\r\n    }\r\n    if typeOf(loaded.budgets) != \"object\" {\r\n      loaded.budgets = {\r\n        turnCount: 0,\r\n        toolCallCount: 0\r\n      }\r\n    }\r\n    this.validateTurnKinds(loaded.turns, filePath)\r\n\r\n    return loaded\r\n  }\r\n\r\n  open(config) {\r\n    let sessionId = this.schema.normalizeSessionId(config)\r\n    let loaded = this.load(config, sessionId)\r\n    if loaded != null {\r\n      loaded.status = \"running\"\r\n      let loadedPath = this.save(config, loaded)\r\n      return {\r\n        session: loaded,\r\n        path: loadedPath,\r\n        resumed: true\r\n      }\r\n    }\r\n\r\n    let created = this.schema.newSession(config, sessionId)\r\n    created.status = \"running\"\r\n    let createdPath = this.save(config, created)\r\n    return {\r\n      session: created,\r\n      path: createdPath,\r\n      resumed: false\r\n    }\r\n  }\r\n\r\n  appendTurn(config, session, turn) {\r\n    session.turns = session.turns.append(turn)\r\n    session.budgets.turnCount = len(session.turns)\r\n    if turn.kind == \"tool_message\" {\r\n      session.budgets.toolCallCount = session.budgets.toolCallCount + 1\r\n    }\r\n    this.save(config, session)\r\n    return turn\r\n  }\r\n\r\n  appendUserMessage(config, session, message) {\r\n    return this.appendTurn(config, session, this.schema.userMessage(message))\r\n  }\r\n\r\n  appendRequestSnapshot(config, session, messages) {\r\n    return this.appendTurn(config, session, this.schema.requestSnapshot(messages))\r\n  }\r\n\r\n  appendAssistantMessage(config, session, response) {\r\n    return this.appendTurn(config, session, this.schema.assistantMessage(response))\r\n  }\r\n\r\n  appendToolMessage(config, session, executed) {\r\n    return this.appendTurn(config, session, this.schema.toolMessage(executed))\r\n  }\r\n\r\n  markCompleted(config, session, summary) {\r\n    session.status = \"completed\"\r\n    if summary != null {\r\n      session.lastResult = summary\r\n      this.appendTurn(config, session, this.schema.runSummary(summary))\r\n    }\r\n    return this.save(config, session)\r\n  }\r\n\r\n  buildMessages(config, context, session) {\r\n    let messages = [\r\n      {\r\n        role: \"system\",\r\n        content: \"You are an Icoo agent. Be concise, repository-aware, and action-oriented. Use tools when repository inspection is required before answering.\"\r\n      }\r\n    ]\r\n\r\n    let hasUserTurn = false\r\n    for i, turn in session.turns {\r\n      let payload = turn.payload\r\n      if turn.kind == \"user_message\" {\r\n        hasUserTurn = true\r\n        messages = messages.append(payload)\r\n        continue\r\n      }\r\n      if turn.kind == \"request_snapshot\" {\r\n        continue\r\n      }\r\n      if turn.kind == \"assistant_message\" {\r\n        let assistantMessage = {\r\n          role: \"assistant\",\r\n          content: payload.content\r\n        }\r\n        if payload.reasoningContent != null \u0026\u0026 payload.reasoningContent != \"\" {\r\n          assistantMessage.reasoning_content = payload.reasoningContent\r\n        }\r\n        if payload.hasToolCalls == true {\r\n          assistantMessage.tool_calls = payload.toolCalls\r\n        }\r\n        messages = messages.append(assistantMessage)\r\n        continue\r\n      }\r\n      if turn.kind == \"tool_message\" {\r\n        messages = messages.append({\r\n          role: \"tool\",\r\n          tool_call_id: payload.toolCallId,\r\n          name: payload.name,\r\n          content: json.encode(payload.output)\r\n        })\r\n        continue\r\n      }\r\n    }\r\n\r\n    if hasUserTurn != true {\r\n      messages = messages.append({\r\n        role: \"user\",\r\n        content: context.userPrompt\r\n      })\r\n    }\r\n\r\n    return messages\r\n  }\r\n}\r\n"
      }
    },
    ".icoo/packages/issueye/agent/pkg/tools.icpkg": {
      "version": 1,
      "kind": "package",
      "entry": "src/main.ic",
      "entry_function": "main",
      "root_alias": "@",
      "package_name": "issueye/agent/pkg/tools",
      "package_version": "0.1.2",
      "export": "src/main.ic",
      "modules": {
        "src/create_skill.ic": "import std.io.fs as fs\r\nimport std.sys.os as os\r\nimport std.core.object as object\r\n\r\nexport class CreateSkill {\r\n  init(skillCatalog) {\r\n    this.skillCatalog = skillCatalog\r\n  }\r\n\r\n  run(config, input) {\r\n    let skillId = object.get(input, \"skill\")\r\n    if this.skillCatalog.isValidSkillId(skillId) != true {\r\n      return {\r\n        ok: false,\r\n        error: \"createSkill requires a safe skill id\"\r\n      }\r\n    }\r\n\r\n    if this.skillCatalog.findById(config, skillId) != null {\r\n      return {\r\n        ok: false,\r\n        error: \"skill already exists: \" + skillId\r\n      }\r\n    }\r\n\r\n    let description = object.get(input, \"description\")\r\n    if typeOf(description) != \"string\" || description == \"\" {\r\n      return {\r\n        ok: false,\r\n        error: \"createSkill requires non-empty description\"\r\n      }\r\n    }\r\n\r\n    let baseDir = this.skillCatalog.primaryDir(config)\r\n    if typeOf(baseDir) != \"string\" || baseDir == \"\" {\r\n      return {\r\n        ok: false,\r\n        error: \"no skill directory configured\"\r\n      }\r\n    }\r\n\r\n    let skillDir = fs.join(baseDir, skillId)\r\n    let skillFile = fs.join(skillDir, \"SKILL.md\")\r\n    let content = object.get(input, \"content\")\r\n    if typeOf(content) != \"string\" || content == \"\" {\r\n      content = this.skillCatalog.buildSkillDocument(\r\n        skillId,\r\n        object.get(input, \"name\"),\r\n        description,\r\n        object.get(input, \"body\")\r\n      )\r\n    }\r\n\r\n    os.mkdirAll(skillDir)\r\n    fs.writeFile(skillFile, content)\r\n\r\n    return {\r\n      ok: true,\r\n      created: skillId,\r\n      meta: {\r\n        dir: skillDir,\r\n        skillFile: skillFile\r\n      }\r\n    }\r\n  }\r\n}\r\n",
        "src/exec_command.ic": "import std.sys.exec as exec\r\nimport std.core.object as object\r\nimport \"./tool_path.ic\" as toolPath\n\r\n// 执行命令工具\r\nexport class ExecCommand {\r\n  init(toolPath) {\r\n    this.toolPath = toolPath\r\n  }\r\n\r\n  // 执行命令\r\n  run(config, input) {\r\n    let command = object.get(input, \"command\")\r\n    let args = object.get(input, \"args\", [])\r\n    let cwd = object.get(input, \"cwd\", config.workspace)\r\n    let shell = object.get(input, \"shell\", false)\r\n    let env = object.get(input, \"env\", {})\r\n\r\n    if command == null || command == \"\" {\r\n      return {\r\n        ok: false,\r\n        error: \"execCommand requires non-empty command\"\r\n      }\r\n    }\r\n\r\n    cwd = this.toolPath.resolve(config, cwd)\r\n\r\n    // `std.sys.exec` 在 shell 模式下只消费 command，本层禁止同时传 args，\r\n    // 避免模型误以为 shell + argv 会一起生效。\r\n    if shell == true \u0026\u0026 typeOf(args) == \"array\" \u0026\u0026 len(args) \u003e 0 {\r\n      return {\r\n        ok: false,\r\n        error: \"execCommand does not support args when shell=true\"\r\n      }\r\n    }\r\n\r\n    let result = exec.run({\r\n      command: command,\r\n      args: args,\r\n      cwd: cwd,\r\n      shell: shell,\r\n      env: env\r\n    })\r\n\r\n    return {\r\n      ok: result.ok,\r\n      content: {\r\n        stdout: result.stdout,\r\n        stderr: result.stderr\r\n      },\r\n      meta: {\r\n        command: result.command,\r\n        exitCode: result.exitCode,\r\n        cwd: cwd,\r\n        shell: shell\r\n      },\r\n      error: result.ok == true ? null : result.stderr\r\n    }\r\n  }\r\n}\r\n",
        "src/executor.ic": "import std.core.object as object\r\nimport std.data.json as json\r\n\r\nexport class ToolExecutor {\r\n  init(toolRegistry) {\r\n    this.toolRegistry = toolRegistry\r\n  }\r\n\r\n  parseArguments(rawArguments) {\r\n    if typeOf(rawArguments) == \"object\" {\r\n      return {\r\n        ok: true,\r\n        value: rawArguments\r\n      }\r\n    }\r\n    if typeOf(rawArguments) != \"string\" || rawArguments == \"\" {\r\n      return {\r\n        ok: false,\r\n        error: \"tool arguments must be a non-empty JSON string\"\r\n      }\r\n    }\r\n\r\n    try {\r\n      return {\r\n        ok: true,\r\n        value: json.decode(rawArguments)\r\n      }\r\n    } catch err {\r\n      return {\r\n        ok: false,\r\n        error: \"invalid tool arguments JSON\"\r\n      }\r\n    }\r\n  }\r\n\r\n  run(config, name, input) {\r\n    let tool = this.toolRegistry.get(name)\r\n    if tool == null {\r\n      return {\r\n        ok: false,\r\n        error: \"unknown tool: \" + name\r\n      }\r\n    }\r\n\r\n    let handler = object.get(tool, \"handler\")\r\n    return handler(config, input)\r\n  }\r\n\r\n  runCall(config, call) {\r\n    let callId = object.get(call, \"id\", \"\")\r\n    let fnDef = object.get(call, \"function\", {})\r\n    let name = object.get(fnDef, \"name\", \"\")\r\n    let parsedArgs = this.parseArguments(object.get(fnDef, \"arguments\"))\r\n    if parsedArgs.ok != true {\r\n      return {\r\n        ok: false,\r\n        toolCallId: callId,\r\n        name: name,\r\n        error: parsedArgs.error,\r\n        output: {\r\n          ok: false,\r\n          error: parsedArgs.error\r\n        }\r\n      }\r\n    }\r\n\r\n    let result = this.run(config, name, parsedArgs.value)\r\n    return {\r\n      ok: result.ok,\r\n      toolCallId: callId,\r\n      name: name,\r\n      input: parsedArgs.value,\r\n      output: result,\r\n      error: object.get(result, \"error\")\r\n    }\r\n  }\r\n}\r\n",
        "src/list_dir.ic": "import std.io.fs as fs\r\nimport std.core.object as object\r\n\r\n// ListDir 是一个列出工作区目录内容的工具。\r\nexport class ListDir {\r\n  init(toolPath) {\r\n    this.toolPath = toolPath\r\n  }\r\n\r\n  // run 列出工作区目录内容。\r\n  run(config, input) {\r\n    let path = object.get(input, \"path\")\r\n    if path == null || path == \"\" {\r\n      return {\r\n        ok: false,\r\n        error: \"listDir requires non-empty path\"\r\n      }\r\n    }\r\n\r\n    path = this.toolPath.resolve(config, path)\r\n    if fs.exists(path) != true {\r\n      return {\r\n        ok: false,\r\n        error: \"directory not found: \" + path\r\n      }\r\n    }\r\n    let info = fs.stat(path)\r\n    if info.isDir != true {\r\n      return {\r\n        ok: false,\r\n        error: \"path is not a directory: \" + path\r\n      }\r\n    }\r\n\r\n    let entries = fs.readDir(path).map(fn(entry) {\r\n      return {\r\n        name: entry.name,\r\n        path: entry.path,\r\n        isDir: entry.isDir\r\n      }\r\n    })\r\n\r\n    return {\r\n      ok: true,\r\n      content: entries,\r\n      meta: {\r\n        path: path,\r\n        count: len(entries)\r\n      }\r\n    }\r\n  }\r\n}\r\n",
        "src/list_skills.ic": "export class ListSkills {\r\n  init(skillCatalog) {\r\n    this.skillCatalog = skillCatalog\r\n  }\r\n\r\n  run(config, input) {\r\n    let items = this.skillCatalog.list(config)\r\n    return {\r\n      ok: true,\r\n      content: items,\r\n      meta: {\r\n        count: len(items),\r\n        configuredDirs: this.skillCatalog.configuredDirs(config)\r\n      }\r\n    }\r\n  }\r\n}\r\n",
        "src/main.ic": "import \"./executor.ic\" as executor\nimport \"./registry.ic\" as registry\nimport \"./tool_path.ic\" as toolPath\nimport \"./web_common.ic\" as webCommon\n\nconst ToolExecutor = executor.ToolExecutor\nconst ToolRegistry = registry.ToolRegistry\nconst ToolPath = toolPath.ToolPath\nconst WebCommon = webCommon.WebCommon\n\nexport { ToolExecutor, ToolRegistry, ToolPath, WebCommon }\n\nfn main() {\n  return null\n}\n",
        "src/read_file.ic": "import std.io.fs as fs\r\nimport std.core.object as object\r\n\r\n// ReadFile 是一个读取工作区文本文件的工具。\r\nexport class ReadFile {\r\n  init(toolPath) {\r\n    this.toolPath = toolPath\r\n  }\r\n\r\n  // run 读取工作区中的文本文件。\r\n  run(config, input) {\r\n    let path = object.get(input, \"path\")\r\n    if path == null || path == \"\" {\r\n      return {\r\n        ok: false,\r\n        error: \"readFile requires non-empty path\"\r\n      }\r\n    }\r\n\r\n    path = this.toolPath.resolve(config, path)\r\n    if fs.exists(path) != true {\r\n      return {\r\n        ok: false,\r\n        error: \"file not found: \" + path\r\n      }\r\n    }\r\n    let info = fs.stat(path)\r\n    if info.isFile != true {\r\n      return {\r\n        ok: false,\r\n        error: \"path is not a file: \" + path\r\n      }\r\n    }\r\n\r\n    return {\r\n      ok: true,\r\n      content: fs.readFile(path),\r\n      meta: {\r\n        path: path\r\n      }\r\n    }\r\n  }\r\n}\r\n",
        "src/read_skill.ic": "import std.io.fs as fs\r\nimport std.core.object as object\r\n\r\nexport class ReadSkill {\r\n  init(skillCatalog) {\r\n    this.skillCatalog = skillCatalog\r\n  }\r\n\r\n  run(config, input) {\r\n    let skillId = object.get(input, \"skill\")\r\n    if typeOf(skillId) != \"string\" || skillId == \"\" {\r\n      return {\r\n        ok: false,\r\n        error: \"readSkill requires non-empty skill\"\r\n      }\r\n    }\r\n\r\n    let skill = this.skillCatalog.findById(config, skillId)\r\n    if skill == null {\r\n      return {\r\n        ok: false,\r\n        error: \"skill not found: \" + skillId\r\n      }\r\n    }\r\n\r\n    return {\r\n      ok: true,\r\n      content: fs.readFile(skill.skillFile),\r\n      meta: skill\r\n    }\r\n  }\r\n}\r\n",
        "src/registry.ic": "import std.core.object as object\r\nimport \"./exec_command.ic\" as execCommand\nimport \"./read_file.ic\" as readFile\nimport \"./list_dir.ic\" as listDir\nimport \"./search_text.ic\" as searchText\nimport \"./web_fetch.ic\" as webFetch\nimport \"./web_search.ic\" as webSearch\nimport \"./skill_tool.ic\" as skillTool\n\r\nexport class ToolRegistry {\r\n  init(toolPath, ignore, webCommon, skillCatalog) {\r\n    this.toolPath = toolPath\r\n    this.ignore = ignore\r\n    this.webCommon = webCommon\r\n    this.skillCatalog = skillCatalog\r\n    this.execCommand = execCommand.ExecCommand(this.toolPath)\r\n    this.readFile = readFile.ReadFile(this.toolPath)\r\n    this.listDir = listDir.ListDir(this.toolPath)\n    this.searchText = searchText.SearchText(this.toolPath, this.ignore)\n    this.webFetch = webFetch.WebFetch(this.webCommon)\n    this.webSearch = webSearch.WebSearch(this.webCommon)\n    this.skill = skillTool.SkillTool(this.skillCatalog)\n  }\r\n\r\n  build() {\r\n    return {\r\n      readFile: {\r\n        name: \"readFile\",\r\n        description: \"Read a UTF-8 text file from the local workspace.\",\r\n        parameters: {\r\n          type: \"object\",\r\n          properties: {\r\n            path: {\r\n              type: \"string\",\r\n              description: \"Workspace-relative path. Use @/ as the workspace root prefix.\"\r\n            }\r\n          },\r\n          required: [\"path\"]\r\n        },\r\n        handler: this.readFile.run\r\n      },\r\n      listDir: {\r\n        name: \"listDir\",\r\n        description: \"List files and directories under a workspace path.\",\r\n        parameters: {\r\n          type: \"object\",\r\n          properties: {\r\n            path: {\r\n              type: \"string\",\r\n              description: \"Workspace-relative directory path. Use @/ as the workspace root prefix.\"\r\n            }\r\n          },\r\n          required: [\"path\"]\r\n        },\r\n        handler: this.listDir.run\r\n      },\r\n      searchText: {\r\n        name: \"searchText\",\r\n        description: \"Search plain text files under a workspace path for a query string.\",\r\n        parameters: {\r\n          type: \"object\",\r\n          properties: {\r\n            path: {\r\n              type: \"string\",\r\n              description: \"Workspace-relative search root. Use @/ as the workspace root prefix.\"\r\n            },\r\n            query: {\r\n              type: \"string\",\r\n              description: \"The literal string to search for.\"\r\n            }\r\n          },\r\n          required: [\"path\", \"query\"]\r\n        },\r\n        handler: this.searchText.run\r\n      },\r\n      execCommand: {\r\n        name: \"execCommand\",\r\n        description: \"Execute a local command inside the workspace and return stdout/stderr.\",\r\n        parameters: {\r\n          type: \"object\",\r\n          properties: {\r\n            command: {\r\n              type: \"string\",\r\n              description: \"Executable or shell command text.\"\r\n            },\r\n            args: {\r\n              type: \"array\",\r\n              description: \"Optional argv list. Do not pass this when shell=true.\",\r\n              items: {\r\n                type: \"string\"\r\n              }\r\n            },\r\n            cwd: {\r\n              type: \"string\",\r\n              description: \"Optional working directory. Supports @/ as the workspace root prefix.\"\r\n            },\r\n            shell: {\r\n              type: \"boolean\",\r\n              description: \"Run command through the system shell. When true, omit args.\"\r\n            },\r\n            env: {\r\n              type: \"object\",\r\n              description: \"Optional environment variable overrides merged on top of the current host environment.\",\r\n              additionalProperties: {\r\n                type: \"string\"\r\n              }\r\n            }\r\n          },\r\n          required: [\"command\"]\r\n        },\r\n        handler: this.execCommand.run\r\n      },\r\n      webFetch: {\r\n        name: \"webFetch\",\r\n        description: \"Fetch a web page URL and return cleaned text content.\",\r\n        parameters: {\r\n          type: \"object\",\r\n          properties: {\r\n            url: {\r\n              type: \"string\",\r\n              description: \"Absolute HTTP or HTTPS URL to fetch.\"\r\n            },\r\n            maxChars: {\r\n              type: \"integer\",\r\n              description: \"Optional maximum number of characters to keep from the cleaned page text.\"\r\n            }\r\n          },\r\n          required: [\"url\"]\r\n        },\r\n        handler: this.webFetch.run\r\n      },\r\n      webSearch: {\r\n        name: \"webSearch\",\r\n        description: \"Search the web with DuckDuckGo and return a short result list.\",\r\n        parameters: {\r\n          type: \"object\",\r\n          properties: {\r\n            query: {\r\n              type: \"string\",\r\n              description: \"Search query text.\"\r\n            },\r\n            maxResults: {\r\n              type: \"integer\",\r\n              description: \"Optional maximum number of results to return.\"\r\n            }\r\n          },\r\n          required: [\"query\"]\r\n        },\r\n        handler: this.webSearch.run\r\n      },\r\n      skill: {\n        name: \"skill\",\n        description: \"Manage discovered agent skills with a single tool. Use action=list|read|create|update|remove.\",\n        parameters: {\n          type: \"object\",\n          properties: {\n            action: {\n              type: \"string\",\n              description: \"Required operation: list, read, create, update, or remove.\"\n            },\n            skill: {\n              type: \"string\",\n              description: \"Skill folder id or frontmatter name. Required for read, create, update, and remove.\"\n            },\n            name: {\n              type: \"string\",\n              description: \"Optional frontmatter skill name for create or update.\"\n            },\n            description: {\n              type: \"string\",\n              description: \"Description for create, or optional replacement description for update.\"\n            },\n            body: {\n              type: \"string\",\n              description: \"Optional markdown body for create or update.\"\n            },\n            content: {\n              type: \"string\",\n              description: \"Optional full SKILL.md content for create or update. Overrides name/description/body assembly.\"\n            }\n          },\n          required: [\"action\"]\n        },\n        handler: this.skill.run\n      }\n    }\n  }\n\r\n  get(name) {\r\n    let tools = this.build()\r\n    return object.get(tools, name)\r\n  }\r\n\r\n  definitions() {\n    let tools = this.build()\n    let names = [\"readFile\", \"listDir\", \"searchText\", \"execCommand\", \"webFetch\", \"webSearch\", \"skill\"]\n    let definitions = []\r\n    for i, name in names {\r\n      let tool = object.get(tools, name)\r\n      definitions = definitions.append({\r\n        type: \"function\",\r\n        function: {\r\n          name: tool.name,\r\n          description: tool.description,\r\n          parameters: tool.parameters\r\n        }\r\n      })\r\n    }\r\n    return definitions\r\n  }\r\n}\r\n",
        "src/remove_skill.ic": "import std.sys.os as os\r\nimport std.core.object as object\r\n\r\nexport class RemoveSkill {\r\n  init(skillCatalog) {\r\n    this.skillCatalog = skillCatalog\r\n  }\r\n\r\n  run(config, input) {\r\n    let skillId = object.get(input, \"skill\")\r\n    if typeOf(skillId) != \"string\" || skillId == \"\" {\r\n      return {\r\n        ok: false,\r\n        error: \"removeSkill requires non-empty skill\"\r\n      }\r\n    }\r\n\r\n    let skill = this.skillCatalog.findById(config, skillId)\r\n    if skill == null {\r\n      return {\r\n        ok: false,\r\n        error: \"skill not found: \" + skillId\r\n      }\r\n    }\r\n\r\n    os.removeAll(skill.dir)\r\n\r\n    return {\r\n      ok: true,\r\n      removed: skill.id,\r\n      meta: skill\r\n    }\r\n  }\r\n}\r\n",
        "src/search_text.ic": "import std.io.fs as fs\r\nimport std.core.object as object\r\nimport std.core.string as str\r\n\r\n// SearchText 是一个搜索工作区文本的工具。\r\nexport class SearchText {\r\n  init(toolPath, ignore) {\r\n    this.toolPath = toolPath\r\n    this.ignore = ignore\r\n  }\r\n\r\n  // isSearchable 判断文件是否适合文本搜索。\r\n  isSearchable(path) {\r\n    return (\r\n      str.hasSuffix(path, \".ic\") ||\r\n      str.hasSuffix(path, \".md\") ||\r\n      str.hasSuffix(path, \".txt\") ||\r\n      str.hasSuffix(path, \".json\") ||\r\n      str.hasSuffix(path, \".toml\") ||\r\n      str.hasSuffix(path, \".yaml\") ||\r\n      str.hasSuffix(path, \".yml\") ||\r\n      str.hasSuffix(path, \".go\") ||\r\n      str.hasSuffix(path, \".js\") ||\r\n      str.hasSuffix(path, \".ts\")\r\n    )\r\n  }\r\n\r\n  // scan 递归搜索目录或单文件。\r\n  scan(path, needle, matches) {\r\n    let info = fs.stat(path)\r\n    if info.isFile {\r\n      if this.isSearchable(path) != true {\r\n        return matches\r\n      }\r\n\r\n      let text = fs.readFile(path)\r\n      if str.contains(text, needle) == true {\r\n        return matches.append({\r\n          path: path\r\n        })\r\n      }\r\n      return matches\r\n    }\r\n\r\n    let entries = fs.readDir(path)\r\n    for i, entry in entries {\r\n      if this.ignore.shouldIgnoreName(entry.name) == true {\r\n        continue\r\n      }\r\n      matches = this.scan(entry.path, needle, matches)\r\n    }\r\n    return matches\r\n  }\r\n\r\n  // run 执行文本搜索工具。\r\n  run(config, input) {\r\n    let path = object.get(input, \"path\")\r\n    let query = object.get(input, \"query\")\r\n    if path == null || path == \"\" {\r\n      return {\r\n        ok: false,\r\n        error: \"searchText requires non-empty path\"\r\n      }\r\n    }\r\n    if query == null || query == \"\" {\r\n      return {\r\n        ok: false,\r\n        error: \"searchText requires non-empty query\"\r\n      }\r\n    }\r\n\r\n    path = this.toolPath.resolve(config, path)\r\n    if fs.exists(path) != true {\r\n      return {\r\n        ok: false,\r\n        error: \"search root not found: \" + path\r\n      }\r\n    }\r\n\r\n    let matches = this.scan(path, query, [])\r\n    return {\r\n      ok: true,\r\n      content: matches,\r\n      meta: {\r\n        path: path,\r\n        query: query,\r\n        count: len(matches)\r\n      }\r\n    }\r\n  }\r\n}\r\n",
        "src/skill_tool.ic": "import std.core.object as object\nimport \"./list_skills.ic\" as listSkills\nimport \"./read_skill.ic\" as readSkill\nimport \"./remove_skill.ic\" as removeSkill\nimport \"./create_skill.ic\" as createSkill\nimport \"./update_skill.ic\" as updateSkill\n\nexport class SkillTool {\n  init(skillCatalog) {\n    this.skillCatalog = skillCatalog\n    this.listSkills = listSkills.ListSkills(this.skillCatalog)\n    this.readSkill = readSkill.ReadSkill(this.skillCatalog)\n    this.removeSkill = removeSkill.RemoveSkill(this.skillCatalog)\n    this.createSkill = createSkill.CreateSkill(this.skillCatalog)\n    this.updateSkill = updateSkill.UpdateSkill(this.skillCatalog)\n  }\n\n  run(config, input) {\n    let action = object.get(input, \"action\")\n    if typeOf(action) != \"string\" || action == \"\" {\n      return {\n        ok: false,\n        error: \"skill tool requires non-empty action\"\n      }\n    }\n\n    if action == \"list\" {\n      return this.listSkills.run(config, input)\n    }\n    if action == \"read\" {\n      return this.readSkill.run(config, input)\n    }\n    if action == \"create\" {\n      return this.createSkill.run(config, input)\n    }\n    if action == \"update\" {\n      return this.updateSkill.run(config, input)\n    }\n    if action == \"remove\" {\n      return this.removeSkill.run(config, input)\n    }\n\n    return {\n      ok: false,\n      error: \"unsupported skill action: \" + action\n    }\n  }\n}\n",
        "src/tool_path.ic": "import std.io.fs as fs\nimport std.core.string as str\n\n// ToolPath 是一个解析工具路径的类。\nexport class ToolPath {\n  // resolve 解析工具路径。\n  // 如果路径以\"@/\"开头，则将其解析为工作空间路径的子路径。\n  // 否则，返回路径本身。\n  resolve(config, path) {\n    if path == null || path == \"\" {\n      return path\n    }\n    // 如果路径以\"@/\"开头，则将其解析为工作空间路径的子路径\n    if str.hasPrefix(path, \"@/\") {\n      let suffix = str.replace(path, \"@/\", \"\", 1)\n      return fs.join(config.workspace, suffix)\n    }\n    return path\n  }\n}\n\n",
        "src/update_skill.ic": "import std.io.fs as fs\r\nimport std.core.object as object\r\n\r\nexport class UpdateSkill {\r\n  init(skillCatalog) {\r\n    this.skillCatalog = skillCatalog\r\n  }\r\n\r\n  run(config, input) {\r\n    let skillId = object.get(input, \"skill\")\r\n    if typeOf(skillId) != \"string\" || skillId == \"\" {\r\n      return {\r\n        ok: false,\r\n        error: \"updateSkill requires non-empty skill\"\r\n      }\r\n    }\r\n\r\n    let skill = this.skillCatalog.findById(config, skillId)\r\n    if skill == null {\r\n      return {\r\n        ok: false,\r\n        error: \"skill not found: \" + skillId\r\n      }\r\n    }\r\n\r\n    let content = object.get(input, \"content\")\r\n    if typeOf(content) != \"string\" || content == \"\" {\r\n      let existing = fs.readFile(skill.skillFile)\r\n      let parsed = this.skillCatalog.parseFrontmatter(existing)\r\n      let name = object.get(input, \"name\", skill.id)\r\n      let description = object.get(input, \"description\", parsed.description)\r\n      let body = object.get(input, \"body\")\r\n      if typeOf(body) != \"string\" || body == \"\" {\r\n        body = this.skillCatalog.extractBody(existing)\r\n      }\r\n      if typeOf(description) != \"string\" || description == \"\" {\r\n        return {\r\n          ok: false,\r\n          error: \"updateSkill requires description when the existing skill has none\"\r\n        }\r\n      }\r\n      content = this.skillCatalog.buildSkillDocument(skill.id, name, description, body)\r\n    }\r\n\r\n    fs.writeFile(skill.skillFile, content)\r\n\r\n    return {\r\n      ok: true,\r\n      updated: skill.id,\r\n      meta: skill\r\n    }\r\n  }\r\n}\r\n",
        "src/web_common.ic": "import std.core.string as str\r\nimport std.data.json as json\r\n\r\n// WebCommon 是一个通用的Web工具类。\r\nexport class WebCommon {\r\n  // after 提取字符串中指定标记之后的内容。\r\n  after(text, marker) {\r\n    let parts = str.split(text, marker)\r\n    if len(parts) \u003c 2 {\r\n      return \"\"\r\n    }\r\n    return parts[1]\r\n  }\r\n\r\n  // between 提取字符串中两个标记之间的内容。\r\n  between(text, startMarker, endMarker) {\r\n    let tail = this.after(text, startMarker)\r\n    if tail == \"\" {\r\n      return \"\"\r\n    }\r\n    return str.split(tail, endMarker)[0]\r\n  }\r\n\r\n  // decodeEntities 解码HTML实体。\r\n  decodeEntities(text) {\r\n    text = str.replace(text, \"\u0026amp;\", \"\u0026\")\r\n    text = str.replace(text, \"\u0026lt;\", \"\u003c\")\r\n    text = str.replace(text, \"\u0026gt;\", \"\u003e\")\r\n    text = str.replace(text, \"\u0026quot;\", \"\\\"\")\r\n    text = str.replace(text, \"\u0026#39;\", \"'\")\r\n    text = str.replace(text, \"\u0026nbsp;\", \" \")\r\n    return text\r\n  }\r\n\r\n  // quoteChar 获取HTML实体中的引号。\r\n  quoteChar() {\r\n    return this.decodeEntities(\"\u0026quot;\")\r\n  }\r\n\r\n  // decodeJSONString 解码JSON字符串。\r\n  decodeJSONString(text) {\r\n    try {\r\n      let decoded = json.decode(text)\r\n      if typeOf(decoded) == \"string\" {\r\n        return decoded\r\n      }\r\n    } catch err {\r\n      return text\r\n    }\r\n    return text\r\n  }\r\n\r\n  // normalizeSpaces 规范化空格。\r\n  normalizeSpaces(text) {\r\n    text = str.replace(text, \"\\r\", \" \")\r\n    text = str.replace(text, \"\\n\", \" \")\r\n    text = str.replace(text, \"\\t\", \" \")\r\n\r\n    let parts = str.split(text, \" \")\r\n    let compact = []\r\n    for i, part in parts {\r\n      part = str.trimSpace(part)\r\n      if part == \"\" {\r\n        continue\r\n      }\r\n      compact = compact.append(part)\r\n    }\r\n    return str.join(compact, \" \")\r\n  }\r\n\r\n  // htmlToText 将HTML转换为文本。\r\n  htmlToText(html) {\r\n    html = this.decodeEntities(html)\r\n\r\n    let parts = str.split(html, \"\u003c\")\r\n    let chunks = []\r\n    for i, part in parts {\r\n      if i == 0 {\r\n        chunks = chunks.append(part)\r\n        continue\r\n      }\r\n\r\n      let inner = str.split(part, \"\u003e\")\r\n      let j = 1\r\n      while j \u003c len(inner) {\r\n        chunks = chunks.append(inner[j])\r\n        j = j + 1\r\n      }\r\n    }\r\n\r\n    return this.normalizeSpaces(str.join(chunks, \" \"))\r\n  }\r\n\r\n  // clipText 截取文本，确保不超过最大字符数。\r\n  clipText(text, maxChars) {\r\n    if typeOf(maxChars) != \"int\" || maxChars \u003c= 0 {\r\n      return text\r\n    }\r\n    if len(text) \u003c= maxChars {\r\n      return text\r\n    }\r\n\r\n    let parts = str.split(text, \" \")\r\n    let clipped = \"\"\r\n    for i, part in parts {\r\n      part = str.trimSpace(part)\r\n      if part == \"\" {\r\n        continue\r\n      }\r\n\r\n      let next = part\r\n      if clipped != \"\" {\r\n        next = clipped + \" \" + part\r\n      }\r\n      if len(next) \u003e maxChars {\r\n        break\r\n      }\r\n      clipped = next\r\n    }\r\n\r\n    if clipped == \"\" {\r\n      return text\r\n    }\r\n    return clipped\r\n  }\r\n\r\n  // extractTitle 从HTML中提取标题。\r\n  extractTitle(html) {\r\n    let title = this.between(html, \"\u003ctitle\u003e\", \"\u003c/title\u003e\")\r\n    if title == \"\" {\r\n      title = this.between(html, \"\u003cTITLE\u003e\", \"\u003c/TITLE\u003e\")\r\n    }\r\n    return this.normalizeSpaces(this.decodeEntities(title))\r\n  }\r\n\r\n  // extractSnippet 从HTML中提取片段。\r\n  extractSnippet(chunk) {\r\n    let tail = this.after(chunk, \"result__snippet\")\r\n    if tail == \"\" {\r\n      return \"\"\r\n    }\r\n\r\n    let parts = str.split(tail, \"\u003e\")\r\n    if len(parts) \u003c 2 {\r\n      return \"\"\r\n    }\r\n    return this.htmlToText(parts[1])\r\n  }\r\n  \r\n  // parseDuckDuckGoResults 解析DuckDuckGo搜索结果。\r\n  parseDuckDuckGoResults(html, maxResults) {\r\n    let results = []\r\n    let limit = maxResults\r\n    if typeOf(limit) != \"int\" || limit \u003c= 0 {\r\n      limit = 5\r\n    }\r\n\r\n    // DuckDuckGo HTML results are anchor-heavy. Split on `\u003ca ` first, then\r\n    // keep only anchors that carry the `result__a` class.\r\n    let parts = str.split(html, \"\u003ca \")\r\n    let i = 0\r\n    while i \u003c len(parts) \u0026\u0026 len(results) \u003c limit {\r\n      let chunk = parts[i]\r\n      if str.contains(chunk, \"result__a\") != true {\r\n        i = i + 1\r\n        continue\r\n      }\r\n\r\n      let hrefTail = this.after(chunk, \"href=\")\r\n      if hrefTail == \"\" {\r\n        i = i + 1\r\n        continue\r\n      }\r\n      let anchorParts = str.split(hrefTail, \"\u003e\")\r\n      if len(anchorParts) \u003c 2 {\r\n        i = i + 1\r\n        continue\r\n      }\r\n      let url = this.decodeJSONString(anchorParts[0])\r\n\r\n      let titleHtml = str.split(anchorParts[1], \"\u003c/a\u003e\")[0]\r\n      let title = this.htmlToText(titleHtml)\r\n      let snippet = this.extractSnippet(chunk)\r\n      if title != \"\" \u0026\u0026 url != \"\" {\r\n        results = results.append({\r\n          title: title,\r\n          url: url,\r\n          snippet: snippet\r\n        })\r\n      }\r\n      i = i + 1\r\n    }\r\n\r\n    return results\r\n  }\r\n}\r\n\r\n",
        "src/web_fetch.ic": "import std.net.http.client as http\r\nimport std.core.object as object\r\n\r\n// WebFetch 是一个从URL获取文本的工具。\r\nexport class WebFetch {\r\n  init(webCommon) {\r\n    this.webCommon = webCommon\r\n  }\r\n\r\n  run(config, input) {\r\n    let url = object.get(input, \"url\")\r\n    let maxChars = object.get(input, \"maxChars\", 4000)\r\n    if url == null || url == \"\" {\r\n      return {\r\n        ok: false,\r\n        error: \"webFetch requires non-empty url\"\r\n      }\r\n    }\r\n\r\n    let response = http.request({\r\n      url: url,\r\n      method: \"GET\",\r\n      headers: {\r\n        Accept: \"text/html,application/xhtml+xml\",\r\n        \"User-Agent\": \"icoo-agent/1.0\"\r\n      },\r\n      followRedirects: true\r\n    })\r\n    if response.ok != true {\r\n      return {\r\n        ok: false,\r\n        error: \"webFetch http request failed: \" + response.statusText\r\n      }\r\n    }\r\n\r\n    let body = object.get(response, \"body\", \"\")\r\n    let title = this.webCommon.extractTitle(body)\r\n    let text = this.webCommon.clipText(\r\n      this.webCommon.htmlToText(body),\r\n      maxChars\r\n    )\r\n    return {\r\n      ok: true,\r\n      content: text,\r\n      meta: {\r\n        url: object.get(response, \"url\", url),\r\n        title: title,\r\n        status: response.status,\r\n        contentLength: response.contentLength\r\n      }\r\n    }\r\n  }\r\n}\r\n",
        "src/web_search.ic": "import std.net.http.client as http\r\nimport std.core.object as object\r\n\r\n// WebSearch 是一个从DuckDuckGo搜索的工具。\r\nexport class WebSearch {\r\n  // init 初始化 WebSearch。\r\n  init(webCommon) {\r\n    this.webCommon = webCommon\r\n  }\r\n\r\n  // run 执行搜索。\r\n  run(config, input) {\r\n    let query = object.get(input, \"query\")\r\n    let maxResults = object.get(input, \"maxResults\", 5)\r\n    let endpoint = object.get(input, \"endpoint\", \"https://html.duckduckgo.com/html/\")\r\n    if query == null || query == \"\" {\r\n      return {\r\n        ok: false,\r\n        error: \"webSearch requires non-empty query\"\r\n      }\r\n    }\r\n\r\n    let response = http.request({\r\n      url: endpoint,\r\n      method: \"GET\",\r\n      query: {\r\n        q: query\r\n      },\r\n      headers: {\r\n        Accept: \"text/html,application/xhtml+xml\",\r\n        \"User-Agent\": \"icoo-agent/1.0\"\r\n      },\r\n      followRedirects: true\r\n    })\r\n    if response.ok != true {\r\n      return {\r\n        ok: false,\r\n        error: \"webSearch http request failed: \" + response.statusText\r\n      }\r\n    }\r\n\r\n    let body = object.get(response, \"body\", \"\")\r\n    let results = this.webCommon.parseDuckDuckGoResults(body, maxResults)\r\n    return {\r\n      ok: true,\r\n      content: results,\r\n      meta: {\r\n        engine: \"duckduckgo\",\r\n        query: query,\r\n        count: len(results),\r\n        url: object.get(response, \"url\", endpoint)\r\n      }\r\n    }\r\n  }\r\n}\r\n"
      }
    }
  }
}