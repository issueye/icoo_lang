{
  "version": 1,
  "kind": "package",
  "entry": "src/main.ic",
  "entry_function": "main",
  "root_alias": "@",
  "package_name": "issueye/agent/pkg/config",
  "package_version": "0.1.2",
  "export": "src/main.ic",
  "modules": {
    "src/args.ic": "import std.sys.cli as cli\r\nimport std.core.string as str\r\n\r\nexport class ArgsConfig {\r\n  argvList() {\r\n    return argv()\r\n  }\r\n\r\n  isHelpRequest() {\r\n    let values = this.argvList()\r\n    for i, value in values {\r\n      if value == \"--help\" || value == \"-h\" {\r\n        return true\r\n      }\r\n    }\r\n    return false\r\n  }\r\n\r\n  hasWorkspaceArg() {\r\n    let values = this.argvList()\r\n    let index = 0\r\n    while index \u003c len(values) {\r\n      let value = values[index]\r\n      if value == \"--workspace\" || value == \"--root\" {\r\n        return index + 1 \u003c len(values)\r\n      }\r\n      if str.hasPrefix(value, \"--workspace=\") || str.hasPrefix(value, \"--root=\") {\r\n        return true\r\n      }\r\n      index = index + 1\r\n    }\r\n    return false\r\n  }\r\n\r\n  defineApp() {\r\n    let app = cli.create({\r\n      name: \"icoo-agent\",\r\n      description: \"Pure Icoo agent entry with OpenAI-compatible tool-calling runtime\",\r\n      allowUnknownArgs: true\r\n    })\r\n\r\n    app.flagString({\r\n      name: \"workspace\",\r\n      aliases: [\"root\"],\r\n      description: \"Workspace root path for context collection\"\r\n    })\r\n    app.flagString({\r\n      name: \"mode\",\r\n      description: \"Runtime mode such as interactive or batch\"\r\n    })\r\n    app.flagString({\r\n      name: \"model\",\r\n      description: \"Remote model name\"\r\n    })\r\n    app.flagString({\r\n      name: \"base-url\",\r\n      aliases: [\"api-base\"],\r\n      description: \"OpenAI-compatible base URL\"\r\n    })\r\n    app.flagString({\r\n      name: \"api-key\",\r\n      description: \"Remote model API key\"\r\n    })\r\n    app.flagString({\r\n      name: \"task\",\r\n      description: \"Top-level engineering task prompt\"\r\n    })\r\n    app.flagString({\r\n      name: \"session\",\r\n      description: \"Explicit session id\"\r\n    })\r\n    app.flagString({\r\n      name: \"resume\",\r\n      description: \"Resume session id\"\r\n    })\r\n    app.flagString({\r\n      name: \"approval\",\r\n      description: \"Approval mode\"\r\n    })\r\n    app.flagString({\r\n      name: \"skills-dir\",\r\n      description: \"Skill directory to discover SKILL.md folders from\"\r\n    })\r\n    app.flagString({\r\n      name: \"session-dir\",\r\n      description: \"Directory for session files\"\r\n    })\r\n    app.flagString({\r\n      name: \"log-path\",\r\n      description: \"Runtime log path\"\r\n    })\r\n    app.flagInt({\r\n      name: \"max-turns\",\r\n      description: \"Maximum model request turns\"\r\n    })\r\n    app.flagInt({\r\n      name: \"max-files\",\r\n      description: \"Maximum context files\"\r\n    })\r\n    app.flagInt({\r\n      name: \"max-total-bytes\",\r\n      aliases: [\"context-bytes\"],\r\n      description: \"Maximum context bytes\"\r\n    })\r\n    app.flagString({\r\n      name: \"stream-final-answer\",\r\n      description: \"Enable or disable streaming for the final assistant answer\"\r\n    })\r\n    app.flagString({\r\n      name: \"agent-name\",\r\n      description: \"Display name for the agent runtime\"\r\n    })\r\n\r\n    return app\r\n  }\r\n\r\n  applyIfString(config, value, key) {\r\n    if typeOf(value) == \"string\" \u0026\u0026 value != \"\" {\r\n      config[key] = value\r\n    }\r\n    return config\r\n  }\r\n\r\n  applyIfInt(config, value, key) {\r\n    if typeOf(value) == \"int\" {\r\n      config[key] = value\r\n    }\r\n    return config\r\n  }\r\n\r\n  applyIfBoolString(config, value, key) {\r\n    if value == \"true\" {\r\n      config[key] = true\r\n    }\r\n    if value == \"false\" {\r\n      config[key] = false\r\n    }\r\n    return config\r\n  }\r\n\r\n  applyArgs(config) {\r\n    let app = this.defineApp()\r\n    if this.isHelpRequest() == true {\r\n      return {\r\n        config: config,\r\n        help: true,\r\n        helpText: app.help()\r\n      }\r\n    }\r\n    let parsed = app.run()\r\n\r\n    let flags = parsed.flags\r\n    config = this.applyIfString(config, flags.workspace, \"workspace\")\r\n    config = this.applyIfString(config, flags.mode, \"mode\")\r\n    config = this.applyIfString(config, flags.model, \"model\")\r\n    config = this.applyIfString(config, flags[\"base-url\"], \"baseUrl\")\r\n    config = this.applyIfString(config, flags[\"api-key\"], \"apiKey\")\r\n    config = this.applyIfString(config, flags.task, \"task\")\r\n    config = this.applyIfString(config, flags.session, \"sessionId\")\r\n    config = this.applyIfString(config, flags.resume, \"resumeSession\")\r\n    config = this.applyIfString(config, flags.approval, \"approval\")\r\n    config = this.applyIfString(config, flags[\"skills-dir\"], \"skillsDir\")\r\n    config = this.applyIfString(config, flags[\"session-dir\"], \"sessionDir\")\r\n    config = this.applyIfString(config, flags[\"log-path\"], \"logPath\")\r\n    config = this.applyIfInt(config, flags[\"max-turns\"], \"maxTurns\")\r\n    config = this.applyIfInt(config, flags[\"max-files\"], \"maxFiles\")\r\n    config = this.applyIfInt(config, flags[\"max-total-bytes\"], \"maxTotalBytes\")\r\n    config = this.applyIfBoolString(config, flags[\"stream-final-answer\"], \"streamFinalAnswer\")\r\n    config = this.applyIfString(config, flags[\"agent-name\"], \"agentName\")\r\n\r\n    if this.hasWorkspaceArg() != true {\r\n      panic(\"missing required flag: --workspace\")\r\n    }\r\n\r\n    config.cliUnknownArgs = parsed.unknown\r\n\r\n    return {\r\n      config: config,\r\n      help: false,\r\n      helpText: null\r\n    }\r\n  }\r\n\r\n  previewWorkspace(config) {\r\n    let values = this.argvList()\r\n    let index = 0\r\n    while index \u003c len(values) {\r\n      let value = values[index]\r\n      if value == \"--workspace\" || value == \"--root\" {\r\n        if index + 1 \u003c len(values) {\r\n          config.workspace = values[index + 1]\r\n        }\r\n        break\r\n      }\r\n      if str.hasPrefix(value, \"--workspace=\") {\r\n        let parts = str.split(value, \"=\")\r\n        if len(parts) \u003e 1 {\r\n          config.workspace = parts[1]\r\n        }\r\n        break\r\n      }\r\n      if str.hasPrefix(value, \"--root=\") {\r\n        let parts = str.split(value, \"=\")\r\n        if len(parts) \u003e 1 {\r\n          config.workspace = parts[1]\r\n        }\r\n        break\r\n      }\r\n      index = index + 1\r\n    }\r\n    return config\r\n  }\r\n}\r\n\r\nlet argsApi = ArgsConfig()\r\n\r\nexport {\r\n  applyArgs: argsApi.applyArgs,\r\n  previewWorkspace: argsApi.previewWorkspace,\r\n  ArgsConfig: ArgsConfig\r\n}\r\n",
    "src/defaults.ic": "import std.io.fs as fs\r\nimport std.sys.os as os\r\n\r\nexport class Defaults {\r\n  defaultConfig() {\r\n    let stateDir = fs.join(os.cwd(), \".agents\")\r\n    return {\r\n      workspace: os.cwd(),\r\n      mode: \"interactive\",\r\n      model: \"gpt-4.1-mini\",\r\n      baseUrl: \"https://api.openai.com/v1\",\r\n      apiKey: null,\r\n      task: null,\r\n      sessionId: null,\r\n      resumeSession: null,\r\n      approval: \"on-request\",\r\n      maxTurns: 12,\r\n      maxFiles: 24,\r\n      maxTotalBytes: 32768,\r\n      streamFinalAnswer: true,\r\n      agentName: \"icoo_agents\",\r\n      skillsDir: null,\r\n      sessionDir: fs.join(stateDir, \"sessions\"),\r\n      logPath: fs.join(stateDir, \"agent.log\"),\r\n      cliUnknownArgs: []\r\n    }\r\n  }\r\n}\r\n",
    "src/env.ic": "import std.sys.os as os\r\nimport std.math.basic as math\r\n\r\nexport class EnvConfig {\r\n  parseIntOr(value, fallback) {\r\n    try {\r\n      return math.parseInt(value)\r\n    } catch err {\r\n      return fallback\r\n    }\r\n  }\r\n\r\n  applyEnv(config) {\r\n    let workspace = os.getEnv(\"ICOO_AGENTS_WORKSPACE\")\r\n    if workspace != null {\r\n      config.workspace = workspace\r\n    }\r\n\r\n    let mode = os.getEnv(\"ICOO_AGENTS_MODE\")\r\n    if mode != null {\r\n      config.mode = mode\r\n    }\r\n\r\n    let model = os.getEnv(\"ICOO_AGENTS_MODEL\")\r\n    if model != null {\r\n      config.model = model\r\n    }\r\n\r\n    let baseUrl = os.getEnv(\"ICOO_AGENTS_BASE_URL\")\r\n    if baseUrl != null {\r\n      config.baseUrl = baseUrl\r\n    }\r\n\r\n    let apiKey = os.getEnv(\"ICOO_AGENTS_API_KEY\")\r\n    if apiKey != null {\r\n      config.apiKey = apiKey\r\n    }\r\n\r\n    let task = os.getEnv(\"ICOO_AGENTS_TASK\")\r\n    if task != null {\r\n      config.task = task\r\n    }\r\n\r\n    let sessionId = os.getEnv(\"ICOO_AGENTS_SESSION_ID\")\r\n    if sessionId != null {\r\n      config.sessionId = sessionId\r\n    }\r\n\r\n    let resumeSession = os.getEnv(\"ICOO_AGENTS_RESUME\")\r\n    if resumeSession != null {\r\n      config.resumeSession = resumeSession\r\n    }\r\n\r\n    let approval = os.getEnv(\"ICOO_AGENTS_APPROVAL\")\r\n    if approval != null {\r\n      config.approval = approval\r\n    }\r\n\r\n    let skillsDir = os.getEnv(\"ICOO_AGENTS_SKILLS_DIR\")\r\n    if skillsDir != null {\r\n      config.skillsDir = skillsDir\r\n    }\r\n\r\n    let sessionDir = os.getEnv(\"ICOO_AGENTS_SESSION_DIR\")\r\n    if sessionDir != null {\r\n      config.sessionDir = sessionDir\r\n    }\r\n\r\n    let logPath = os.getEnv(\"ICOO_AGENTS_LOG_PATH\")\r\n    if logPath != null {\r\n      config.logPath = logPath\r\n    }\r\n\r\n    let maxTurns = os.getEnv(\"ICOO_AGENTS_MAX_TURNS\")\r\n    if maxTurns != null {\r\n      config.maxTurns = this.parseIntOr(maxTurns, config.maxTurns)\r\n    }\r\n\r\n    let maxFiles = os.getEnv(\"ICOO_AGENTS_MAX_FILES\")\r\n    if maxFiles != null {\r\n      config.maxFiles = this.parseIntOr(maxFiles, config.maxFiles)\r\n    }\r\n\r\n    let maxTotalBytes = os.getEnv(\"ICOO_AGENTS_MAX_TOTAL_BYTES\")\r\n    if maxTotalBytes != null {\r\n      config.maxTotalBytes = this.parseIntOr(maxTotalBytes, config.maxTotalBytes)\r\n    }\r\n\r\n    return config\r\n  }\r\n}\r\n",
    "src/file.ic": "import std.core.object as object\r\nimport std.core.string as str\r\nimport std.data.toml as toml\r\nimport std.io.fs as fs\r\n\r\nexport class ConfigFile {\r\n  applyString(config, value, key) {\r\n    if typeOf(value) == \"string\" \u0026\u0026 value != \"\" {\r\n      config[key] = value\r\n    }\r\n    return config\r\n  }\r\n\r\n  applyInt(config, value, key) {\r\n    if typeOf(value) == \"int\" {\r\n      config[key] = value\r\n    }\r\n    return config\r\n  }\r\n\r\n  applyBool(config, value, key) {\r\n    if typeOf(value) == \"bool\" {\r\n      config[key] = value\r\n    }\r\n    return config\r\n  }\r\n\r\n  resolveConfigPath(config) {\r\n    let workspace = config.workspace\r\n    if typeOf(workspace) != \"string\" || workspace == \"\" {\r\n      return null\r\n    }\r\n\r\n    let normalized = workspace\r\n    if str.hasSuffix(normalized, \"/\") || str.hasSuffix(normalized, \"\\\\\") {\r\n      normalized = fs.dir(normalized + \"x\")\r\n    }\r\n    return fs.join(normalized, \"config.toml\")\r\n  }\r\n\r\n  isAbsolutePath(path) {\r\n    if typeOf(path) != \"string\" || path == \"\" {\r\n      return false\r\n    }\r\n    if str.hasPrefix(path, \"/\") || str.hasPrefix(path, \"\\\\\") {\r\n      return true\r\n    }\r\n    return str.indexOf(path, \":\") == 1\r\n  }\r\n\r\n  resolvePathValue(configDir, value) {\r\n    if typeOf(value) != \"string\" || value == \"\" {\r\n      return value\r\n    }\r\n    if this.isAbsolutePath(value) == true {\r\n      return value\r\n    }\r\n    return fs.join(configDir, value)\r\n  }\r\n\r\n  applyFile(config) {\r\n    let filePath = this.resolveConfigPath(config)\r\n    if filePath == null || fs.exists(filePath) != true {\r\n      return config\r\n    }\r\n    let configDir = fs.dir(filePath)\r\n\r\n    let loaded = toml.fromFile(filePath)\r\n    if typeOf(loaded) != \"object\" {\r\n      return config\r\n    }\r\n\r\n    config = this.applyString(config, object.get(loaded, \"workspace\"), \"workspace\")\r\n    config = this.applyString(config, object.get(loaded, \"mode\"), \"mode\")\r\n    config = this.applyString(config, object.get(loaded, \"model\"), \"model\")\r\n    config = this.applyString(config, object.get(loaded, \"base_url\"), \"baseUrl\")\r\n    config = this.applyString(config, object.get(loaded, \"api_key\"), \"apiKey\")\r\n    config = this.applyString(config, object.get(loaded, \"task\"), \"task\")\r\n    config = this.applyString(config, object.get(loaded, \"session\"), \"sessionId\")\r\n    config = this.applyString(config, object.get(loaded, \"resume\"), \"resumeSession\")\r\n    config = this.applyString(config, object.get(loaded, \"approval\"), \"approval\")\r\n    config = this.applyString(\r\n      config,\r\n      this.resolvePathValue(configDir, object.get(loaded, \"skills_dir\")),\r\n      \"skillsDir\"\r\n    )\r\n    config = this.applyString(\r\n      config,\r\n      this.resolvePathValue(configDir, object.get(loaded, \"session_dir\")),\r\n      \"sessionDir\"\r\n    )\r\n    config = this.applyString(\r\n      config,\r\n      this.resolvePathValue(configDir, object.get(loaded, \"log_path\")),\r\n      \"logPath\"\r\n    )\r\n    config = this.applyInt(config, object.get(loaded, \"max_turns\"), \"maxTurns\")\r\n    config = this.applyInt(config, object.get(loaded, \"max_files\"), \"maxFiles\")\r\n    config = this.applyInt(config, object.get(loaded, \"max_total_bytes\"), \"maxTotalBytes\")\r\n    config = this.applyBool(config, object.get(loaded, \"stream_final_answer\"), \"streamFinalAnswer\")\r\n    config = this.applyString(config, object.get(loaded, \"agent_name\"), \"agentName\")\r\n\r\n    return config\r\n  }\r\n}\r\n\r\nlet fileApi = ConfigFile()\r\n\r\nexport {\r\n  applyFile: fileApi.applyFile,\r\n  resolveConfigPath: fileApi.resolveConfigPath,\r\n  resolvePathValue: fileApi.resolvePathValue,\r\n  ConfigFile: ConfigFile\r\n}\r\n",
    "src/main.ic": "import \"./args.ic\" as args\nimport \"./defaults.ic\" as defaults\nimport \"./env.ic\" as env\nimport \"./file.ic\" as file\nimport \"./merge.ic\" as merge\n\nconst ArgsConfig = args.ArgsConfig\nconst Defaults = defaults.Defaults\nconst EnvConfig = env.EnvConfig\nconst ConfigFile = file.ConfigFile\nconst MergeConfig = merge.MergeConfig\n\nexport { ArgsConfig, Defaults, EnvConfig, ConfigFile, MergeConfig }\n\nfn main() {\n  return null\n}\n",
    "src/merge.ic": "import std.core.object as object\r\n\r\nexport class MergeConfig {\r\n  init(defaultsConfig, argsConfig, envConfig, configFile) {\r\n    this.defaults = defaultsConfig\r\n    this.argsConfig = argsConfig\r\n    this.envConfig = envConfig\r\n    this.configFile = configFile\r\n  }\r\n\r\n  loadConfig(overrides) {\r\n    let config = this.defaults.defaultConfig()\r\n    config = this.argsConfig.previewWorkspace(config)\r\n    config = this.configFile.applyFile(config)\r\n    config = this.envConfig.applyEnv(config)\r\n\r\n    let argResult = this.argsConfig.applyArgs(config)\r\n    config = argResult.config\r\n\r\n    if overrides != null {\r\n      config = object.merge(config, overrides)\r\n    }\r\n\r\n    return {\r\n      config: config,\r\n      help: argResult.help,\r\n      helpText: argResult.helpText\r\n    }\r\n  }\r\n}\r\n"
  }
}