{
  "version": 1,
  "kind": "package",
  "entry": "src/main.ic",
  "entry_function": "main",
  "root_alias": "@",
  "package_name": "issueye/agent/pkg/session",
  "package_version": "0.1.2",
  "export": "src/main.ic",
  "modules": {
    "src/main.ic": "import \"./schema.ic\" as schema\nimport \"./store.ic\" as store\n\nconst Schema = schema.Schema\nconst SessionStore = store.SessionStore\n\nexport { Schema, SessionStore }\n\nfn main() {\n  return null\n}\n",
    "src/schema.ic": "import std.time.basic as time\r\n\r\n// 会话数据库 schema 定义\r\nexport class Schema {\r\n  // Session 数据库 schema 版本\r\n  sessionSchemaVersion() {\r\n    return 2\r\n  }\r\n\r\n  // 归一化会话 ID，确保唯一性\r\n  normalizeSessionId(config) {\r\n    if config.resumeSession != null \u0026\u0026 config.resumeSession != \"\" {\r\n      return config.resumeSession\r\n    }\r\n    if config.sessionId != null \u0026\u0026 config.sessionId != \"\" {\r\n      return config.sessionId\r\n    }\r\n    return \"s_\" + time.format(time.now(), \"YYYYMMDD-HHmmss\", \"UTC\")\r\n  }\r\n\r\n  // 创建新会话\r\n  newSession(config, sessionId) {\r\n    let now = time.now()\r\n\r\n    // Session 作为顶层状态容器，后续所有 turn / event / artifact 都挂在这里。\r\n    return {\r\n      sessionSchemaVersion: this.sessionSchemaVersion(),\r\n      sessionId: sessionId,\r\n      workspace: config.workspace,\r\n      mode: config.mode,\r\n      status: \"idle\",\r\n      createdAt: now,\r\n      updatedAt: now,\r\n      config: {\r\n        model: config.model,\r\n        baseUrl: config.baseUrl,\r\n        approval: config.approval,\r\n        maxTurns: config.maxTurns,\r\n        maxFiles: config.maxFiles,\r\n        maxTotalBytes: config.maxTotalBytes\r\n      },\r\n      turns: [],\r\n      events: [],\r\n      artifacts: [],\r\n      budgets: {\r\n        turnCount: 0,\r\n        toolCallCount: 0\r\n      },\r\n      approvals: []\r\n    }\r\n  }\r\n\r\n  // 创建新 turn\r\n  newTurn(kind, payload) {\r\n    let now = time.now()\r\n    return {\r\n      kind: kind,\r\n      createdAt: now,\r\n      payload: payload\r\n    }\r\n  }\r\n\r\n  // 创建新用户消息 turn\r\n  userMessage(message) {\r\n    return this.newTurn(\"user_message\", message)\r\n  }\r\n\r\n  // 创建新请求快照 turn\r\n  requestSnapshot(messages) {\r\n    return this.newTurn(\"request_snapshot\", {\r\n      messages: messages\r\n    })\r\n  }\r\n\r\n  // 创建新助手消息 turn\r\n  assistantMessage(response) {\r\n    return this.newTurn(\"assistant_message\", {\r\n      role: \"assistant\",\r\n      content: response.text,\r\n      reasoningContent: response.reasoningContent,\r\n      toolCalls: response.toolCalls,\r\n      hasToolCalls: response.hasToolCalls,\r\n      finishReason: response.finishReason,\r\n      mode: response.mode\r\n    })\r\n  }\r\n\r\n  // 创建新工具消息 turn\r\n  toolMessage(executed) {\r\n    return this.newTurn(\"tool_message\", {\r\n      role: \"tool\",\r\n      toolCallId: executed.toolCallId,\r\n      name: executed.name,\r\n      output: executed.output,\r\n      ok: executed.ok,\r\n      error: executed.error\r\n    })\r\n  }\r\n\r\n  // 创建新运行摘要 turn\r\n  runSummary(summary) {\r\n    return this.newTurn(\"run_summary\", summary)\r\n  }\r\n}\r\n",
    "src/store.ic": "import std.core.object as object\nimport std.data.json as json\nimport std.io.fs as fs\nimport std.sys.os as os\nimport std.time.basic as time\n\r\nexport class SessionStore {\r\n  init(sessionSchema) {\r\n    this.schema = sessionSchema\r\n  }\r\n\r\n  validateTurnKinds(turns, filePath) {\r\n    let allowed = {\r\n      user_message: true,\r\n      request_snapshot: true,\r\n      assistant_message: true,\r\n      tool_message: true,\r\n      run_summary: true\r\n    }\r\n    let deprecated = {\r\n      user_prompt: true,\r\n      request_messages: true,\r\n      assistant_response: true,\r\n      tool_result: true\r\n    }\r\n\r\n    for i, turn in turns {\n      let kind = turn.kind\n      if object.get(deprecated, kind, false) == true {\n        panic(\"deprecated session turn kind: \" + kind + \" in \" + filePath)\n      }\n      if object.get(allowed, kind, false) != true {\n        panic(\"unknown session turn kind in \" + filePath)\n      }\n    }\n  }\n\r\n  sessionPath(config, sessionId) {\r\n    return fs.join(config.sessionDir, sessionId + \".json\")\r\n  }\r\n\r\n  save(config, session) {\r\n    os.mkdirAll(config.sessionDir)\r\n    session.updatedAt = time.now()\r\n    let filePath = this.sessionPath(config, session.sessionId)\r\n    json.saveToFile(filePath, session)\r\n    return filePath\r\n  }\r\n\r\n  load(config, sessionId) {\r\n    let filePath = this.sessionPath(config, sessionId)\r\n    if fs.exists(filePath) != true {\r\n      return null\r\n    }\r\n\r\n    let loaded = json.fromFile(filePath)\r\n    if loaded == null || typeOf(loaded) != \"object\" {\r\n      panic(\"invalid session file: \" + filePath)\r\n    }\r\n    if loaded.sessionId == null || loaded.sessionId == \"\" {\r\n      panic(\"invalid session schema: missing sessionId\")\r\n    }\r\n    if loaded.sessionSchemaVersion != this.schema.sessionSchemaVersion() {\r\n      panic(\"unsupported session schema version: \" + loaded.sessionSchemaVersion)\r\n    }\r\n    if typeOf(loaded.turns) != \"array\" {\r\n      loaded.turns = []\r\n    }\r\n    if typeOf(loaded.events) != \"array\" {\r\n      loaded.events = []\r\n    }\r\n    if typeOf(loaded.artifacts) != \"array\" {\r\n      loaded.artifacts = []\r\n    }\r\n    if typeOf(loaded.approvals) != \"array\" {\r\n      loaded.approvals = []\r\n    }\r\n    if typeOf(loaded.budgets) != \"object\" {\r\n      loaded.budgets = {\r\n        turnCount: 0,\r\n        toolCallCount: 0\r\n      }\r\n    }\r\n    this.validateTurnKinds(loaded.turns, filePath)\r\n\r\n    return loaded\r\n  }\r\n\r\n  open(config) {\r\n    let sessionId = this.schema.normalizeSessionId(config)\r\n    let loaded = this.load(config, sessionId)\r\n    if loaded != null {\r\n      loaded.status = \"running\"\r\n      let loadedPath = this.save(config, loaded)\r\n      return {\r\n        session: loaded,\r\n        path: loadedPath,\r\n        resumed: true\r\n      }\r\n    }\r\n\r\n    let created = this.schema.newSession(config, sessionId)\r\n    created.status = \"running\"\r\n    let createdPath = this.save(config, created)\r\n    return {\r\n      session: created,\r\n      path: createdPath,\r\n      resumed: false\r\n    }\r\n  }\r\n\r\n  appendTurn(config, session, turn) {\r\n    session.turns = session.turns.append(turn)\r\n    session.budgets.turnCount = len(session.turns)\r\n    if turn.kind == \"tool_message\" {\r\n      session.budgets.toolCallCount = session.budgets.toolCallCount + 1\r\n    }\r\n    this.save(config, session)\r\n    return turn\r\n  }\r\n\r\n  appendUserMessage(config, session, message) {\r\n    return this.appendTurn(config, session, this.schema.userMessage(message))\r\n  }\r\n\r\n  appendRequestSnapshot(config, session, messages) {\r\n    return this.appendTurn(config, session, this.schema.requestSnapshot(messages))\r\n  }\r\n\r\n  appendAssistantMessage(config, session, response) {\r\n    return this.appendTurn(config, session, this.schema.assistantMessage(response))\r\n  }\r\n\r\n  appendToolMessage(config, session, executed) {\r\n    return this.appendTurn(config, session, this.schema.toolMessage(executed))\r\n  }\r\n\r\n  markCompleted(config, session, summary) {\r\n    session.status = \"completed\"\r\n    if summary != null {\r\n      session.lastResult = summary\r\n      this.appendTurn(config, session, this.schema.runSummary(summary))\r\n    }\r\n    return this.save(config, session)\r\n  }\r\n\r\n  buildMessages(config, context, session) {\n    let systemPrompt = \"You are an Icoo agent. Be concise, repository-aware, and action-oriented. Use tools when repository inspection is required before answering.\"\n    if context != null \u0026\u0026 typeOf(context) == \"object\" {\n      let nextSystemPrompt = object.get(context, \"systemPrompt\")\n      if typeOf(nextSystemPrompt) == \"string\" \u0026\u0026 nextSystemPrompt != \"\" {\n        systemPrompt = nextSystemPrompt\n      }\n    }\n\n    let messages = [\n      {\n        role: \"system\",\n        content: systemPrompt\n      }\n    ]\n\r\n    let hasUserTurn = false\r\n    for i, turn in session.turns {\r\n      let payload = turn.payload\r\n      if turn.kind == \"user_message\" {\r\n        hasUserTurn = true\r\n        messages = messages.append(payload)\r\n        continue\r\n      }\r\n      if turn.kind == \"request_snapshot\" {\r\n        continue\r\n      }\r\n      if turn.kind == \"assistant_message\" {\r\n        let assistantMessage = {\r\n          role: \"assistant\",\r\n          content: payload.content\r\n        }\r\n        if payload.reasoningContent != null \u0026\u0026 payload.reasoningContent != \"\" {\r\n          assistantMessage.reasoning_content = payload.reasoningContent\r\n        }\r\n        if payload.hasToolCalls == true {\r\n          assistantMessage.tool_calls = payload.toolCalls\r\n        }\r\n        messages = messages.append(assistantMessage)\r\n        continue\r\n      }\r\n      if turn.kind == \"tool_message\" {\r\n        messages = messages.append({\r\n          role: \"tool\",\r\n          tool_call_id: payload.toolCallId,\r\n          name: payload.name,\r\n          content: json.encode(payload.output)\r\n        })\r\n        continue\r\n      }\r\n    }\r\n\r\n    if hasUserTurn != true {\r\n      messages = messages.append({\r\n        role: \"user\",\r\n        content: context.userPrompt\r\n      })\r\n    }\r\n\r\n    return messages\r\n  }\r\n}\r\n"
  }
}