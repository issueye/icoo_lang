# Agent project defaults.
# Priority: defaults < config.toml < explicit overrides

workspace = "./runtime"
mode = "server"
model = "deepseek-v4-flash"
base_url = ""
api_key = ""
approval = "on-request"
max_turns = 12
max_files = 24
max_total_bytes = 32768
stream_final_answer = true
agent_name = "icoo_agents"

server_host = "127.0.0.1"
server_port = 8099
server_read_timeout_ms = 0
server_read_header_timeout_ms = 0
server_write_timeout_ms = 0
server_idle_timeout_ms = 0

# Project-local runtime state defaults.
session_dir = "./runtime/.agents/sessions"
log_path = "./runtime/.agents/agent.log"
