import std.time.basic as time

// 会话数据库 schema 定义
export class Schema {
  // Session 数据库 schema 版本
  sessionSchemaVersion() {
    return 2
  }

  // 归一化会话 ID，确保唯一性
  normalizeSessionId(config) {
    if config.resumeSession != null && config.resumeSession != "" {
      return config.resumeSession
    }
    if config.sessionId != null && config.sessionId != "" {
      return config.sessionId
    }
    return "s_" + time.format(time.now(), "YYYYMMDD-HHmmss", "UTC")
  }

  // 创建新会话
  newSession(config, sessionId) {
    let now = time.now()

    // Session 作为顶层状态容器，后续所有 turn / event / artifact 都挂在这里。
    return {
      sessionSchemaVersion: this.sessionSchemaVersion(),
      sessionId: sessionId,
      workspace: config.workspace,
      mode: config.mode,
      status: "idle",
      createdAt: now,
      updatedAt: now,
      config: {
        model: config.model,
        baseUrl: config.baseUrl,
        approval: config.approval,
        maxTurns: config.maxTurns,
        maxFiles: config.maxFiles,
        maxTotalBytes: config.maxTotalBytes
      },
      turns: [],
      events: [],
      artifacts: [],
      budgets: {
        turnCount: 0,
        toolCallCount: 0
      },
      approvals: []
    }
  }

  // 创建新 turn
  newTurn(kind, payload) {
    let now = time.now()
    return {
      kind: kind,
      createdAt: now,
      payload: payload
    }
  }

  // 创建新用户消息 turn
  userMessage(message) {
    return this.newTurn("user_message", message)
  }

  // 创建新请求快照 turn
  requestSnapshot(messages) {
    return this.newTurn("request_snapshot", {
      messages: messages
    })
  }

  // 创建新助手消息 turn
  assistantMessage(response) {
    return this.newTurn("assistant_message", {
      role: "assistant",
      content: response.text,
      reasoningContent: response.reasoningContent,
      toolCalls: response.toolCalls,
      hasToolCalls: response.hasToolCalls,
      finishReason: response.finishReason,
      mode: response.mode
    })
  }

  // 创建新工具消息 turn
  toolMessage(executed) {
    return this.newTurn("tool_message", {
      role: "tool",
      toolCallId: executed.toolCallId,
      name: executed.name,
      output: executed.output,
      ok: executed.ok,
      error: executed.error
    })
  }

  // 创建新运行摘要 turn
  runSummary(summary) {
    return this.newTurn("run_summary", summary)
  }
}
