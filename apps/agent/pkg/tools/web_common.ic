import std.core.string as str
import std.data.json as json

// WebCommon 是一个通用的Web工具类。
export class WebCommon {
  // after 提取字符串中指定标记之后的内容。
  after(text, marker) {
    let parts = str.split(text, marker)
    if len(parts) < 2 {
      return ""
    }
    return parts[1]
  }

  // between 提取字符串中两个标记之间的内容。
  between(text, startMarker, endMarker) {
    let tail = this.after(text, startMarker)
    if tail == "" {
      return ""
    }
    return str.split(tail, endMarker)[0]
  }

  // decodeEntities 解码HTML实体。
  decodeEntities(text) {
    text = str.replace(text, "&amp;", "&")
    text = str.replace(text, "&lt;", "<")
    text = str.replace(text, "&gt;", ">")
    text = str.replace(text, "&quot;", "\"")
    text = str.replace(text, "&#39;", "'")
    text = str.replace(text, "&nbsp;", " ")
    return text
  }

  // quoteChar 获取HTML实体中的引号。
  quoteChar() {
    return this.decodeEntities("&quot;")
  }

  // decodeJSONString 解码JSON字符串。
  decodeJSONString(text) {
    try {
      let decoded = json.decode(text)
      if typeOf(decoded) == "string" {
        return decoded
      }
    } catch err {
      return text
    }
    return text
  }

  // normalizeSpaces 规范化空格。
  normalizeSpaces(text) {
    text = str.replace(text, "\r", " ")
    text = str.replace(text, "\n", " ")
    text = str.replace(text, "\t", " ")

    let parts = str.split(text, " ")
    let compact = []
    for i, part in parts {
      part = str.trimSpace(part)
      if part == "" {
        continue
      }
      compact = compact.append(part)
    }
    return str.join(compact, " ")
  }

  // htmlToText 将HTML转换为文本。
  htmlToText(html) {
    html = this.decodeEntities(html)

    let parts = str.split(html, "<")
    let chunks = []
    for i, part in parts {
      if i == 0 {
        chunks = chunks.append(part)
        continue
      }

      let inner = str.split(part, ">")
      let j = 1
      while j < len(inner) {
        chunks = chunks.append(inner[j])
        j = j + 1
      }
    }

    return this.normalizeSpaces(str.join(chunks, " "))
  }

  // clipText 截取文本，确保不超过最大字符数。
  clipText(text, maxChars) {
    if typeOf(maxChars) != "int" || maxChars <= 0 {
      return text
    }
    if len(text) <= maxChars {
      return text
    }

    let parts = str.split(text, " ")
    let clipped = ""
    for i, part in parts {
      part = str.trimSpace(part)
      if part == "" {
        continue
      }

      let next = part
      if clipped != "" {
        next = clipped + " " + part
      }
      if len(next) > maxChars {
        break
      }
      clipped = next
    }

    if clipped == "" {
      return text
    }
    return clipped
  }

  // extractTitle 从HTML中提取标题。
  extractTitle(html) {
    let title = this.between(html, "<title>", "</title>")
    if title == "" {
      title = this.between(html, "<TITLE>", "</TITLE>")
    }
    return this.normalizeSpaces(this.decodeEntities(title))
  }

  // extractSnippet 从HTML中提取片段。
  extractSnippet(chunk) {
    let tail = this.after(chunk, "result__snippet")
    if tail == "" {
      return ""
    }

    let parts = str.split(tail, ">")
    if len(parts) < 2 {
      return ""
    }
    return this.htmlToText(parts[1])
  }
  
  // parseDuckDuckGoResults 解析DuckDuckGo搜索结果。
  parseDuckDuckGoResults(html, maxResults) {
    let results = []
    let limit = maxResults
    if typeOf(limit) != "int" || limit <= 0 {
      limit = 5
    }

    // DuckDuckGo HTML results are anchor-heavy. Split on `<a ` first, then
    // keep only anchors that carry the `result__a` class.
    let parts = str.split(html, "<a ")
    let i = 0
    while i < len(parts) && len(results) < limit {
      let chunk = parts[i]
      if str.contains(chunk, "result__a") != true {
        i = i + 1
        continue
      }

      let hrefTail = this.after(chunk, "href=")
      if hrefTail == "" {
        i = i + 1
        continue
      }
      let anchorParts = str.split(hrefTail, ">")
      if len(anchorParts) < 2 {
        i = i + 1
        continue
      }
      let url = this.decodeJSONString(anchorParts[0])

      let titleHtml = str.split(anchorParts[1], "</a>")[0]
      let title = this.htmlToText(titleHtml)
      let snippet = this.extractSnippet(chunk)
      if title != "" && url != "" {
        results = results.append({
          title: title,
          url: url,
          snippet: snippet
        })
      }
      i = i + 1
    }

    return results
  }
}

