import std.io.fs as fs
import std.sys.os as os

export class Defaults {
  defaultConfig() {
    let stateDir = fs.join(os.cwd(), ".agent")
    return {
      workspace: os.cwd(),
      mode: "interactive",
      model: "gpt-4.1-mini",
      baseUrl: "https://api.openai.com/v1",
      apiKey: null,
      task: null,
      sessionId: null,
      resumeSession: null,
      approval: "on-request",
      maxTurns: 12,
      maxFiles: 24,
      maxTotalBytes: 32768,
      streamFinalAnswer: true,
      agentName: "icoo_agent",
      sessionDir: fs.join(stateDir, "sessions"),
      logPath: fs.join(stateDir, "agent.log"),
      cliUnknownArgs: []
    }
  }
}
