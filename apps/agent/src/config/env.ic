import std.sys.os as os
import std.math.basic as math

const envApi = fn() {
  fn parseIntOr(value, fallback) {
    try {
      return math.parseInt(value)
    } catch err {
      return fallback
    }
  }

  fn applyEnv(config) {
    // 环境变量覆盖用于无交互启动和 CI 场景。
    let workspace = os.getEnv("ICOO_AGENT_WORKSPACE")
    if workspace != null {
      config.workspace = workspace
    }

    let mode = os.getEnv("ICOO_AGENT_MODE")
    if mode != null {
      config.mode = mode
    }

    let model = os.getEnv("ICOO_AGENT_MODEL")
    if model != null {
      config.model = model
    }

    let baseUrl = os.getEnv("ICOO_AGENT_BASE_URL")
    if baseUrl != null {
      config.baseUrl = baseUrl
    }

    let apiKey = os.getEnv("ICOO_AGENT_API_KEY")
    if apiKey != null {
      config.apiKey = apiKey
    }

    let task = os.getEnv("ICOO_AGENT_TASK")
    if task != null {
      config.task = task
    }

    let sessionId = os.getEnv("ICOO_AGENT_SESSION_ID")
    if sessionId != null {
      config.sessionId = sessionId
    }

    let resumeSession = os.getEnv("ICOO_AGENT_RESUME")
    if resumeSession != null {
      config.resumeSession = resumeSession
    }

    let approval = os.getEnv("ICOO_AGENT_APPROVAL")
    if approval != null {
      config.approval = approval
    }

    let sessionDir = os.getEnv("ICOO_AGENT_SESSION_DIR")
    if sessionDir != null {
      config.sessionDir = sessionDir
    }

    let logPath = os.getEnv("ICOO_AGENT_LOG_PATH")
    if logPath != null {
      config.logPath = logPath
    }

    let maxTurns = os.getEnv("ICOO_AGENT_MAX_TURNS")
    if maxTurns != null {
      config.maxTurns = parseIntOr(maxTurns, config.maxTurns)
    }

    let maxFiles = os.getEnv("ICOO_AGENT_MAX_FILES")
    if maxFiles != null {
      config.maxFiles = parseIntOr(maxFiles, config.maxFiles)
    }

    let maxTotalBytes = os.getEnv("ICOO_AGENT_MAX_TOTAL_BYTES")
    if maxTotalBytes != null {
      config.maxTotalBytes = parseIntOr(maxTotalBytes, config.maxTotalBytes)
    }

    return config
  }

  return {
    applyEnv: applyEnv
  }
}()

export const applyEnv = envApi.applyEnv
