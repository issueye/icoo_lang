import std.core.object as object
import "@/src/config/defaults.ic" as defaults
import "@/src/config/env.ic" as env
import "@/src/config/args.ic" as args

const mergeApi = fn() {
  fn loadConfig(overrides) {
    // 配置优先级固定为 defaults -> env -> args -> explicit overrides。
    let config = defaults.defaultConfig()
    config = env.applyEnv(config)
    config = args.applyArgs(config)

    if overrides != null {
      config = object.merge(config, overrides)
    }

    return config
  }

  return {
    loadConfig: loadConfig
  }
}()

export const loadConfig = mergeApi.loadConfig
