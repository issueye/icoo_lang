import std.io.fs as fs
import std.core.string as str
import "@/src/context/budget.ic" as budget
import "@/src/context/ignore.ic" as ignore

export class ContextBuilder {
  init(ignoreRule, contextBudget, skillCatalog) {
    this.ignore = ignoreRule
    this.budget = contextBudget
    this.skillCatalog = skillCatalog
  }

  isPreviewable(path) {
    return (
      str.hasSuffix(path, ".ic") ||
      str.hasSuffix(path, ".md") ||
      str.hasSuffix(path, ".txt") ||
      str.hasSuffix(path, ".json") ||
      str.hasSuffix(path, ".toml") ||
      str.hasSuffix(path, ".yaml") ||
      str.hasSuffix(path, ".yml") ||
      str.hasSuffix(path, ".go") ||
      str.hasSuffix(path, ".js") ||
      str.hasSuffix(path, ".ts")
    )
  }

  fileItem(path, size, included, preview, omittedReason) {
    return {
      path: path,
      size: size,
      kind: "file",
      included: included,
      preview: preview,
      omittedReason: omittedReason
    }
  }

  pushOmitted(state, path, reason) {
    state.omittedCount = state.omittedCount + 1
    state.omitted = state.omitted.append({
      path: path,
      reason: reason
    })
  }

  summarizeFile(path, info, state) {
    if state.fileCount >= state.budget.maxFiles {
      return
    }

    state.fileCount = state.fileCount + 1

    if state.totalBytes + info.size > state.budget.maxTotalBytes {
      this.pushOmitted(state, path, "budget exceeded")
      state.files = state.files.append(this.fileItem(path, info.size, false, null, "budget exceeded"))
      return
    }

    let preview = null
    if this.isPreviewable(path) == true {
      preview = fs.readFile(path)
    }

    state.totalBytes = state.totalBytes + info.size
    state.files = state.files.append(this.fileItem(path, info.size, true, preview, null))
  }

  scan(path, depth, state) {
    if depth > state.budget.maxDepth {
      this.pushOmitted(state, path, "max depth reached")
      return
    }
    if state.fileCount >= state.budget.maxFiles {
      return
    }

    let info = fs.stat(path)
    if info.isFile {
      this.summarizeFile(path, info, state)
      return
    }

    let entries = fs.readDir(path)
    for i, entry in entries {
      if state.fileCount >= state.budget.maxFiles {
        break
      }
      if this.ignore.shouldIgnoreName(entry.name) == true {
        this.pushOmitted(state, entry.path, "ignored by name")
        continue
      }

      if entry.isDir {
        this.scan(entry.path, depth + 1, state)
        continue
      }

      this.summarizeFile(entry.path, fs.stat(entry.path), state)
    }
  }

  build(config) {
    let state = {
      budget: this.budget.create(config),
      fileCount: 0,
      totalBytes: 0,
      omittedCount: 0,
      files: [],
      omitted: []
    }

    this.scan(config.workspace, 0, state)

    return {
      workspace: config.workspace,
      summary: {
        fileCount: state.fileCount,
        totalBytes: state.totalBytes,
        omittedCount: state.omittedCount,
        maxFiles: state.budget.maxFiles,
        maxTotalBytes: state.budget.maxTotalBytes,
        maxDepth: state.budget.maxDepth
      },
      skillsSummary: this.skillCatalog.summary(config),
      files: state.files,
      omitted: state.omitted
    }
  }
}
