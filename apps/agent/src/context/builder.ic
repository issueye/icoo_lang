import std.io.fs as fs
import std.core.string as str
import "@/src/context/budget.ic" as budget
import "@/src/context/ignore.ic" as ignore

const builderApi = fn() {
  fn isPreviewable(path) {
    return (
      str.hasSuffix(path, ".ic") ||
      str.hasSuffix(path, ".md") ||
      str.hasSuffix(path, ".txt") ||
      str.hasSuffix(path, ".json") ||
      str.hasSuffix(path, ".toml") ||
      str.hasSuffix(path, ".yaml") ||
      str.hasSuffix(path, ".yml") ||
      str.hasSuffix(path, ".go") ||
      str.hasSuffix(path, ".js") ||
      str.hasSuffix(path, ".ts")
    )
  }

  fn fileItem(path, size, included, preview, omittedReason) {
    return {
      path: path,
      size: size,
      kind: "file",
      included: included,
      preview: preview,
      omittedReason: omittedReason
    }
  }

  fn pushOmitted(state, path, reason) {
    state.omittedCount = state.omittedCount + 1
    state.omitted = state.omitted.append({
      path: path,
      reason: reason
    })
  }

  fn summarizeFile(path, info, state) {
    if state.fileCount >= state.budget.maxFiles {
      return
    }

    state.fileCount = state.fileCount + 1

    if state.totalBytes + info.size > state.budget.maxTotalBytes {
      pushOmitted(state, path, "budget exceeded")
      state.files = state.files.append(fileItem(path, info.size, false, null, "budget exceeded"))
      return
    }

    let preview = null
    if isPreviewable(path) == true {
      // 先直接读全文；后续如果大文件预览仍有成本问题，再补专门的截断读能力。
      preview = fs.readFile(path)
    }

    state.totalBytes = state.totalBytes + info.size
    state.files = state.files.append(fileItem(path, info.size, true, preview, null))
  }

  fn scan(path, depth, state) {
    if depth > state.budget.maxDepth {
      pushOmitted(state, path, "max depth reached")
      return
    }
    if state.fileCount >= state.budget.maxFiles {
      return
    }

    let info = fs.stat(path)
    if info.isFile {
      summarizeFile(path, info, state)
      return
    }

    let entries = fs.readDir(path)
    for i, entry in entries {
      if state.fileCount >= state.budget.maxFiles {
        break
      }
      if ignore.shouldIgnoreName(entry.name) == true {
        pushOmitted(state, entry.path, "ignored by name")
        continue
      }

      if entry.isDir {
        scan(entry.path, depth + 1, state)
        continue
      }

      summarizeFile(entry.path, fs.stat(entry.path), state)
    }
  }

  fn build(config) {
    // 第一版优先保证结构清晰：summary + files + omitted，便于后续直接喂给 model 层。
    let state = {
      budget: budget.create(config),
      fileCount: 0,
      totalBytes: 0,
      omittedCount: 0,
      files: [],
      omitted: []
    }

    scan(config.workspace, 0, state)

    return {
      workspace: config.workspace,
      summary: {
        fileCount: state.fileCount,
        totalBytes: state.totalBytes,
        omittedCount: state.omittedCount,
        maxFiles: state.budget.maxFiles,
        maxTotalBytes: state.budget.maxTotalBytes,
        maxDepth: state.budget.maxDepth
      },
      files: state.files,
      omitted: state.omitted
    }
  }

  return {
    build: build
  }
}()

export const build = builderApi.build
