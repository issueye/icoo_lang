import std.io.console as io
import "@/src/config/merge.ic" as config
import "@/src/runtime/runtime.ic" as runtime

const agentApi = fn() {
  fn startImpl(overrides) {
    // 启动层先收敛配置和 help 分支，再决定是否进入 runtime。
    let loaded = config.MergeConfig.loadConfig(overrides)
    let cfg = loaded.config
    if loaded.help == true {
      io.println(loaded.helpText)
      return {
        ok: true,
        help: true,
        config: cfg
      }
    }
    return runtime.Runtime.start(cfg)
  }

  fn mainImpl() {
    return startImpl(null)
  }

  return {
    start: startImpl,
    main: mainImpl
  }
}()

const main = agentApi.main

export {
  start: agentApi.start,
  main,
}
