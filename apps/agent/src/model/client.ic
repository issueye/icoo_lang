import std.net.http.client as http
import std.data.json as json
import "@/src/model/messages.ic" as messages
import "@/src/model/parser.ic" as parser

const clientApi = fn() {
  fn localFallback(context) {
    return {
      mode: "local",
      text:
        "Summary\n" +
        "- Remote model is disabled because no API key is configured.\n" +
        "- Workspace context was collected successfully.\n\n" +
        "Risks\n" +
        "- This fallback does not yet perform model-grade reasoning.\n" +
        "- Tool-calling requires a remote OpenAI-compatible model endpoint.\n\n" +
        "Next Steps\n" +
        "- Configure `ICOO_AGENT_API_KEY` to enable remote model calls.\n" +
        "- Keep extending tool coverage and session persistence on top of the current runtime loop.\n\n" +
        "Context Summary\n" +
        context.summaryJson,
      toolCalls: [],
      hasToolCalls: false
    }
  }

  fn requestRemote(config, payload) {
    let response = http.requestJSON({
      url: config.baseUrl + "/chat/completions",
      method: "POST",
      headers: {
        Authorization: "Bearer " + config.apiKey
      },
      json: payload
    })

    let parsed = parser.parseResponse(response.json)
    if parsed.ok == true {
      return {
        mode: "remote",
        text: parsed.text,
        raw: response.json,
        toolCalls: parsed.toolCalls,
        hasToolCalls: parsed.hasToolCalls,
        finishReason: parsed.finishReason
      }
    }

    return {
      mode: "remote",
      text: json.encode(response.json),
      raw: response.json,
      toolCalls: [],
      hasToolCalls: false,
      finishReason: null
    }
  }

  fn request(config, context) {
    if config.apiKey == null || config.apiKey == "" {
      return localFallback(context)
    }

    return requestRemote(config, {
      model: config.model,
      temperature: 0.2,
      messages: messages.build(config, context),
      tools: messages.toolDefinitions()
    })
  }

  fn requestWithMessages(config, builtMessages) {
    if config.apiKey == null || config.apiKey == "" {
      return {
        mode: "local",
        text: "Local fallback does not emulate multi-turn tool calling.",
        toolCalls: [],
        hasToolCalls: false,
        finishReason: null
      }
    }

    return requestRemote(config, {
      model: config.model,
      temperature: 0.2,
      messages: builtMessages,
      tools: messages.toolDefinitions()
    })
  }

  return {
    request: request,
    requestWithMessages: requestWithMessages
  }
}()

export const request = clientApi.request
export const requestWithMessages = clientApi.requestWithMessages
