import std.net.http.client as http
import std.io.console as io
import std.core.object as object
import std.core.string as str
import std.data.json as json
import "@/src/model/messages.ic" as messages
import "@/src/model/parser.ic" as parser

class ModelClient {
  shouldStreamFinalAnswer(config, builtMessages) {
    if config.streamFinalAnswer != true {
      return false
    }

    for i, message in builtMessages {
      if message.role == "tool" {
        return true
      }
    }
    return false
  }

  tryParseStreamLine(line) {
    if str.hasPrefix(line, "data: ") != true {
      return null
    }
    let raw = str.split(line, "data: ")[1]
    if raw == "[DONE]" {
      return {
        done: true
      }
    }

    try {
      return {
        done: false,
        json: json.decode(raw)
      }
    } catch err {
      return null
    }
  }

  requestRemoteStream(config, payload) {
    let stream = http.requestStream({
      url: config.baseUrl + "/chat/completions",
      method: "POST",
      headers: {
        Authorization: "Bearer " + config.apiKey,
        Accept: "text/event-stream",
        "Content-Type": "application/json"
      },
      body: json.encode(payload)
    })

    let state = {
      text: "",
      reasoningContent: "",
      toolCalls: [],
      finishReason: null,
      hasToolCalls: false,
      deltaText: ""
    }
    let done = false
    let startedOutput = false
    let printed = false

    try {
      let text = stream.readAll()
      let lines = str.split(text, "\n")
      for i, rawLine in lines {
        let line = str.trimSpace(rawLine)
        if line == "" {
          continue
        }

        let parsedLine = this.tryParseStreamLine(line)
        if parsedLine == null {
          continue
        }
        if parsedLine.done == true {
          done = true
          break
        }

        state = parser.parseStreamEvent(parsedLine.json, state)
        if state.sawToolCallDelta == true {
          panic("stream emitted tool_calls; fallback to non-streaming response")
        }
        if state.deltaText != "" {
          if startedOutput != true {
            io.println("streaming final answer:")
            startedOutput = true
          }
          io.print(state.deltaText)
          printed = true
        }
      }
    } finally {
      stream.close()
    }

    if printed == true {
      io.println("")
    }

    return {
      mode: "remote",
      text: state.text,
      reasoningContent: state.reasoningContent,
      raw: null,
      toolCalls: state.toolCalls,
      hasToolCalls: state.hasToolCalls,
      finishReason: state.finishReason
    }
  }

  localFallback(context) {
    return {
      mode: "local",
      text:
        "Summary\n" +
        "- Remote model is disabled because no API key is configured.\n" +
        "- Workspace context was collected successfully.\n\n" +
        "Risks\n" +
        "- This fallback does not yet perform model-grade reasoning.\n" +
        "- Tool-calling requires a remote OpenAI-compatible model endpoint.\n\n" +
        "Next Steps\n" +
        "- Configure `ICOO_AGENT_API_KEY` to enable remote model calls.\n" +
        "- Keep extending tool coverage and session persistence on top of the current runtime loop.\n\n" +
        "Context Summary\n" +
        context.summaryJson,
      reasoningContent: null,
      toolCalls: [],
      hasToolCalls: false
    }
  }

  requestRemote(config, payload) {
    let response = http.requestJSON({
      url: config.baseUrl + "/chat/completions",
      method: "POST",
      headers: {
        Authorization: "Bearer " + config.apiKey
      },
      json: payload
    })

    let parsed = parser.parseResponse(response.json)
    if parsed.ok == true {
      return {
        mode: "remote",
        text: parsed.text,
        reasoningContent: parsed.reasoningContent,
        raw: response.json,
        toolCalls: parsed.toolCalls,
        hasToolCalls: parsed.hasToolCalls,
        finishReason: parsed.finishReason
      }
    }

    return {
      mode: "remote",
      text: json.encode(response.json),
      raw: response.json,
      reasoningContent: null,
      toolCalls: [],
      hasToolCalls: false,
      finishReason: null
    }
  }

  request(config, context) {
    if config.apiKey == null || config.apiKey == "" {
      return this.localFallback(context)
    }

    return this.requestRemote(config, {
      model: config.model,
      temperature: 0.2,
      messages: messages.build(config, context),
      tools: messages.toolDefinitions()
    })
  }

  requestWithMessages(config, builtMessages) {
    if config.apiKey == null || config.apiKey == "" {
      return {
        mode: "local",
        text: "Local fallback does not emulate multi-turn tool calling.",
        reasoningContent: null,
        toolCalls: [],
        hasToolCalls: false,
        finishReason: null
      }
    }

    let payload = {
      model: config.model,
      temperature: 0.2,
      messages: builtMessages,
      tools: messages.toolDefinitions()
    }

    if this.shouldStreamFinalAnswer(config, builtMessages) == true {
      try {
        return this.requestRemoteStream(config, object.merge(payload, {
          stream: true
        }))
      } catch err {
        return this.requestRemote(config, payload)
      }
    }

    return this.requestRemote(config, payload)
  }

}

let clientApi = ModelClient()

export const request = clientApi.request
export const requestWithMessages = clientApi.requestWithMessages
