import std.data.json as json
import std.core.object as object

export class ModelMessages {
  init(toolRegistry) {
    this.toolRegistry = toolRegistry
  }

  systemPrompt() {
    return "You are an Icoo agent. Be concise, repository-aware, and action-oriented. Use tools when repository inspection is required before answering."
  }

  userPrompt(config, context) {
    let text = ""
    if config.task != null && config.task != "" {
      text = text + "Task:\n" + config.task + "\n\n"
    } else {
      text = text + "Task:\nSummarize the repository state and suggest the next concrete engineering step.\n\n"
    }
    text = text + "Workspace:\n" + context.workspace + "\n\n"
    if typeOf(context.cliUnknownArgs) == "array" && len(context.cliUnknownArgs) > 0 {
      text = text + "CLI Unknown Args:\n" + json.encode(context.cliUnknownArgs) + "\n\n"
    }
    let skillsSummary = object.get(context, "skillsSummary")
    if typeOf(skillsSummary) == "string" && skillsSummary != "" {
      text = text + skillsSummary + "\n\n"
    }
    text = text + "Context Summary:\n" + context.summaryJson + "\n"
    return text
  }

  buildBase(config, context) {
    return [
      {
        role: "system",
        content: this.systemPrompt()
      },
      {
        role: "user",
        content: this.userPrompt(config, context)
      }
    ]
  }

  build(config, context) {
    return this.buildBase(config, context)
  }

  toolDefinitions() {
    return this.toolRegistry.definitions()
  }

  appendAssistantToolCalls(messages, toolCalls, content, reasoningContent) {
    let assistantContent = content
    if assistantContent == null {
      assistantContent = ""
    }
    let assistantMessage = {
      role: "assistant",
      content: assistantContent,
      tool_calls: toolCalls
    }
    if reasoningContent != null && reasoningContent != "" {
      assistantMessage.reasoning_content = reasoningContent
    }
    return messages.append(assistantMessage)
  }

  appendToolResult(messages, toolCallId, name, output) {
    return messages.append({
      role: "tool",
      tool_call_id: toolCallId,
      name: name,
      content: json.encode(output)
    })
  }
}
