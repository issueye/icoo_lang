import std.data.json as json
import "@/src/tools/registry.ic" as registry

const messagesApi = fn() {
  fn systemPrompt() {
    return "You are an Icoo agent. Be concise, repository-aware, and action-oriented. Use tools when repository inspection is required before answering."
  }

  fn userPrompt(config, context) {
    let text = ""
    if config.task != null && config.task != "" {
      text = text + "Task:\n" + config.task + "\n\n"
    } else {
      text = text + "Task:\nSummarize the repository state and suggest the next concrete engineering step.\n\n"
    }
    text = text + "Workspace:\n" + context.workspace + "\n\n"
    text = text + "Context Summary:\n" + context.summaryJson + "\n"
    return text
  }

  fn buildBase(config, context) {
    return [
      {
        role: "system",
        content: systemPrompt()
      },
      {
        role: "user",
        content: userPrompt(config, context)
      }
    ]
  }

  fn build(config, context) {
    return buildBase(config, context)
  }

  fn toolDefinitions() {
    return registry.definitions()
  }

  fn appendAssistantToolCalls(messages, toolCalls, content) {
    let assistantContent = content
    if assistantContent == null {
      assistantContent = ""
    }
    return messages.append({
      role: "assistant",
      content: assistantContent,
      tool_calls: toolCalls
    })
  }

  fn appendToolResult(messages, toolCallId, name, output) {
    return messages.append({
      role: "tool",
      tool_call_id: toolCallId,
      name: name,
      content: json.encode(output)
    })
  }

  return {
    build: build,
    buildBase: buildBase,
    toolDefinitions: toolDefinitions,
    appendAssistantToolCalls: appendAssistantToolCalls,
    appendToolResult: appendToolResult
  }
}()

export const build = messagesApi.build
export const buildBase = messagesApi.buildBase
export const toolDefinitions = messagesApi.toolDefinitions
export const appendAssistantToolCalls = messagesApi.appendAssistantToolCalls
export const appendToolResult = messagesApi.appendToolResult
