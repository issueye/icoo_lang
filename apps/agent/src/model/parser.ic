import std.core.object as object

class ModelParser {
  appendDeltaToolCalls(toolCalls, rawToolCalls) {
    if typeOf(rawToolCalls) != "array" {
      return toolCalls
    }

    for i, rawCall in rawToolCalls {
      if typeOf(rawCall) != "object" {
        continue
      }

      let callId = object.get(rawCall, "id", "")
      let callIndex = object.get(rawCall, "index", -1)
      let matched = false
      let nextCalls = []
      for j, existing in toolCalls {
        let existingId = object.get(existing, "id", "")
        let existingIndex = object.get(existing, "streamIndex", -1)
        let sameCall = false
        if callId != "" && existingId == callId {
          sameCall = true
        }
        if callId == "" && callIndex >= 0 && existingIndex == callIndex {
          sameCall = true
        }

        if sameCall != true {
          nextCalls = nextCalls.append(existing)
          continue
        }

        let existingFn = object.get(existing, "function", {})
        let deltaFn = object.get(rawCall, "function", {})
        nextCalls = nextCalls.append({
          id: callId,
          streamIndex: callIndex,
          type: object.get(rawCall, "type", object.get(existing, "type", "function")),
          function: {
            name: object.get(deltaFn, "name", object.get(existingFn, "name", "")),
            arguments:
              object.get(existingFn, "arguments", "") +
              object.get(deltaFn, "arguments", "")
          }
        })
        matched = true
      }

      if matched == true {
        toolCalls = nextCalls
        continue
      }

      let fnDef = object.get(rawCall, "function", {})
      toolCalls = toolCalls.append({
        id: callId,
        streamIndex: callIndex,
        type: object.get(rawCall, "type", "function"),
        function: {
          name: object.get(fnDef, "name", ""),
          arguments: object.get(fnDef, "arguments", "")
        }
      })
    }

    return toolCalls
  }

  normalizeContent(content) {
    if typeOf(content) == "string" {
      return content
    }
    if typeOf(content) == "array" {
      let text = ""
      for i, part in content {
        if typeOf(part) == "string" {
          text = text + part
          continue
        }
        if typeOf(part) != "object" {
          continue
        }
        if object.get(part, "type") == "text" {
          text = text + object.get(part, "text", "")
        }
      }
      return text
    }
    return ""
  }

  normalizeToolCalls(rawToolCalls) {
    if typeOf(rawToolCalls) != "array" {
      return []
    }

    let calls = []
    for i, rawCall in rawToolCalls {
      if typeOf(rawCall) != "object" {
        continue
      }
      let fnDef = object.get(rawCall, "function", {})
      calls = calls.append({
        id: object.get(rawCall, "id", ""),
        type: object.get(rawCall, "type", "function"),
        function: {
          name: object.get(fnDef, "name", ""),
          arguments: object.get(fnDef, "arguments", "")
        }
      })
    }
    return calls
  }

  parseChoiceMessage(message) {
    let content = this.normalizeContent(object.get(message, "content"))
    let toolCalls = this.normalizeToolCalls(object.get(message, "tool_calls"))
    // 部分 provider 会返回 reasoning_content，并要求下一轮 assistant 消息原样回放。
    let reasoningContent = object.get(message, "reasoning_content")
    return {
      ok: true,
      text: content,
      reasoningContent: reasoningContent,
      finishReason: null,
      toolCalls: toolCalls,
      hasToolCalls: len(toolCalls) > 0
    }
  }

  parseResponse(payload) {
    let choices = object.get(payload, "choices")
    if typeOf(choices) == "array" && len(choices) > 0 {
      let first = choices[0]
      let message = object.get(first, "message")
      if typeOf(message) == "object" {
        let parsed = this.parseChoiceMessage(message)
        parsed.finishReason = object.get(first, "finish_reason")
        return parsed
      }
    }

    let outputText = object.get(payload, "output_text")
    if typeOf(outputText) == "string" {
      return {
        ok: true,
        text: outputText,
        reasoningContent: null,
        finishReason: null,
        toolCalls: [],
        hasToolCalls: false
      }
    }

    return {
      ok: false,
      text: null,
      reasoningContent: null,
      finishReason: null,
      toolCalls: [],
      hasToolCalls: false
    }
  }

  parseStreamEvent(payload, state) {
    let choices = object.get(payload, "choices")
    if typeOf(choices) != "array" || len(choices) == 0 {
      return state
    }

    let first = choices[0]
    let delta = object.get(first, "delta", {})
    let deltaContent = this.normalizeContent(object.get(delta, "content"))
    let deltaReasoning = this.normalizeContent(object.get(delta, "reasoning_content"))
    let rawToolCalls = object.get(delta, "tool_calls")
    let nextToolCalls = this.appendDeltaToolCalls(
      object.get(state, "toolCalls", []),
      rawToolCalls
    )

    return {
      text: object.get(state, "text", "") + deltaContent,
      reasoningContent: object.get(state, "reasoningContent", "") + deltaReasoning,
      toolCalls: nextToolCalls,
      finishReason: object.get(first, "finish_reason"),
      hasToolCalls: len(nextToolCalls) > 0,
      deltaText: deltaContent,
      sawToolCallDelta: typeOf(rawToolCalls) == "array" && len(rawToolCalls) > 0
    }
  }

}

let parserApi = ModelParser()

export const parseResponse = parserApi.parseResponse
export const parseStreamEvent = parserApi.parseStreamEvent
