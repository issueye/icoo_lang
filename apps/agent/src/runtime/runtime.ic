import std.io.console as io
import std.data.json as json
import "@/src/context/builder.ic" as contextBuilder
import "@/src/model/client.ic" as modelClient
import "@/src/model/messages.ic" as modelMessages
import "@/src/session/store.ic" as sessionStore
import "@/src/tools/executor.ic" as toolExecutor

const runtimeApi = fn() {
  fn printListPreview(label, items, limit) {
    if typeOf(items) != "array" || len(items) == 0 {
      io.println(label + ":", "[]")
      return
    }

    let preview = items.take(limit)
    io.println(label + ":", json.encode(preview))
  }

  fn appendToolResults(config, messages, toolCalls, toolRuns) {
    // tool_calls 必须顺序回放为 tool 消息，模型下一轮才能继续基于结果推理。
    for i, call in toolCalls {
      let executed = toolExecutor.runCall(config, call)
      toolRuns = toolRuns.append(executed)
      messages = modelMessages.appendToolResult(
        messages,
        executed.toolCallId,
        executed.name,
        executed.output
      )
    }

    return {
      messages: messages,
      toolRuns: toolRuns
    }
  }

  fn runToolLoop(config, context) {
    let messages = modelMessages.build(config, context)
    let requests = []
    let toolRuns = []
    let finalResult = null
    let stopReason = "max turns reached"
    let turn = 0

    // 多轮循环统一受 maxTurns 限制，避免模型持续请求工具导致无限运行。
    while turn < config.maxTurns {
      turn = turn + 1
      let response = modelClient.requestWithMessages(config, messages)
      requests = requests.append(response)
      finalResult = response

      if response.hasToolCalls != true {
        stopReason = "assistant response completed"
        break
      }

      messages = modelMessages.appendAssistantToolCalls(messages, response.toolCalls, response.text)
      let appended = appendToolResults(config, messages, response.toolCalls, toolRuns)
      messages = appended.messages
      toolRuns = appended.toolRuns
    }

    if len(requests) == 0 {
      return {
        first: null,
        final: {
          mode: "local",
          text: "No model request was executed.",
          toolCalls: [],
          hasToolCalls: false,
          finishReason: null
        },
        toolRuns: [],
        requests: [],
        turnsUsed: 0,
        stopReason: "no request"
      }
    }

    return {
      first: requests.first(),
      final: finalResult,
      toolRuns: toolRuns,
      requests: requests,
      turnsUsed: len(requests),
      stopReason: stopReason
    }
  }

  fn start(config) {
    // session 先于 runtime 其他组件建立，后续可以在这里追加 turn 持久化。
    let opened = sessionStore.open(config)
    let session = opened.session
    let context = contextBuilder.build(config)
    let modelContext = {
      workspace: context.workspace,
      summaryJson: json.encode(context.summary),
      files: context.files,
      omitted: context.omitted
    }
    let modelLoop = runToolLoop(config, modelContext)

    io.println("== icoo agent ==")
    io.println("workspace:", config.workspace)
    io.println("mode:", config.mode)
    io.println("model:", config.model)
    io.println("approval:", config.approval)
    io.println("session id:", session.sessionId)
    io.println("resume:", config.resumeSession)
    io.println("session dir:", config.sessionDir)
    io.println("session path:", opened.path)
    io.println("session resumed:", opened.resumed)
    io.println("log path:", config.logPath)
    io.println("max turns:", config.maxTurns)
    io.println("max files:", config.maxFiles)
    io.println("max total bytes:", config.maxTotalBytes)
    io.println("context summary:", json.encode(context.summary))
    printListPreview("context files", context.files, 3)
    printListPreview("context omitted", context.omitted, 3)
    io.println("")
    io.println("model mode:", modelLoop.final.mode)
    io.println("turns used:", modelLoop.turnsUsed)
    io.println("stop reason:", modelLoop.stopReason)
    io.println("tool calls:", len(modelLoop.toolRuns))
    if len(modelLoop.toolRuns) > 0 {
      printListPreview("tool run preview", modelLoop.toolRuns, 2)
    }
    io.println("model output:")
    io.println(modelLoop.final.text)

    return {
      ok: true,
      config: config,
      session: session,
      sessionPath: opened.path,
      context: context,
      model: modelLoop.final,
      toolRuns: modelLoop.toolRuns,
      firstModel: modelLoop.first,
      modelRequests: modelLoop.requests,
      turnsUsed: modelLoop.turnsUsed,
      stopReason: modelLoop.stopReason
    }
  }

  return {
    start: start
  }
}()

export const start = runtimeApi.start
