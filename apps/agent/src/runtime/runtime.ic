import std.io.console as io
import std.data.json as json
import "@/src/context/builder.ic" as contextBuilder
import "@/src/model/client.ic" as modelClient
import "@/src/model/messages.ic" as modelMessages
import "@/src/session/store.ic" as sessionStore
import "@/src/tools/executor.ic" as toolExecutor

// 运行时
export class Runtime {
  // 初始化运行时
  init() {
    this.ctxBuilder = contextBuilder.ContextBuilder()
    this.modelClient = modelClient.ModelClient()
    this.sessionStore = sessionStore.SessionStore()
    this.toolExecutor = toolExecutor.ToolExecutor()
  }

  // 打印列表预览
  printListPreview(label, items, limit) {
    if typeOf(items) != "array" || len(items) == 0 {
      io.println(label + ":", "[]")
      return
    }

    let preview = items.take(limit)
    io.println(label + ":", json.encode(preview))
  }

  // 追加工具调用结果
  appendToolResults(config, session, messages, toolCalls, toolRuns) {
    // tool_calls 必须顺序回放为 tool 消息，模型下一轮才能继续基于结果推理。
    for i, call in toolCalls {
      let executed = this.toolExecutor.runCall(config, call)
      toolRuns = toolRuns.append(executed)
      this.sessionStore.appendToolMessage(config, session, executed)
      messages = modelMessages.ModelMessages().appendToolResult(
        messages,
        executed.toolCallId,
        executed.name,
        executed.output
      )
    }

    return {
      messages: messages,
      toolRuns: toolRuns
    }
  }

  // 运行工具循环
  runToolLoop(config, session, context) {
    let userPrompt = modelMessages.ModelMessages().userPrompt(config, context)
    let builtContext = {
      userPrompt: userPrompt
    }
    let messages = this.sessionStore.buildMessages(config, builtContext, session)
    if len(session.turns) == 0 {
      let userMessage = {
        role: "user",
        content: userPrompt
      }
      this.sessionStore.appendUserMessage(config, session, userMessage)
      messages = this.sessionStore.buildMessages(config, builtContext, session)
    }

    let requests = []
    let toolRuns = []
    let finalResult = null
    let stopReason = "max turns reached"
    let turn = 0

    // 多轮循环统一受 maxTurns 限制，避免模型持续请求工具导致无限运行。
    while turn < config.maxTurns {
      turn = turn + 1
      this.sessionStore.appendRequestSnapshot(config, session, messages)
      let response = this.modelClient.requestWithMessages(config, messages)
      this.sessionStore.appendAssistantMessage(config, session, response)
      requests = requests.append(response)
      finalResult = response

      if response.hasToolCalls != true {
        stopReason = "assistant response completed"
        break
      }

      messages = modelMessages.ModelMessages().appendAssistantToolCalls(
        messages,
        response.toolCalls,
        response.text,
        response.reasoningContent
      )
      let appended = this.appendToolResults(config, session, messages, response.toolCalls, toolRuns)
      messages = appended.messages
      toolRuns = appended.toolRuns
    }

    if len(requests) == 0 {
      return {
        first: null,
        final: {
          mode: "local",
          text: "No model request was executed.",
          reasoningContent: null,
          toolCalls: [],
          hasToolCalls: false,
          finishReason: null
        },
        toolRuns: [],
        requests: [],
        turnsUsed: 0,
        stopReason: "no request"
      }
    }

    return {
      first: requests.first(),
      final: finalResult,
      toolRuns: toolRuns,
      requests: requests,
      turnsUsed: len(requests),
      stopReason: stopReason
    }
  }

  // 启动运行时
  start(config) {
    // session 先于 runtime 其他组件建立，后续会把 turn 持久化也挂在同一个 session 上。
    let opened = this.sessionStore.open(config)
    let session = opened.session
    let context = this.ctxBuilder.build(config)
    let modelContext = {
      workspace: context.workspace,
      summaryJson: json.encode(context.summary),
      files: context.files,
      omitted: context.omitted,
      cliUnknownArgs: config.cliUnknownArgs
    }
    let modelLoop = this.runToolLoop(config, session, modelContext)
    this.sessionStore.markCompleted(config, session, {
      turnsUsed: modelLoop.turnsUsed,
      stopReason: modelLoop.stopReason,
      mode: modelLoop.final.mode
    })

    io.println("== " + config.agentName + " ==")
    io.println("workspace:", config.workspace)
    io.println("mode:", config.mode)
    io.println("model:", config.model)
    io.println("approval:", config.approval)
    io.println("session id:", session.sessionId)
    io.println("resume:", config.resumeSession)
    io.println("session dir:", config.sessionDir)
    io.println("session path:", opened.path)
    io.println("session resumed:", opened.resumed)
    io.println("log path:", config.logPath)
    io.println("max turns:", config.maxTurns)
    io.println("max files:", config.maxFiles)
    io.println("max total bytes:", config.maxTotalBytes)
    // unknown args 会被 CLI 层完整保留，便于后续接子工具链或调试入口。
    this.printListPreview("cli unknown args", config.cliUnknownArgs, 6)
    io.println("context summary:", json.encode(context.summary))
    this.printListPreview("context files", context.files, 3)
    this.printListPreview("context omitted", context.omitted, 3)
    io.println("")
    io.println("model mode:", modelLoop.final.mode)
    io.println("turns used:", modelLoop.turnsUsed)
    io.println("stop reason:", modelLoop.stopReason)
    io.println("tool calls:", len(modelLoop.toolRuns))
    io.println("session stored turns:", len(session.turns))
    if len(modelLoop.toolRuns) > 0 {
      this.printListPreview("tool run preview", modelLoop.toolRuns, 2)
    }
    io.println("model output:")
    io.println(modelLoop.final.text)

    return {
      ok: true,
      config: config,
      session: session,
      sessionPath: opened.path,
      context: context,
      model: modelLoop.final,
      toolRuns: modelLoop.toolRuns,
      firstModel: modelLoop.first,
      modelRequests: modelLoop.requests,
      turnsUsed: modelLoop.turnsUsed,
      stopReason: modelLoop.stopReason
    }
  }
}
