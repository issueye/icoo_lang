import std.time.basic as time

const schemaApi = fn() {
  fn sessionSchemaVersion() {
    return 2
  }

  fn normalizeSessionId(config) {
    if config.resumeSession != null && config.resumeSession != "" {
      return config.resumeSession
    }
    if config.sessionId != null && config.sessionId != "" {
      return config.sessionId
    }
    return "s_" + time.format(time.now(), "YYYYMMDD-HHmmss", "UTC")
  }

  fn newSession(config, sessionId) {
    let now = time.now()

    // Session 作为顶层状态容器，后续所有 turn / event / artifact 都挂在这里。
    return {
      sessionSchemaVersion: sessionSchemaVersion(),
      sessionId: sessionId,
      workspace: config.workspace,
      mode: config.mode,
      status: "idle",
      createdAt: now,
      updatedAt: now,
      config: {
        model: config.model,
        baseUrl: config.baseUrl,
        approval: config.approval,
        maxTurns: config.maxTurns,
        maxFiles: config.maxFiles,
        maxTotalBytes: config.maxTotalBytes
      },
      turns: [],
      events: [],
      artifacts: [],
      budgets: {
        turnCount: 0,
        toolCallCount: 0
      },
      approvals: []
    }
  }

  fn newTurn(kind, payload) {
    let now = time.now()
    return {
      kind: kind,
      createdAt: now,
      payload: payload
    }
  }

  fn userMessage(message) {
    return newTurn("user_message", message)
  }

  fn requestSnapshot(messages) {
    return newTurn("request_snapshot", {
      messages: messages
    })
  }

  fn assistantMessage(response) {
    return newTurn("assistant_message", {
      role: "assistant",
      content: response.text,
      reasoningContent: response.reasoningContent,
      toolCalls: response.toolCalls,
      hasToolCalls: response.hasToolCalls,
      finishReason: response.finishReason,
      mode: response.mode
    })
  }

  fn toolMessage(executed) {
    return newTurn("tool_message", {
      role: "tool",
      toolCallId: executed.toolCallId,
      name: executed.name,
      output: executed.output,
      ok: executed.ok,
      error: executed.error
    })
  }

  fn runSummary(summary) {
    return newTurn("run_summary", summary)
  }

  return {
    sessionSchemaVersion: sessionSchemaVersion,
    normalizeSessionId: normalizeSessionId,
    newSession: newSession,
    newTurn: newTurn,
    userMessage: userMessage,
    requestSnapshot: requestSnapshot,
    assistantMessage: assistantMessage,
    toolMessage: toolMessage,
    runSummary: runSummary
  }
}()

export {
  sessionSchemaVersion: schemaApi.sessionSchemaVersion,
  normalizeSessionId: schemaApi.normalizeSessionId,
  newSession: schemaApi.newSession,
  newTurn: schemaApi.newTurn,
  userMessage: schemaApi.userMessage,
  requestSnapshot: schemaApi.requestSnapshot,
  assistantMessage: schemaApi.assistantMessage,
  toolMessage: schemaApi.toolMessage,
  runSummary: schemaApi.runSummary,
}
