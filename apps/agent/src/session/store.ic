import std.data.json as json
import std.io.fs as fs
import std.sys.os as os
import std.time.basic as time
import "@/src/session/schema.ic" as schema

// 会话数据库存储
export class SessionStore {
  init() {
    this.schema = schema.Schema()
  }

  // 验证会话 turn 类型是否符合 schema 定义
  validateTurnKinds(turns, filePath) {
    let allowed = {
      user_message: true,
      request_snapshot: true,
      assistant_message: true,
      tool_message: true,
      run_summary: true
    }
    let deprecated = {
      user_prompt: true,
      request_messages: true,
      assistant_response: true,
      tool_result: true
    }

    for i, turn in turns {
      let kind = turn.kind
      if deprecated[kind] == true {
        panic("deprecated session turn kind: " + kind + " in " + filePath)
      }
      if allowed[kind] != true {
        panic("unknown session turn kind in " + filePath)
      }
    }
  }

  // 会话文件路径
  sessionPath(config, sessionId) {
    return fs.join(config.sessionDir, sessionId + ".json")
  }

  // 保存会话
  save(config, session) {
    os.mkdirAll(config.sessionDir)
    session.updatedAt = time.now()
    let filePath = this.sessionPath(config, session.sessionId)
    json.saveToFile(filePath, session)
    return filePath
  }

  // 加载会话
  load(config, sessionId) {
    let filePath = this.sessionPath(config, sessionId)
    if fs.exists(filePath) != true {
      return null
    }

    let loaded = json.fromFile(filePath)
    if loaded == null || typeOf(loaded) != "object" {
      panic("invalid session file: " + filePath)
    }
    if loaded.sessionId == null || loaded.sessionId == "" {
      panic("invalid session schema: missing sessionId")
    }
    if loaded.sessionSchemaVersion != this.schema.sessionSchemaVersion() {
      panic("unsupported session schema version: " + loaded.sessionSchemaVersion)
    }
    if typeOf(loaded.turns) != "array" {
      loaded.turns = []
    }
    if typeOf(loaded.events) != "array" {
      loaded.events = []
    }
    if typeOf(loaded.artifacts) != "array" {
      loaded.artifacts = []
    }
    if typeOf(loaded.approvals) != "array" {
      loaded.approvals = []
    }
    if typeOf(loaded.budgets) != "object" {
      loaded.budgets = {
        turnCount: 0,
        toolCallCount: 0
      }
    }
    // 旧 session schema 不再兼容读取，避免在恢复链路里继续堆积隐式分支。
    this.validateTurnKinds(loaded.turns, filePath)

    return loaded
  }

  // 打开会话
  open(config) {
    let sessionId = this.schema.normalizeSessionId(config)
    let loaded = this.load(config, sessionId)
    if loaded != null {
      loaded.status = "running"
      let loadedPath = this.save(config, loaded)
      return {
        session: loaded,
        path: loadedPath,
        resumed: true
      }
    }

    let created = this.schema.newSession(config, sessionId)
    created.status = "running"
    let createdPath = this.save(config, created)
    return {
      session: created,
      path: createdPath,
      resumed: false
    }
  }

  // 追加会话 turn
  appendTurn(config, session, turn) {
    session.turns = session.turns.append(turn)
    session.budgets.turnCount = len(session.turns)
    if turn.kind == "tool_message" {
      session.budgets.toolCallCount = session.budgets.toolCallCount + 1
    }
    this.save(config, session)
    return turn
  }

  // 追加用户消息 turn
  appendUserMessage(config, session, message) {
    return this.appendTurn(config, session, this.schema.userMessage(message))
  }

  // 追加请求快照 turn
  appendRequestSnapshot(config, session, messages) {
    return this.appendTurn(config, session, this.schema.requestSnapshot(messages))
  }

  // 追加助手消息 turn
  appendAssistantMessage(config, session, response) {
    return this.appendTurn(config, session, this.schema.assistantMessage(response))
  }

  // 追加工具消息 turn
  appendToolMessage(config, session, executed) {
    return this.appendTurn(config, session, this.schema.toolMessage(executed))
  }

  // 标记会话为已完成
  markCompleted(config, session, summary) {
    session.status = "completed"
    if summary != null {
      session.lastResult = summary
      this.appendTurn(config, session, this.schema.runSummary(summary))
    }
    return this.save(config, session)
  }

  // 构建会话消息列表
  buildMessages(config, context, session) {
    let messages = [
      {
        role: "system",
        content: "You are an Icoo agent. Be concise, repository-aware, and action-oriented. Use tools when repository inspection is required before answering."
      }
    ]

    let hasUserTurn = false
    for i, turn in session.turns {
      let payload = turn.payload
      if turn.kind == "user_message" {
        hasUserTurn = true
        messages = messages.append(payload)
        continue
      }
      if turn.kind == "request_snapshot" {
        continue
      }
      if turn.kind == "assistant_message" {
        let assistantMessage = {
          role: "assistant",
          content: payload.content
        }
        if payload.reasoningContent != null && payload.reasoningContent != "" {
          assistantMessage.reasoning_content = payload.reasoningContent
        }
        if payload.hasToolCalls == true {
          assistantMessage.tool_calls = payload.toolCalls
        }
        messages = messages.append(assistantMessage)
        continue
      }
      if turn.kind == "tool_message" {
        messages = messages.append({
          role: "tool",
          tool_call_id: payload.toolCallId,
          name: payload.name,
          content: json.encode(payload.output)
        })
        continue
      }
    }

    if hasUserTurn != true {
      messages = messages.append({
        role: "user",
        content: context.userPrompt
      })
    }

    return messages
  }

}
