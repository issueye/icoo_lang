import std.io.fs as fs
import std.core.object as object
import "@/src/tools/tool_path.ic" as toolPath

export class ListDir {
  // run 列出工作区目录内容。
  run(config, input) {
    let path = object.get(input, "path")
    if path == null || path == "" {
      return {
        ok: false,
        error: "listDir requires non-empty path"
      }
    }

    path = toolPath.ToolPath().resolve(config, path)
    if fs.exists(path) != true {
      return {
        ok: false,
        error: "directory not found: " + path
      }
    }
    let info = fs.stat(path)
    if info.isDir != true {
      return {
        ok: false,
        error: "path is not a directory: " + path
      }
    }

    let entries = fs.readDir(path).map(fn(entry) {
      return {
        name: entry.name,
        path: entry.path,
        isDir: entry.isDir
      }
    })

    return {
      ok: true,
      content: entries,
      meta: {
        path: path,
        count: len(entries)
      }
    }
  }
}
