import std.io.fs as fs
import std.core.object as object
import "@/src/tools/tool_path.ic" as toolPath

export class ReadFile {
  // run 读取工作区中的文本文件。
  run(config, input) {
    let path = object.get(input, "path")
    if path == null || path == "" {
      return {
        ok: false,
        error: "readFile requires non-empty path"
      }
    }

    path = toolPath.ToolPath().resolve(config, path)
    if fs.exists(path) != true {
      return {
        ok: false,
        error: "file not found: " + path
      }
    }
    let info = fs.stat(path)
    if info.isFile != true {
      return {
        ok: false,
        error: "path is not a file: " + path
      }
    }

    return {
      ok: true,
      content: fs.readFile(path),
      meta: {
        path: path
      }
    }
  }
}
