import std.io.fs as fs
import std.core.object as object
import "@/src/tools/tool_path.ic" as toolPath

// ReadFile 是一个读取文件内容的类。
class ReadFile {
  // run 读取文件内容。
  // 如果文件不存在，则返回错误。
  run(config, input) {
    let path = object.get(input, "path")
    if path == null || path == "" {
      return {
        ok: false,
        error: "readFile requires non-empty path"
      }
    }
    path = toolPath.resolve(config, path)
    if fs.exists(path) != true {
      return {
        ok: false,
        error: "file not found: " + path
      }
    }

    return {
      ok: true,
      content: fs.readFile(path),
      meta: {
        path: path
      }
    }
  }
}

export ReadFile()
