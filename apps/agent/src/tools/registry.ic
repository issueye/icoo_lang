import std.core.object as object
import "@/src/tools/exec_command.ic" as execCommand
import "@/src/tools/read_file.ic" as readFile
import "@/src/tools/list_dir.ic" as listDir
import "@/src/tools/search_text.ic" as searchText
import "@/src/tools/web_fetch.ic" as webFetch
import "@/src/tools/web_search.ic" as webSearch
import "@/src/tools/tool_path.ic" as toolPath
import "@/src/tools/web_common.ic" as webCommon
import "@/src/context/ignore.ic" as ignore

// ToolRegistry 是一个工具注册器。
export class ToolRegistry {
  init() {
    // 初始化执行命令工具。
    this.execCommand = execCommand.ExecCommand(this.toolsPath)

    // 初始化工具路径。
    this.toolsPath = toolPath.ToolPath()
    this.ignore = ignore.Ignore()
    this.readFile = readFile.ReadFile(this.toolsPath)
    this.listDir = listDir.ListDir(this.toolsPath)
    this.searchText = searchText.SearchText(this.toolsPath, this.ignore)
    
    // 初始化网络工具。
    this.webCommon = webCommon.WebCommon(this.toolsPath)
    this.webFetch = webFetch.WebFetch(this.webCommon)
    this.webSearch = webSearch.WebSearch(this.webCommon)
  }

  build() {
    // registry 统一维护本地 handler 与暴露给 LLM 的 function schema。
    return {
      readFile: {
        name: "readFile",
        description: "Read a UTF-8 text file from the local workspace.",
        parameters: {
          type: "object",
          properties: {
            path: {
              type: "string",
              description: "Workspace-relative path. Use @/ as the workspace root prefix."
            }
          },
          required: ["path"]
        },
        handler: this.readFile.run
      },
      listDir: {
        name: "listDir",
        description: "List files and directories under a workspace path.",
        parameters: {
          type: "object",
          properties: {
            path: {
              type: "string",
              description: "Workspace-relative directory path. Use @/ as the workspace root prefix."
            }
          },
          required: ["path"]
        },
        handler: this.listDir.run
      },
      searchText: {
        name: "searchText",
        description: "Search plain text files under a workspace path for a query string.",
        parameters: {
          type: "object",
          properties: {
            path: {
              type: "string",
              description: "Workspace-relative search root. Use @/ as the workspace root prefix."
            },
            query: {
              type: "string",
              description: "The literal string to search for."
            }
          },
          required: ["path", "query"]
        },
        handler: this.searchText.run
      },
      execCommand: {
        name: "execCommand",
        description: "Execute a local command inside the workspace and return stdout/stderr.",
        parameters: {
          type: "object",
          properties: {
            command: {
              type: "string",
              description: "Executable or shell command text."
            },
            args: {
              type: "array",
              description: "Optional argv list. Do not pass this when shell=true.",
              items: {
                type: "string"
              }
            },
            cwd: {
              type: "string",
              description: "Optional working directory. Supports @/ as the workspace root prefix."
            },
            shell: {
              type: "boolean",
              description: "Run command through the system shell. When true, omit args."
            },
            env: {
              type: "object",
              description: "Optional environment variable overrides merged on top of the current host environment.",
              additionalProperties: {
                type: "string"
              }
            }
          },
          required: ["command"]
        },
        handler: this.execCommand.run
      },
      webFetch: {
        name: "webFetch",
        description: "Fetch a web page URL and return cleaned text content.",
        parameters: {
          type: "object",
          properties: {
            url: {
              type: "string",
              description: "Absolute HTTP or HTTPS URL to fetch."
            },
            maxChars: {
              type: "integer",
              description: "Optional maximum number of characters to keep from the cleaned page text."
            }
          },
          required: ["url"]
        },
        handler: this.webFetch.run
      },
      webSearch: {
        name: "webSearch",
        description: "Search the web with DuckDuckGo and return a short result list.",
        parameters: {
          type: "object",
          properties: {
            query: {
              type: "string",
              description: "Search query text."
            },
            maxResults: {
              type: "integer",
              description: "Optional maximum number of results to return."
            }
          },
          required: ["query"]
        },
        handler: this.webSearch.run
      }
    }
  }

  get(name) {
    let tools = this.build()
    return object.get(tools, name)
  }

  definitions() {
    let tools = this.build()
    let names = ["readFile", "listDir", "searchText", "execCommand", "webFetch", "webSearch"]
    let definitions = []
    for i, name in names {
      let tool = object.get(tools, name)
      definitions = definitions.append({
        type: "function",
        function: {
          name: tool.name,
          description: tool.description,
          parameters: tool.parameters
        }
      })
    }
    return definitions
  }
}
