import std.io.fs as fs
import std.core.object as object
import std.core.string as str
import "@/src/context/ignore.ic" as ignore
import "@/src/tools/tool_path.ic" as toolPath

// SearchText 是一个搜索文本的类。
class SearchText {
  // run 搜索文本。
  // 如果目录不存在，则返回错误。
  run(config, input) {
      str.hasSuffix(path, ".txt") ||
      str.hasSuffix(path, ".json") ||
      str.hasSuffix(path, ".toml") ||
      str.hasSuffix(path, ".yaml") ||
      str.hasSuffix(path, ".yml") ||
      str.hasSuffix(path, ".go") ||
      str.hasSuffix(path, ".js") ||
      str.hasSuffix(path, ".ts")
  }

  // scan 搜索目录下的所有文件。
  // 如果文件包含查询字符串，则将其路径添加到匹配列表中。
  scan(path, needle, matches) {
    let info = fs.stat(path)
    if info.isFile {
      if isSearchable(path) != true {
        return matches
      }
      let text = fs.readFile(path)
      if str.contains(text, needle) == true {
        return matches.append({
          path: path
        })
      }
      return matches
    }

    let entries = fs.readDir(path)
    for i, entry in entries {
      if ignore.shouldIgnoreName(entry.name) == true {
        continue
      }
      matches = scan(entry.path, needle, matches)
    }
    return matches
  }

  // run 搜索文本。
  // 如果目录不存在，则返回错误。
  run(config, input) {
    let path = object.get(input, "path")
    let query = object.get(input, "query")
    if path == null || path == "" {
      return {
        ok: false,
        error: "searchText requires non-empty path"
      }
    }
    if query == null || query == "" {
      return {
        ok: false,
        error: "searchText requires non-empty query"
      }
    }
    path = toolPath.resolve(config, path)
    if fs.exists(path) != true {
      return {
        ok: false,
        error: "search root not found: " + path
      }
    }

    let matches = scan(path, query, [])
    return {
      ok: true,
      content: matches,
      meta: {
        path: path,
        query: query,
        count: len(matches)
      }
    }
  }
}

export SearchText()