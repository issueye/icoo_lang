import std.io.fs as fs
import std.core.string as str

// ToolPath 是一个解析工具路径的类。
export class ToolPath {
  // resolve 解析工具路径。
  // 如果路径以"@/"开头，则将其解析为工作空间路径的子路径。
  // 否则，返回路径本身。
  resolve(config, path) {
    if path == null || path == "" {
      return path
    }
    // 如果路径以"@/"开头，则将其解析为工作空间路径的子路径
    if str.hasPrefix(path, "@/") {
      let suffix = str.replace(path, "@/", "", 1)
      return fs.join(config.workspace, suffix)
    }
    return path
  }
}

