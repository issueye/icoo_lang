import std.core.object as object
import std.core.string as str
import std.data.json as json
import std.io.fs as fs
import std.ui.tui as tui

export class AgentTUI {
  init(config, runtimeApp) {
    this.baseConfig = config
    this.runtime = runtimeApp
  }

  initialTask() {
    if this.baseConfig.task != null && this.baseConfig.task != "" {
      return this.baseConfig.task
    }
    return ""
  }

  sessionFilePath(entry) {
    return fs.join(this.baseConfig.sessionDir, entry.name)
  }

  sessionTitle(session) {
    if session == null {
      return "Untitled"
    }
    if session.sessionId != null && session.sessionId != "" {
      return session.sessionId
    }
    return "Untitled"
  }

  buildTurnLine(turn) {
    if turn.kind == "user_message" {
      return "You\n" + turn.payload.content
    }
    if turn.kind == "assistant_message" {
      let content = turn.payload.content
      if content == null || content == "" {
        content = "(no text)"
      }
      return "Agent\n" + content
    }
    if turn.kind == "tool_message" {
      let state = "ok"
      if turn.payload.ok != true {
        state = "error"
      }
      return "Tool · " + turn.payload.name + " · " + state
    }
    return null
  }

  buildConversation(session) {
    if session == null || typeOf(session.turns) != "array" || len(session.turns) == 0 {
      return "No conversation yet."
    }

    let parts = []
    for i, turn in session.turns {
      let line = this.buildTurnLine(turn)
      if line != null {
        parts = parts.append(line)
      }
    }
    if len(parts) == 0 {
      return "No conversation yet."
    }
    return str.join(parts, "\n\n")
  }

  turnCount(session) {
    if session != null && session.budgets != null && session.budgets.turnCount != null {
      return session.budgets.turnCount
    }
    if session != null && typeOf(session.turns) == "array" {
      return len(session.turns)
    }
    return 0
  }

  toolCallCount(session) {
    if session != null && session.budgets != null && session.budgets.toolCallCount != null {
      return session.budgets.toolCallCount
    }
    return 0
  }

  sessionUpdatedAt(session) {
    if session != null && session.updatedAt != null {
      return session.updatedAt
    }
    return 0
  }

  firstLine(text) {
    if text == null || text == "" {
      return ""
    }
    let lines = str.lines(text)
    if len(lines) == 0 {
      return ""
    }
    return str.trimSpace(lines[0])
  }

  sessionPreview(session) {
    if session == null || typeOf(session.turns) != "array" || len(session.turns) == 0 {
      return "No messages yet"
    }

    let index = len(session.turns) - 1
    while index >= 0 {
      let turn = session.turns[index]
      index = index - 1
      if turn.kind == "assistant_message" {
        let content = this.firstLine(turn.payload.content)
        if content != "" {
          return "Agent: " + content
        }
      }
      if turn.kind == "user_message" {
        let content = this.firstLine(turn.payload.content)
        if content != "" {
          return "You: " + content
        }
      }
      if turn.kind == "tool_message" {
        return "Tool: " + turn.payload.name
      }
    }

    return "No messages yet"
  }

  sortSessionsByRecent(sessions) {
    let sorted = []
    for i, item in sessions {
      let inserted = false
      let itemUpdatedAt = this.sessionUpdatedAt(item.session)
      let next = []
      for j, existing in sorted {
        if inserted != true && itemUpdatedAt > this.sessionUpdatedAt(existing.session) {
          next = next.append(item)
          inserted = true
        }
        next = next.append(existing)
      }
      if inserted != true {
        next = next.append(item)
      }
      sorted = next
    }
    return sorted
  }

  summarizeSession(session, path) {
    let title = this.sessionTitle(session)
    let subtitle = "idle"
    if session.status != null && session.status != "" {
      subtitle = session.status
    }
    let toolCalls = this.toolCallCount(session)
    let turns = this.turnCount(session)
    return {
      id: title,
      title: title,
      subtitle: subtitle + " · " + this.toText(turns) + " turns · " + this.toText(toolCalls) + " tools",
      preview: this.sessionPreview(session),
      updatedAt: this.sessionUpdatedAt(session),
      path: path,
      session: session,
      conversation: this.buildConversation(session)
    }
  }

  loadSessions() {
    if fs.exists(this.baseConfig.sessionDir) != true {
      return []
    }

    let entries = fs.readDir(this.baseConfig.sessionDir)
    let sessions = []
    let index = len(entries) - 1
    while index >= 0 {
      let entry = entries[index]
      index = index - 1
      if entry.isDir == true || str.hasSuffix(entry.name, ".json") != true {
        continue
      }
      let path = this.sessionFilePath(entry)
      let loaded = json.fromFile(path)
      if loaded == null || typeOf(loaded) != "object" {
        continue
      }
      sessions = sessions.append(this.summarizeSession(loaded, path))
    }
    return this.sortSessionsByRecent(sessions)
  }

  sessionListFromSessions(sessions, selected) {
    let items = []
    for i, sessionItem in sessions {
      items = items.append(sessionItem.title + "\n" + sessionItem.preview + "\n" + sessionItem.subtitle)
    }
    return tui.listState({
      items: items,
      selected: selected
    })
  }

  selectedSession(sessions, sessionList) {
    if typeOf(sessions) != "array" || len(sessions) == 0 {
      return null
    }
    let index = sessionList.selected
    if index < 0 || index >= len(sessions) {
      return sessions[0]
    }
    return sessions[index]
  }

  sidebarStatus(model) {
    let text = "Sessions " + this.toText(len(model.sessions))
    if model.focus == "sessions" {
      text = text + " · focus"
    }
    return text
  }

  toText(value) {
    let kind = typeOf(value)
    if kind == "string" {
      return value
    }
    if kind == "null" {
      return ""
    }
    return json.encode(value)
  }

  conversationViewport(content) {
    return tui.viewportState({
      content: content,
      height: 20,
      offset: 999999
    })
  }

  inputContentHeight() {
    return 3
  }

  showSidebar(model) {
    return model.windowWidth >= 72
  }

  sidebarWidth(model) {
    if this.showSidebar(model) != true {
      return 0
    }
    let width = 28
    if model.windowWidth >= 140 {
      width = 32
    }
    if model.windowWidth <= 96 {
      width = 24
    }
    if model.windowWidth <= 72 {
      width = 20
    }
    return width
  }

  contentWidth(model) {
    let width = model.windowWidth - 2
    if this.showSidebar(model) == true {
      width = model.windowWidth - this.sidebarWidth(model) - 3
    }
    if width < 12 {
      return 12
    }
    return width
  }

  conversationHeight(model) {
    let height = model.windowHeight - 10
    if height < 8 {
      return 8
    }
    return height
  }

  syncConversationView(model, content) {
    model.currentConversation = content
    model.conversationView = tui.viewportState({
      content: content,
      height: this.conversationHeight(model),
      offset: 999999
    })
    return model
  }

  runTask(taskText) {
    let nextTask = str.trimSpace(taskText)
    if nextTask == "" {
      nextTask = this.initialTask()
    }

    let config = object.merge(this.baseConfig, {
      mode: "tui",
      task: nextTask,
      streamFinalAnswer: false
    })
    let result = this.runtime.execute(config)
    let sessions = this.loadSessions()
    let selected = 0
    let idx = 0
    while idx < len(sessions) {
      if sessions[idx].id == result.session.sessionId {
        selected = idx
        break
      }
      idx = idx + 1
    }

    return {
      kind: "run_complete",
      task: nextTask,
      result: result,
      sessions: sessions,
      selected: selected,
      conversation: this.buildConversation(result.session)
    }
  }

  initialModel() {
    let sessions = this.loadSessions()
    let selected = 0
    let selectedSession = null
    if len(sessions) > 0 {
      selectedSession = sessions[0]
    }

    return {
      focus: "input",
      running: false,
      windowWidth: 120,
      windowHeight: 36,
      sessions: sessions,
      sessionList: this.sessionListFromSessions(sessions, selected),
      currentConversation: selectedSession == null ? "No conversation yet." : selectedSession.conversation,
      conversationView: tui.viewportState({
        content: selectedSession == null ? "No conversation yet." : selectedSession.conversation,
        height: 26,
        offset: 999999
      }),
      prompt: tui.inputState({
        value: this.initialTask(),
        placeholder: "Message agent...",
        focused: true,
        multiLine: true
      })
    }
  }

  syncSessionSelection(model) {
    let selected = this.selectedSession(model.sessions, model.sessionList)
    if selected == null {
      return this.syncConversationView(model, "No conversation yet.")
    }

    return this.syncConversationView(model, selected.conversation)
  }

  composerTitle(model) {
    let title = "Model · " + this.baseConfig.model
    if model.running == true {
      title = title + " · running"
    }
    return title
  }

  app() {
    let current = this
    return tui.app({
      altScreen: true,
      init: fn() {
        return current.initialModel()
      },
      update: fn(model, msg) {
        if msg.kind == "key" && msg.key == "ctrl+c" {
          return {
            model: model,
            quit: true
          }
        }

        if msg.kind == "key" && msg.key == "tab" {
          if model.focus == "input" {
            model.focus = "sessions"
            model.prompt.focused = false
          } else {
            model.focus = "input"
            model.prompt.focused = true
          }
          return {
            model: model
          }
        }

        if msg.kind == "window" {
          if msg.width <= 0 || msg.height <= 0 {
            return {
              model: model
            }
          }
          model.windowWidth = msg.width
          model.windowHeight = msg.height
          model = current.syncConversationView(model, model.currentConversation)
          return {
            model: model
          }
        }

        model.conversationView = tui.viewportUpdate(model.conversationView, msg)

        if model.focus == "sessions" {
          model.sessionList = tui.listUpdate(model.sessionList, msg)
          model = current.syncSessionSelection(model)
          return {
            model: model
          }
        }

        if model.running != true {
          model.prompt.focused = true
          model.prompt = tui.inputUpdate(model.prompt, msg)
        }

        if model.running != true && model.prompt.submitted == true {
          let taskText = model.prompt.value
          model.running = true
          model.prompt = tui.inputState({
            value: taskText,
            placeholder: "Message agent...",
            focused: true,
            multiLine: true
          })
          model = current.syncConversationView(model, model.currentConversation + "\n\nYou\n" + taskText)
          return {
            model: model,
            command: tui.task(fn() {
              return current.runTask(taskText)
            })
          }
        }

        if msg.kind == "run_complete" {
          model.running = false
          model.sessions = msg.sessions
          model.sessionList = current.sessionListFromSessions(msg.sessions, msg.selected)
          model = current.syncConversationView(model, msg.conversation)
          model.prompt = tui.inputState({
            value: "",
            placeholder: "Message agent...",
            focused: true,
            multiLine: true
          })
          return {
            model: model
          }
        }

        if msg.kind == "task_error" {
          model.running = false
          model = current.syncConversationView(model, model.currentConversation + "\n\nSystem\n" + msg.error)
        }

        return {
          model: model
        }
      },
  view: fn(model) {
        let children = []
        if current.showSidebar(model) == true {
          children = children.append(
            tui.box({
              title: current.sidebarStatus(model),
              border: "rounded",
              padding: [0, 1],
              width: current.sidebarWidth(model),
              child: tui.list({
                state: model.sessionList
              })
            })
          )
        }
        children = children.append(
          tui.vstack({
            gap: 1,
            children: [
              tui.box({
                title: "Conversation",
                border: "rounded",
                padding: [0, 1],
                width: current.contentWidth(model),
                child: tui.viewport({
                  state: model.conversationView
                })
              }),
              tui.box({
                title: current.composerTitle(model),
                border: "rounded",
                padding: [0, 1],
                width: current.contentWidth(model),
                child: tui.input({
                  state: model.prompt,
                  height: current.inputContentHeight()
                })
              })
            ]
          })
        )
        return tui.hstack({
          gap: 1,
          children: children
        })
      }
    })
  }

  start() {
    return tui.run(this.app())
  }
}
