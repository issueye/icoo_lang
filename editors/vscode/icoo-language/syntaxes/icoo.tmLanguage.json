{
  "name": "Icoo",
  "scopeName": "source.icoo",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#decorators" },
    { "include": "#declarations" },
    { "include": "#keywords" },
    { "include": "#builtins" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.icoo",
          "begin": "//",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.icoo" }
          },
          "end": "$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.icoo",
          "begin": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.icoo" }
          },
          "end": "\"",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.icoo" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.icoo",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.icoo",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "decorators": {
      "patterns": [
        {
          "name": "meta.annotation.icoo",
          "match": "@[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.function.icoo",
          "match": "\\b(fn)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.function.icoo" },
            "2": { "name": "entity.name.function.icoo" }
          }
        },
        {
          "name": "meta.class.icoo",
          "match": "\\b(class|interface|type)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.icoo" },
            "2": { "name": "entity.name.type.icoo" }
          }
        },
        {
          "name": "entity.name.function.method.icoo",
          "match": "(?m)^\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.icoo",
          "match": "\\b(if|else|for|while|match|break|continue|return|try|catch|finally|throw|go|select|recv|send|in|as)\\b"
        },
        {
          "name": "storage.modifier.icoo",
          "match": "\\b(import|export|let|const)\\b"
        },
        {
          "name": "constant.language.icoo",
          "match": "\\b(true|false|null|this|super)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.icoo",
          "match": "\\b(print|println|len|typeOf|chan|error|satisfies)\\b"
        },
        {
          "name": "support.constant.stdlib.icoo",
          "match": "\\bstd(?:\\.[A-Za-z_][A-Za-z0-9_]*)+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.icoo",
          "match": "==|!=|<=|>=|&&|\\|\\||=>|\\+=|-=|\\*=|/=|[=+\\-*/%<>?:.@]"
        }
      ]
    }
  }
}
