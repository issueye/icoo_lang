import std.io as io

let age = 18
let label = age >= 18 ? "adult" : "minor"
let sum = 0
let i = 0

for i < 8 {
  i = i + 1

  if i == 2 {
    continue
  }

  if i == 7 {
    break
  }

  sum = sum + i
}

let inRange = sum > 10 && sum < 30
let fallback = "" || "default text"

io.println("== control flow ==")
io.println("label:", label)
io.println("sum:", sum)
io.println("inRange:", inRange)
io.println("fallback:", fallback)
