import std.io.console as io
import "@/src/models/config_model.ic" as config
import "@/src/services/agent_service.ic" as agent

const runtimeApi = fn() {
  fn runImpl(overrides) {
    let cfg = config.loadConfig(overrides)
    return agent.run(cfg)
  }

  fn mainImpl() {
    return runImpl(null)
  }

  return {
    run: runImpl,
    main: mainImpl
  }
}()

export const run = runtimeApi.run
export const main = runtimeApi.main
