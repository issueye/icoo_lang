import std.io.fs as fs
import std.sys.os as os
import std.core.object as object
import std.math.basic as math
import std.data.json as json

const configApi = fn() {
  fn parseConfigInt(value, fallback) {
    try {
      return math.parseInt(value)
    } catch err {
      return fallback
    }
  }

  fn defaultConfig() {
    let stateDir = fs.join(os.cwd(), ".icooa")
    return {
      workspace: os.cwd(),
      task: "Summarize the workspace, identify the most important files, and propose the next coding steps.",
      command: null,
      model: "gpt-4.1-mini",
      baseUrl: "https://api.openai.com/v1",
      apiKey: null,
      maxEntries: 24,
      maxDepth: 2,
      maxFileBytes: 4096,
      includeHidden: false,
      sessionDir: fs.join(stateDir, "sessions"),
      logPath: fs.join(stateDir, "icooa.log")
    }
  }

  fn applyEnv(config) {
    let workspace = os.getEnv("ICOOA_WORKSPACE")
    if workspace != null {
      config.workspace = workspace
    }

    let task = os.getEnv("ICOOA_TASK")
    if task != null {
      config.task = task
    }

    let command = os.getEnv("ICOOA_COMMAND")
    if command != null {
      config.command = command
    }

    let model = os.getEnv("ICOOA_MODEL")
    if model != null {
      config.model = model
    }

    let baseUrl = os.getEnv("ICOOA_BASE_URL")
    if baseUrl != null {
      config.baseUrl = baseUrl
    }

    let apiKey = os.getEnv("OPENAI_API_KEY")
    if apiKey == null {
      apiKey = os.getEnv("ICOOA_API_KEY")
    }
    if apiKey != null {
      config.apiKey = apiKey
    }

    let sessionDir = os.getEnv("ICOOA_SESSION_DIR")
    if sessionDir != null {
      config.sessionDir = sessionDir
    }

    let logPath = os.getEnv("ICOOA_LOG_PATH")
    if logPath != null {
      config.logPath = logPath
    }

    let includeHidden = os.getEnv("ICOOA_INCLUDE_HIDDEN")
    if includeHidden == "1" || includeHidden == "true" {
      config.includeHidden = true
    }
    if includeHidden == "0" || includeHidden == "false" {
      config.includeHidden = false
    }

    let maxEntries = os.getEnv("ICOOA_MAX_ENTRIES")
    if maxEntries != null {
      config.maxEntries = parseConfigInt(maxEntries, config.maxEntries)
    }

    let maxDepth = os.getEnv("ICOOA_MAX_DEPTH")
    if maxDepth != null {
      config.maxDepth = parseConfigInt(maxDepth, config.maxDepth)
    }

    let maxFileBytes = os.getEnv("ICOOA_MAX_FILE_BYTES")
    if maxFileBytes != null {
      config.maxFileBytes = parseConfigInt(maxFileBytes, config.maxFileBytes)
    }

    return config
  }

  fn loadConfigImpl(overrides) {
    let config = defaultConfig()

    let configPath = os.getEnv("ICOOA_CONFIG")
    if configPath != null && fs.exists(configPath) {
      config = object.merge(config, json.fromFile(configPath))
    }

    config = applyEnv(config)

    if overrides != null {
      config = object.merge(config, overrides)
    }

    return config
  }

  return {
    defaultConfig: defaultConfig,
    loadConfig: loadConfigImpl
  }
}()

export const defaultConfig = configApi.defaultConfig
export const loadConfig = configApi.loadConfig
