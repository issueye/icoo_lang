import std.express as express
import std.math as math
import std.object as object
import "./catalog.ic" as catalog
import "./history.ic" as history
import "./services/catalog_service.ic" as catalogService
import "./state.ic" as runtimeState

const adminApi = fn() {
  fn queryText(req, name) {
    let value = object.get(req.query, name)
    if typeOf(value) == "array" {
      if len(value) == 0 {
        return null
      }
      return value[0]
    }
    return value
  }

  fn queryInt(req, name, fallback) {
    let value = queryText(req, name)
    if value == null || value == "" {
      return fallback
    }
    try {
      return math.parseInt(value)
    } catch err {
      return fallback
    }
  }

  fn queryBool(req, name, fallback) {
    let value = queryText(req, name)
    if value == null || value == "" {
      return fallback
    }
    return value == "1" || value == "true"
  }

  fn bodyPayload(req) {
    return object.get(req, "json", {})
  }

  fn payloadOrQueryText(req, name) {
    let payloadValue = object.get(bodyPayload(req), name)
    if payloadValue != null && payloadValue != "" {
      return payloadValue
    }
    return queryText(req, name)
  }

  fn respondJSON(value) {
    if object.get(value, "status") != null || object.get(value, "json") != null || object.get(value, "body") != null {
      return value
    }
    return express.json(value)
  }

  fn badRequest(message) {
    return {
      status: 400,
      json: {
        ok: false,
        error: "bad_request",
        message: message
      }
    }
  }

  fn deleteMissing() {
    return badRequest("delete requires id or resource identity")
  }

  fn historyFilters(req, state) {
    let limit = queryInt(req, "limit", state.config.historyLimit)
    if limit <= 0 {
      limit = state.config.historyLimit
    }
    if limit > 200 {
      limit = 200
    }

    let page = queryInt(req, "page", 1)
    if page <= 0 {
      page = 1
    }

    return {
      request_id: queryText(req, "request_id"),
      route_name: queryText(req, "route_name"),
      method: queryText(req, "method"),
      path: queryText(req, "path"),
      downstream_protocol: queryText(req, "downstream_protocol"),
      upstream_protocol: queryText(req, "upstream_protocol"),
      status: queryInt(req, "status", null),
      limit: limit,
      offset: (page - 1) * limit
    }
  }

  fn trafficSnapshot(req, state) {
    let filters = historyFilters(req, state)
    let snapshot = {
      ok: true,
      total: history.count(state.history, filters),
      items: history.list(state.history, filters),
      page: queryInt(req, "page", 1),
      limit: filters.limit,
      filters: {
        request_id: filters.request_id,
        route_name: filters.route_name,
        method: filters.method,
        path: filters.path,
        downstream_protocol: filters.downstream_protocol,
        upstream_protocol: filters.upstream_protocol,
        status: filters.status
      },
      counters: state.monitor.counters(),
      latency: state.monitor.latency(),
      stats: history.trafficStats(state.history, filters),
      eventCount: state.monitor.eventCount(),
      recentEvents: state.monitor.recentEvents(),
      store: history.snapshot(state.history),
      protocols: {
        downstream: ["openai", "anthropic", "openai-responses"],
        upstream: ["openai", "anthropic", "openai-responses"]
      }
    }

    if filters.request_id != null && filters.request_id != "" {
      snapshot.mirror = history.mirror(state.history, filters.request_id)
    }

    return snapshot
  }

  fn trafficMirrorPayload(req, state) {
    let requestID = queryText(req, "request_id")
    if requestID == null || requestID == "" {
      return badRequest("request_id is required")
    }

    return {
      ok: true,
      request_id: requestID,
      mirror: history.mirror(state.history, requestID)
    }
  }

  fn trafficEventsPayload(state) {
    return {
      ok: true,
      eventCount: state.monitor.eventCount(),
      items: state.monitor.recentEvents()
    }
  }

  fn controlOverview(state) {
    let snapshot = catalogService.snapshot(state.catalogService)
    return {
      ok: true,
      service: state.monitor.name,
      ready: state.monitor.ready(),
      requestCount: state.monitor.requestCount(),
      runtime: runtimeState.runtimeSnapshot(state),
      history: history.snapshot(state.history),
      catalog: snapshot.store,
      defaultSupplier: snapshot.defaultSupplier,
      counters: state.monitor.counters()
    }
  }

  fn controlState(state) {
    return {
      ok: true,
      config: {
        listenAddr: state.config.listenAddr,
        upstreamBaseUrl: state.config.upstreamBaseUrl,
        timeoutMs: state.config.timeoutMs,
        recentLimit: state.config.recentLimit,
        eventLimit: state.config.eventLimit,
        allowUnauthenticatedLocal: state.config.allowUnauthenticatedLocal,
        apiKeyCount: len(catalogService.listAuthKeyValues(state.catalogService)),
        catalogPath: state.config.catalogPath,
        historyPath: state.config.historyPath
      },
      catalog: catalogService.snapshot(state.catalogService),
      history: history.snapshot(state.history),
      monitor: state.monitor.snapshot(),
      runtime: runtimeState.runtimeSnapshot(state)
    }
  }

  fn supplierHealthCheckPayload(req, state) {
    let supplierName = payloadOrQueryText(req, "name")
    let result = runtimeState.checkSuppliers(state, supplierName)
    if result.ok != true && object.get(result, "error") == "supplier_not_found" {
      return {
        status: 404,
        json: result
      }
    }
    return result
  }

  fn requireSupplierPayload(payload) {
    if object.get(payload, "id") != null {
      return null
    }
    if object.get(payload, "name") == null || object.get(payload, "name") == "" {
      return "supplier name is required"
    }
    if object.get(payload, "baseUrl") == null || object.get(payload, "baseUrl") == "" {
      return "supplier baseUrl is required"
    }
    return null
  }

  fn requireEndpointPayload(payload) {
    if object.get(payload, "id") != null {
      return null
    }
    if object.get(payload, "name") == null || object.get(payload, "name") == "" {
      return "endpoint name is required"
    }
    if object.get(payload, "endpoint") == null || object.get(payload, "endpoint") == "" {
      return "endpoint path is required"
    }
    if object.get(payload, "upstreamPath") == null || object.get(payload, "upstreamPath") == "" {
      return "upstreamPath is required"
    }
    if object.get(payload, "upstreamModel") == null || object.get(payload, "upstreamModel") == "" {
      return "upstreamModel is required"
    }
    if object.get(payload, "protocol") == null || object.get(payload, "protocol") == "" {
      return "protocol is required"
    }
    return null
  }

  fn requireAliasPayload(payload) {
    if object.get(payload, "id") != null {
      return null
    }
    if object.get(payload, "alias") == null || object.get(payload, "alias") == "" {
      return "alias is required"
    }
    return requireEndpointPayload(payload)
  }

  fn requireAuthKeyPayload(payload) {
    if object.get(payload, "id") != null {
      return null
    }
    if object.get(payload, "name") == null || object.get(payload, "name") == "" {
      return "auth key name is required"
    }
    if object.get(payload, "keyValue") == null || object.get(payload, "keyValue") == "" {
      return "auth key keyValue is required"
    }
    return null
  }

  fn requireRoutePolicyPayload(payload) {
    if object.get(payload, "id") != null {
      return null
    }
    if object.get(payload, "name") == null || object.get(payload, "name") == "" {
      return "route policy name is required"
    }
    if object.get(payload, "endpoint") == null || object.get(payload, "endpoint") == "" {
      return "route policy endpoint is required"
    }
    return null
  }

  fn requireNamedValuePayload(payload) {
    if object.get(payload, "id") != null {
      return null
    }
    if object.get(payload, "name") == null || object.get(payload, "name") == "" {
      return "name is required"
    }
    return null
  }

  fn deletedByNameOrID(payload, firstField, secondField) {
    if object.get(payload, "id") != null {
      return true
    }
    if firstField != null && object.get(payload, firstField) != null && object.get(payload, firstField) != "" {
      return true
    }
    if secondField != null && object.get(payload, secondField) != null && object.get(payload, secondField) != "" {
      return true
    }
    return false
  }

  fn resourceList(items) {
    return {
      ok: true,
      total: len(items),
      items: items
    }
  }

  fn writeResource(state, validator, writeFn, payload) {
    let error = validator(payload)
    if error != null {
      return badRequest(error)
    }

    let item = writeFn(state.catalogService, payload)
    let reloadResult = runtimeState.reload(state)
    return {
      ok: true,
      item: item,
      reload: reloadResult
    }
  }

  fn deleteResource(state, deleteFn, payload) {
    let result = deleteFn(state.catalogService, payload)
    let reloadResult = runtimeState.reload(state)
    return {
      ok: true,
      result: result,
      reload: reloadResult
    }
  }

  fn registerRoutesImpl(app, state) {
    app.get("/healthz", fn(req) {
      return respondJSON(state.monitor.health())
    })

    app.get("/readyz", fn(req) {
      return respondJSON(object.merge(state.monitor.ready(), {
        upstreamBaseUrl: state.config.upstreamBaseUrl,
        requestCount: state.monitor.requestCount()
      }))
    })

    app.get("/admin/routes", fn(req) {
      let currentCatalog = catalogService.currentCatalog(state.catalogService)
      return respondJSON({
        ok: true,
        routes: catalog.snapshot(currentCatalog)
      })
    })

    app.get("/admin/models", fn(req) {
      let currentCatalog = catalogService.currentCatalog(state.catalogService)
      return respondJSON({
        ok: true,
        models: catalog.modelsSnapshot(currentCatalog)
      })
    })

    app.get("/admin/requests", fn(req) {
      return respondJSON(object.merge({
        ok: true,
        total: state.monitor.requestCount(),
        requests: state.monitor.recentRequests(),
        counters: state.monitor.counters(),
        latency: state.monitor.latency()
      }, {
        service: state.monitor.name,
        startedAt: state.monitor.startedAt
      }))
    })

    app.get("/admin/monitor", fn(req) {
      return respondJSON(state.monitor.snapshot())
    })

    app.get("/admin/suppliers/health", fn(req) {
      return respondJSON({
        ok: true,
        suppliers: state.monitor.suppliersHealth()
      })
    })

    app.post("/admin/suppliers/health/check", fn(req) {
      return respondJSON(supplierHealthCheckPayload(req, state))
    })

    app.get("/admin/catalog", fn(req) {
      return respondJSON({
        ok: true,
        catalog: catalogService.snapshot(state.catalogService)
      })
    })

    app.get("/admin/suppliers", fn(req) {
      return respondJSON(resourceList(catalogService.listSuppliers(state.catalogService)))
    })

    app.get("/admin/endpoints", fn(req) {
      return respondJSON(resourceList(catalogService.listEndpoints(state.catalogService)))
    })

    app.get("/admin/model-aliases", fn(req) {
      return respondJSON(resourceList(catalogService.listModelAliases(state.catalogService)))
    })

    app.get("/admin/auth-keys", fn(req) {
      let revealSecret = queryBool(req, "reveal", false)
      let items = catalogService.listAuthKeys(state.catalogService)
      if revealSecret == true {
        items = catalogService.revealAuthKeys(state.catalogService)
      }

      return respondJSON({
        ok: true,
        total: len(items),
        items: items,
        reveal: revealSecret
      })
    })

    app.get("/admin/route-policies", fn(req) {
      return respondJSON(resourceList(catalogService.listRoutePolicies(state.catalogService)))
    })

    app.get("/admin/history/mirror", fn(req) {
      return respondJSON(trafficMirrorPayload(req, state))
    })

    app.get("/admin/history/events", fn(req) {
      return respondJSON(trafficEventsPayload(state))
    })

    app.get("/admin/history", fn(req) {
      return respondJSON(trafficSnapshot(req, state))
    })

    app.post("/admin/history/clear", fn(req) {
      let result = history.clear(state.history)
      state.monitor.increment("admin.history_cleared")
      state.monitor.recordEvent({
        kind: "admin.history.clear",
        request_id: req.requestId
      })

      return respondJSON({
        ok: true,
        cleared: true,
        result: result,
        store: history.snapshot(state.history)
      })
    })

    app.get("/api/overview", fn(req) {
      return respondJSON(controlOverview(state))
    })

    app.get("/api/state", fn(req) {
      return respondJSON(controlState(state))
    })

    app.post("/api/proxy/reload", fn(req) {
      return respondJSON(runtimeState.reload(state))
    })

    app.post("/api/suppliers/health/check", fn(req) {
      return respondJSON(supplierHealthCheckPayload(req, state))
    })

    app.get("/api/traffic/mirror", fn(req) {
      return respondJSON(trafficMirrorPayload(req, state))
    })

    app.get("/api/traffic/events", fn(req) {
      return respondJSON(trafficEventsPayload(state))
    })

    app.get("/api/traffic", fn(req) {
      return respondJSON(trafficSnapshot(req, state))
    })

    app.post("/api/traffic/clear", fn(req) {
      return respondJSON({
        ok: true,
        result: history.clear(state.history)
      })
    })

    app.get("/api/suppliers", fn(req) {
      return respondJSON(resourceList(catalogService.listSuppliers(state.catalogService)))
    })

    app.post("/api/suppliers", fn(req) {
      return respondJSON(writeResource(state, requireSupplierPayload, catalogService.upsertSupplier, bodyPayload(req)))
    })

    app.delete("/api/suppliers", fn(req) {
      let payload = bodyPayload(req)
      if deletedByNameOrID(payload, "name", null) != true {
        return respondJSON(deleteMissing())
      }
      return respondJSON(deleteResource(state, catalogService.deleteSupplier, payload))
    })

    app.get("/api/endpoints", fn(req) {
      return respondJSON(resourceList(catalogService.listEndpoints(state.catalogService)))
    })

    app.post("/api/endpoints", fn(req) {
      return respondJSON(writeResource(state, requireEndpointPayload, catalogService.upsertEndpoint, bodyPayload(req)))
    })

    app.delete("/api/endpoints", fn(req) {
      let payload = bodyPayload(req)
      if deletedByNameOrID(payload, "name", "endpoint") != true {
        return respondJSON(deleteMissing())
      }
      return respondJSON(deleteResource(state, catalogService.deleteEndpoint, payload))
    })

    app.get("/api/model-aliases", fn(req) {
      return respondJSON(resourceList(catalogService.listModelAliases(state.catalogService)))
    })

    app.post("/api/model-aliases", fn(req) {
      return respondJSON(writeResource(state, requireAliasPayload, catalogService.upsertModelAlias, bodyPayload(req)))
    })

    app.delete("/api/model-aliases", fn(req) {
      let payload = bodyPayload(req)
      if deletedByNameOrID(payload, "alias", null) != true {
        return respondJSON(deleteMissing())
      }
      return respondJSON(deleteResource(state, catalogService.deleteModelAlias, payload))
    })

    app.get("/api/auth-keys", fn(req) {
      let revealSecret = queryBool(req, "reveal", false)
      let items = catalogService.listAuthKeys(state.catalogService)
      if revealSecret == true {
        items = catalogService.revealAuthKeys(state.catalogService)
      }
      return respondJSON({
        ok: true,
        total: len(items),
        items: items,
        reveal: revealSecret
      })
    })

    app.post("/api/auth-keys", fn(req) {
      return respondJSON(writeResource(state, requireAuthKeyPayload, catalogService.upsertAuthKey, bodyPayload(req)))
    })

    app.delete("/api/auth-keys", fn(req) {
      let payload = bodyPayload(req)
      if deletedByNameOrID(payload, "name", null) != true {
        return respondJSON(deleteMissing())
      }
      return respondJSON(deleteResource(state, catalogService.deleteAuthKey, payload))
    })

    app.get("/api/route-policies", fn(req) {
      return respondJSON(resourceList(catalogService.listRoutePolicies(state.catalogService)))
    })

    app.post("/api/route-policies", fn(req) {
      return respondJSON(writeResource(state, requireRoutePolicyPayload, catalogService.upsertRoutePolicy, bodyPayload(req)))
    })

    app.delete("/api/route-policies", fn(req) {
      let payload = bodyPayload(req)
      if deletedByNameOrID(payload, "name", null) != true {
        return respondJSON(deleteMissing())
      }
      return respondJSON(deleteResource(state, catalogService.deleteRoutePolicy, payload))
    })

    app.get("/api/settings", fn(req) {
      return respondJSON(resourceList(catalogService.listSettings(state.catalogService)))
    })

    app.post("/api/settings", fn(req) {
      return respondJSON(writeResource(state, requireNamedValuePayload, catalogService.upsertSetting, bodyPayload(req)))
    })

    app.delete("/api/settings", fn(req) {
      let payload = bodyPayload(req)
      if deletedByNameOrID(payload, "name", null) != true {
        return respondJSON(deleteMissing())
      }
      return respondJSON(deleteResource(state, catalogService.deleteSetting, payload))
    })

    app.get("/api/ui-prefs", fn(req) {
      return respondJSON(resourceList(catalogService.listUIPrefs(state.catalogService)))
    })

    app.post("/api/ui-prefs", fn(req) {
      return respondJSON(writeResource(state, requireNamedValuePayload, catalogService.upsertUIPref, bodyPayload(req)))
    })

    app.delete("/api/ui-prefs", fn(req) {
      let payload = bodyPayload(req)
      if deletedByNameOrID(payload, "name", null) != true {
        return respondJSON(deleteMissing())
      }
      return respondJSON(deleteResource(state, catalogService.deleteUIPref, payload))
    })

    return app
  }

  return {
    registerRoutes: registerRoutesImpl
  }
}()

export const registerRoutes = adminApi.registerRoutes
