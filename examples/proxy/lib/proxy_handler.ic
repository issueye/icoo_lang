import std.json as json
import std.http.server as server
import std.object as object
import std.time as time
import "./auth.ic" as auth
import "./catalog.ic" as catalog
import "./stream.ic" as stream
import "./translate.ic" as translate

const proxyHandlerApi = fn() {
  fn buildForwardHeaders(req, authResult, route) {
    let headers = {}
    headers["X-Request-Id"] = req.requestId
    headers["X-Proxy-Route"] = route.name
    headers["X-Resolved-Model"] = route.upstreamModel
    headers["X-Proxy-Auth"] = authResult.via
    headers["X-Proxy-Downstream"] = translate.downstreamProtocol(route)
    headers["X-Proxy-Upstream"] = translate.upstreamProtocol(route)

    let accept = req.header("Accept")
    if accept != null {
      headers.Accept = accept
    }

    if object.has(req, "json") {
      headers["Content-Type"] = "application/json"
    }

    return headers
  }

  fn elapsedMs(startedAt) {
    let duration = time.now() - startedAt
    if duration < 0 {
      return 0
    }
    return duration
  }

  fn recordOutcome(state, req, routeName, requestedModel, resolvedModel, authVia, status, upstreamUrl, note, durationMs) {
    state.monitor.recordRequest({
      request_id: req.requestId,
      method: req.method,
      path: req.path,
      route_name: routeName,
      requested_model: requestedModel,
      resolved_model: resolvedModel,
      auth_via: authVia,
      status: status,
      duration_ms: durationMs,
      upstream_url: upstreamUrl,
      note: note
    })
    return null
  }

  fn forwardTranslatedImpl(req, state, route, authResult, bodyInfo, startedAt) {
    let upstreamUrl = state.config.upstreamBaseUrl + route.upstreamPath
    let headers = buildForwardHeaders(req, authResult, route)
    headers.Accept = "application/json"

    try {
      let resp = server.forward(req, {
        url: upstreamUrl,
        headers: headers,
        body: bodyInfo.body,
        timeoutMs: state.config.timeoutMs
      })
      let translated = translate.translateResponse(resp, route)

      recordOutcome(
        state,
        req,
        route.name,
        bodyInfo.requestedModel,
        route.upstreamModel,
        authResult.via,
        resp.status,
        upstreamUrl,
        route.selection + ":translated",
        elapsedMs(startedAt)
      )
      state.monitor.increment("proxy.forwarded")
      state.monitor.increment("proxy.translated")
      return translated
    } catch err {
      state.monitor.increment("proxy.upstream_error")
      recordOutcome(
        state,
        req,
        route.name,
        bodyInfo.requestedModel,
        route.upstreamModel,
        authResult.via,
        502,
        upstreamUrl,
        err.message,
        elapsedMs(startedAt)
      )
      return {
        status: 502,
        json: {
          ok: false,
          error: "upstream_error",
          message: err.message
        }
      }
    }
  }

  fn forwardTranslatedStreamImpl(req, state, route, authResult, bodyInfo, startedAt) {
    let upstreamUrl = state.config.upstreamBaseUrl + route.upstreamPath
    let headers = buildForwardHeaders(req, authResult, route)
    headers.Accept = "text/event-stream"

    try {
      let aggregated = stream.aggregateResponsesJSON({
        url: upstreamUrl,
        method: req.method,
        headers: headers,
        body: bodyInfo.body,
        timeoutMs: state.config.timeoutMs
      })
      let translated = translate.translateResponse({
        status: aggregated.status,
        body: json.encode(aggregated.json),
        header: fn(name) {
          if name == "Content-Type" {
            return "application/json"
          }
          return null
        }
      }, route)

      recordOutcome(
        state,
        req,
        route.name,
        bodyInfo.requestedModel,
        route.upstreamModel,
        authResult.via,
        aggregated.status,
        upstreamUrl,
        route.selection + ":stream-aggregated",
        elapsedMs(startedAt)
      )
      state.monitor.increment("proxy.forwarded")
      state.monitor.increment("proxy.translated")
      state.monitor.increment("proxy.stream_aggregated")
      return translated
    } catch err {
      state.monitor.increment("proxy.upstream_error")
      recordOutcome(
        state,
        req,
        route.name,
        bodyInfo.requestedModel,
        route.upstreamModel,
        authResult.via,
        502,
        upstreamUrl,
        err.message,
        elapsedMs(startedAt)
      )
      return {
        status: 502,
        json: {
          ok: false,
          error: "upstream_error",
          message: err.message
        }
      }
    }
  }

  fn forwardTranslatedDirectStreamImpl(req, res, state, route, authResult, bodyInfo, startedAt) {
    let upstreamUrl = state.config.upstreamBaseUrl + route.upstreamPath
    let headers = buildForwardHeaders(req, authResult, route)
    headers.Accept = "text/event-stream"

    try {
      let streamed = stream.translateResponsesToChat(res, {
        url: upstreamUrl,
        method: req.method,
        headers: headers,
        body: bodyInfo.body,
        timeoutMs: state.config.timeoutMs,
        model: route.upstreamModel
      })

      recordOutcome(
        state,
        req,
        route.name,
        bodyInfo.requestedModel,
        route.upstreamModel,
        authResult.via,
        streamed.status,
        upstreamUrl,
        route.selection + ":stream-translated",
        elapsedMs(startedAt)
      )
      state.monitor.increment("proxy.forwarded")
      state.monitor.increment("proxy.translated")
      state.monitor.increment("proxy.stream_translated")
      return null
    } catch err {
      state.monitor.increment("proxy.upstream_error")
      recordOutcome(
        state,
        req,
        route.name,
        bodyInfo.requestedModel,
        route.upstreamModel,
        authResult.via,
        502,
        upstreamUrl,
        err.message,
        elapsedMs(startedAt)
      )
      return {
        status: 502,
        json: {
          ok: false,
          error: "upstream_error",
          message: err.message
        }
      }
    }
  }

  fn handleProxyImpl(req, state) {
    let startedAt = time.now()
    let requestedModel = object.get(req, "json")
    if requestedModel != null {
      requestedModel = object.get(requestedModel, "model")
    }
    let authResult = auth.authenticate(state.config, req)
    if authResult.ok != true {
      state.monitor.increment("auth.unauthorized")
      recordOutcome(state, req, "", requestedModel, null, "rejected", 401, "", "unauthorized", elapsedMs(startedAt))
      return authResult.response
    }

    let route = catalog.resolveRoute(state.catalog, req.path, requestedModel)
    if route == null {
      state.monitor.increment("proxy.route_not_found")
      recordOutcome(state, req, "", requestedModel, null, authResult.via, 404, "", "route not found", elapsedMs(startedAt))
      return {
        status: 404,
        json: {
          ok: false,
          error: "route_not_found",
          path: req.path,
          requestedModel: requestedModel
        }
      }
    }

    let bodyInfo = translate.prepareRequest(req, route)
    if translate.needsTranslation(route) {
      if bodyInfo.wantsStream == true {
        if translate.downstreamProtocol(route) == "openai" && translate.upstreamProtocol(route) == "openai-responses" {
          state.monitor.increment("proxy.stream_direct_not_available")
          recordOutcome(
            state,
            req,
            route.name,
            bodyInfo.requestedModel,
            route.upstreamModel,
            authResult.via,
            501,
            "",
            "stream translation requires direct response handle",
            elapsedMs(startedAt)
          )
          return {
            status: 501,
            json: {
              ok: false,
              error: "stream_not_supported",
              message: "stream translation requires direct response handle"
            }
          }
        }
        state.monitor.increment("proxy.stream_not_supported")
        recordOutcome(
          state,
          req,
          route.name,
          bodyInfo.requestedModel,
          route.upstreamModel,
          authResult.via,
          501,
          "",
          "downstream streaming translation not implemented",
          elapsedMs(startedAt)
        )
        return {
          status: 501,
          json: {
            ok: false,
            error: "stream_not_supported",
            message: "downstream streaming translation not implemented"
          }
        }
      }
      if bodyInfo.forceUpstreamStream == true && translate.upstreamProtocol(route) == "openai-responses" {
        return forwardTranslatedStreamImpl(req, state, route, authResult, bodyInfo, startedAt)
      }
      return forwardTranslatedImpl(req, state, route, authResult, bodyInfo, startedAt)
    }

    let upstreamUrl = state.config.upstreamBaseUrl + route.upstreamPath
    let headers = buildForwardHeaders(req, authResult, route)

    try {
      let resp = server.forward(req, {
        url: upstreamUrl,
        headers: headers,
        body: bodyInfo.body,
        timeoutMs: state.config.timeoutMs
      })

      recordOutcome(
        state,
        req,
        route.name,
        bodyInfo.requestedModel,
        route.upstreamModel,
        authResult.via,
        resp.status,
        upstreamUrl,
        route.selection,
        elapsedMs(startedAt)
      )
      state.monitor.increment("proxy.forwarded")
      return resp
    } catch err {
      state.monitor.increment("proxy.upstream_error")
      recordOutcome(
        state,
        req,
        route.name,
        bodyInfo.requestedModel,
        route.upstreamModel,
        authResult.via,
        502,
        upstreamUrl,
        err.message,
        elapsedMs(startedAt)
      )
      return {
        status: 502,
        json: {
          ok: false,
          error: "upstream_error",
          message: err.message
        }
      }
    }
  }

  fn handleProxyDirectImpl(req, res, state) {
    let startedAt = time.now()
    let requestedModel = object.get(req, "json")
    if requestedModel != null {
      requestedModel = object.get(requestedModel, "model")
    }
    let authResult = auth.authenticate(state.config, req)
    if authResult.ok != true {
      state.monitor.increment("auth.unauthorized")
      recordOutcome(state, req, "", requestedModel, null, "rejected", 401, "", "unauthorized", elapsedMs(startedAt))
      return authResult.response
    }

    let route = catalog.resolveRoute(state.catalog, req.path, requestedModel)
    if route == null {
      state.monitor.increment("proxy.route_not_found")
      recordOutcome(state, req, "", requestedModel, null, authResult.via, 404, "", "route not found", elapsedMs(startedAt))
      return {
        status: 404,
        json: {
          ok: false,
          error: "route_not_found",
          path: req.path,
          requestedModel: requestedModel
        }
      }
    }

    let bodyInfo = translate.prepareRequest(req, route)
    if translate.needsTranslation(route) {
      if bodyInfo.wantsStream == true {
        if translate.downstreamProtocol(route) == "openai" && translate.upstreamProtocol(route) == "openai-responses" {
          return forwardTranslatedDirectStreamImpl(req, res, state, route, authResult, bodyInfo, startedAt)
        }
        state.monitor.increment("proxy.stream_not_supported")
        recordOutcome(
          state,
          req,
          route.name,
          bodyInfo.requestedModel,
          route.upstreamModel,
          authResult.via,
          501,
          "",
          "downstream streaming translation not implemented",
          elapsedMs(startedAt)
        )
        return {
          status: 501,
          json: {
            ok: false,
            error: "stream_not_supported",
            message: "downstream streaming translation not implemented"
          }
        }
      }
      if bodyInfo.forceUpstreamStream == true && translate.upstreamProtocol(route) == "openai-responses" {
        return forwardTranslatedStreamImpl(req, state, route, authResult, bodyInfo, startedAt)
      }
      return forwardTranslatedImpl(req, state, route, authResult, bodyInfo, startedAt)
    }

    let upstreamUrl = state.config.upstreamBaseUrl + route.upstreamPath
    let headers = buildForwardHeaders(req, authResult, route)

    try {
      let proxied = res.proxy(req, {
        url: upstreamUrl,
        headers: headers,
        body: bodyInfo.body,
        timeoutMs: state.config.timeoutMs
      })

      recordOutcome(
        state,
        req,
        route.name,
        bodyInfo.requestedModel,
        route.upstreamModel,
        authResult.via,
        res.statusCode(),
        upstreamUrl,
        route.selection,
        elapsedMs(startedAt)
      )
      state.monitor.increment("proxy.forwarded")
      return proxied
    } catch err {
      state.monitor.increment("proxy.upstream_error")
      recordOutcome(
        state,
        req,
        route.name,
        bodyInfo.requestedModel,
        route.upstreamModel,
        authResult.via,
        502,
        upstreamUrl,
        err.message,
        elapsedMs(startedAt)
      )
      return {
        status: 502,
        json: {
          ok: false,
          error: "upstream_error",
          message: err.message
        }
      }
    }
  }

  return {
    handleProxy: handleProxyImpl,
    handleProxyDirect: handleProxyDirectImpl
  }
}()

export const handleProxy = proxyHandlerApi.handleProxy
export const handleProxyDirect = proxyHandlerApi.handleProxyDirect
