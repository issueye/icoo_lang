if customDefaultResp.json.route != "custom-chat-default" {
  panic("expected custom endpoint default route")
}

let customAliasResp = client.requestJSON({
  url: runtimeApp.server.url + "/v1/custom/chat",
  method: "POST",
  headers: {
    Authorization: "Bearer runtime-key"
  },
  json: {
    model: "custom-alias",
    messages: [
      {
        role: "user",
        content: "dynamic alias"
      }
    ]
  }
})

if customAliasResp.status != 200 {
  panic("expected custom alias request to succeed")
}
if customAliasResp.json.route != "custom-chat-alias" {
  panic("expected custom alias route")
}

let updatedState = client.getJSON(runtimeApp.server.url + "/api/state")
if updatedState.json.catalog.store.suppliers != 2 {
  panic("expected updated supplier count")
}
if updatedState.json.catalog.store.authKeys != 2 {
  panic("expected updated auth key count")
}
if updatedState.json.catalog.store.settings != 4 {
  panic("expected updated setting count")
}
if updatedState.json.catalog.store.uiPrefs != 1 {
  panic("expected updated ui pref count")
}
if updatedState.json.runtime.reloadCount != 8 {
  panic("expected updated runtime reload count")
}
if updatedState.json.runtime.lastSupplierHealthCheckAt == null {
  panic("expected supplier health check timestamp")
}
if updatedState.json.runtime.catalogCache.supplierCount != 2 {
  panic("expected updated runtime cache supplier count")
}

let deleteAlias = client.requestJSON({
  url: runtimeApp.server.url + "/api/model-aliases",
  method: "DELETE",
  json: {
    alias: "custom-alias"
  }
})

if deleteAlias.status != 200 {
  panic("expected alias delete to succeed")
}
if deleteAlias.json.result.rowsAffected != 1 {
  panic("expected alias delete rowsAffected")
}

let deleteEndpoint = client.requestJSON({
  url: runtimeApp.server.url + "/api/endpoints",
  method: "DELETE",
  json: {
    name: "custom-chat-default"
  }
})

if deleteEndpoint.status != 200 {
  panic("expected endpoint delete to succeed")
}
if deleteEndpoint.json.result.rowsAffected != 1 {
  panic("expected endpoint delete rowsAffected")
}

let removedEndpointResp = client.requestJSON({
  url: runtimeApp.server.url + "/v1/custom/chat",
  method: "POST",
  headers: {
    Authorization: "Bearer runtime-key"
  },
  json: {
    model: "custom-alias",
    messages: [
      {
        role: "user",
        content: "should fail"
      }
    ]
  }
})

if removedEndpointResp.status != 404 {
  panic("expected removed endpoint to stop routing")
}

proxy.stop(runtimeApp)

let restartedApp = proxy.start({
  listenAddr: "127.0.0.1:0",
  upstreamBaseUrl: upstream.url,
  apiKeys: ["ignored-key"],
  recentLimit: 20,
  catalogPath: catalogPath,
  historyPath: historyPath,
  historyLimit: 20,
  defaultRoutes: [],
  aliases: []
})

let persistedHistory = client.getJSON(restartedApp.server.url + "/admin/history")
if persistedHistory.json.total != 18 {
  panic("expected persisted history after restart")
}

let persistedCatalog = client.getJSON(restartedApp.server.url + "/admin/catalog")
if persistedCatalog.json.catalog.store.path != catalogPath {
  panic("expected persisted catalog after restart")
}
if persistedCatalog.json.catalog.store.suppliers != 2 {
  panic("expected persisted supplier count after restart")
}
if persistedCatalog.json.catalog.store.authKeys != 2 {
  panic("expected persisted auth key count after restart")
}
if persistedCatalog.json.catalog.store.settings != 4 {
  panic("expected persisted setting count after restart")
}
if persistedCatalog.json.catalog.store.uiPrefs != 1 {
  panic("expected persisted ui pref count after restart")
}

let persistedProxy = client.requestJSON({
  url: restartedApp.server.url + "/v1/chat/completions",
  method: "POST",
  headers: {
    Authorization: "Bearer demo-key"
  },
  json: {
    model: "gpt-4o",
    messages: [
      {
        role: "user",
        content: "persisted alias"
      }
    ]
  }
})

if persistedProxy.status != 200 {
  panic("expected persisted catalog request to succeed after restart")
}
if persistedProxy.json.route != "chat-gpt-4o" {
  panic("expected persisted alias route after restart")
}

proxy.stop(restartedApp)
upstream.close()
safeRemove(historyPath)
safeRemove(catalogPath)

io.println("== proxy smoke ==")
io.println("proxy status:", okResp.status)
io.println("proxy path:", okResp.json.path)
io.println("rewritten model:", okResp.json.model)
io.println("responses path:", responsesResp.json.path)
io.println("admin request total:", requests.json.total)
io.println("persisted history total:", history.json.total)
