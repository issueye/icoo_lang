import std.io as io
import std.http.client as client
import std.http.server as server
import "./src/main.ic" as proxy

let upstream = server.listen({
  addr: "127.0.0.1:0",
  handler: fn(req) {
    let payload = req.json
    let model = null
    if payload != null {
      model = payload.model
    }

    if req.path == "/openai/chat/completions" {
      return {
        json: {
          id: "chatcmpl-upstream",
          object: "chat.completion",
          path: req.path,
          method: req.method,
          model: model,
          requestId: req.requestId,
          route: req.header("X-Proxy-Route"),
          forwardedRequestId: req.header("X-Request-Id"),
          auth: req.header("X-Proxy-Auth"),
          choices: [
            {
              index: 0,
              message: {
                role: "assistant",
                content: "chat:" + model
              },
              finish_reason: "stop"
            }
          ],
          usage: {
            prompt_tokens: 11,
            completion_tokens: 7,
            total_tokens: 18
          }
        }
      }
    }

    if req.path == "/openai/responses" {
      return {
        json: {
          id: "resp-upstream",
          object: "response",
          path: req.path,
          method: req.method,
          model: model,
          status: "completed",
          requestId: req.requestId,
          route: req.header("X-Proxy-Route"),
          forwardedRequestId: req.header("X-Request-Id"),
          auth: req.header("X-Proxy-Auth"),
          output: [
            {
              id: "msg-upstream",
              type: "message",
              role: "assistant",
              content: [
                {
                  type: "output_text",
                  text: "response:" + model
                }
              ]
            }
          ],
          usage: {
            input_tokens: 13,
            output_tokens: 5,
            total_tokens: 18
          }
        }
      }
    }

    return {
      json: {
        ok: true,
        path: req.path,
        method: req.method,
        model: model,
        requestId: req.requestId,
        route: req.header("X-Proxy-Route"),
        forwardedRequestId: req.header("X-Request-Id"),
        auth: req.header("X-Proxy-Auth")
      }
    }
  }
})

let runtimeApp = proxy.start({
  listenAddr: "127.0.0.1:0",
  upstreamBaseUrl: upstream.url,
  apiKeys: ["demo-key"],
  recentLimit: 8
})

let okResp = client.requestJSON({
  url: runtimeApp.server.url + "/v1/chat/completions",
  method: "POST",
  headers: {
    Authorization: "Bearer demo-key"
  },
  json: {
    model: "gpt-4o",
    messages: [
      {
        role: "user",
        content: "hello"
      }
    ]
  }
})

if okResp.status != 200 {
  panic("expected proxied request to succeed")
}
if okResp.json.path != "/openai/chat/completions" {
  panic("expected upstream path rewrite")
}
if okResp.json.model != "gpt-4o-mini" {
  panic("expected alias model rewrite")
}
if okResp.json.route != "chat-gpt-4o" {
  panic("expected alias route selection")
}
if okResp.header("X-Request-Id") == null || okResp.header("X-Request-Id") == "" {
  panic("expected proxy response request id header")
}
if okResp.json.forwardedRequestId != okResp.header("X-Request-Id") {
  panic("expected forwarded request id")
}
if okResp.json.requestId != okResp.header("X-Request-Id") {
  panic("expected upstream request id to match response header")
}

let responsesResp = client.requestJSON({
  url: runtimeApp.server.url + "/v1/responses",
  method: "POST",
  headers: {
    Authorization: "Bearer demo-key"
  },
  json: {
    model: "gpt-4.1",
    input: "hello responses"
  }
})

if responsesResp.status != 200 {
  panic("expected responses request to succeed")
}
if responsesResp.json.path != "/openai/responses" {
  panic("expected responses upstream path rewrite")
}
if responsesResp.json.model != "gpt-4.1-mini" {
  panic("expected responses alias model rewrite")
}
if responsesResp.json.route != "responses-gpt-4.1" {
  panic("expected responses alias route selection")
}

let translatedChat = client.requestJSON({
  url: runtimeApp.server.url + "/v1/chat/completions",
  method: "POST",
  headers: {
    Authorization: "Bearer demo-key"
  },
  json: {
    model: "gpt-4o-responses",
    messages: [
      {
        role: "system",
        content: "be concise"
      },
      {
        role: "user",
        content: "translate me"
      }
    ]
  }
})

if translatedChat.status != 200 {
  panic("expected translated chat request to succeed")
}
if translatedChat.json.object != "chat.completion" {
  panic("expected translated chat response shape")
}
if translatedChat.json.choices[0].message.content != "response:gpt-4.1-mini" {
  panic("expected translated chat response content")
}
if translatedChat.json.usage.prompt_tokens != 13 || translatedChat.json.usage.completion_tokens != 5 {
  panic("expected translated chat usage mapping")
}

let translatedResponses = client.requestJSON({
  url: runtimeApp.server.url + "/v1/responses",
  method: "POST",
  headers: {
    Authorization: "Bearer demo-key"
  },
  json: {
    model: "gpt-4.1-chat",
    input: "translate back"
  }
})

if translatedResponses.status != 200 {
  panic("expected translated responses request to succeed")
}
if translatedResponses.json.object != "response" {
  panic("expected translated responses response shape")
}
if translatedResponses.json.output[0].content[0].text != "chat:gpt-4o-mini" {
  panic("expected translated responses response content")
}
if translatedResponses.json.usage.input_tokens != 11 || translatedResponses.json.usage.output_tokens != 7 {
  panic("expected translated responses usage mapping")
}

let unauthorized = client.requestJSON({
  url: runtimeApp.server.url + "/v1/chat/completions",
  method: "POST",
  json: {
    model: "gpt-4o"
  }
})

if unauthorized.status != 401 {
  panic("expected unauthorized response")
}

let health = client.getJSON(runtimeApp.server.url + "/healthz")
let ready = client.getJSON(runtimeApp.server.url + "/readyz")
let routes = client.getJSON(runtimeApp.server.url + "/admin/routes")
let requests = client.getJSON(runtimeApp.server.url + "/admin/requests")
let monitor = client.getJSON(runtimeApp.server.url + "/admin/monitor")

if health.json.ok != true {
  panic("expected healthz ok")
}
if ready.json.ok != true {
  panic("expected readyz ok")
}
if monitor.json.ready.ok != true {
  panic("expected monitor ready ok")
}
if monitor.json.requestCount != 5 {
  panic("expected monitor request count")
}
if len(monitor.json.recentRequests) != 5 {
  panic("expected monitor recent requests")
}
if monitor.json.counters["requests.total"] != 5 {
  panic("expected monitor total counter")
}
if monitor.json.counters["requests.status.2xx"] != 4 {
  panic("expected monitor 2xx counter")
}
if monitor.json.counters["requests.status.4xx"] != 1 {
  panic("expected monitor 4xx counter")
}
if monitor.json.counters["auth.unauthorized"] != 1 {
  panic("expected auth unauthorized counter")
}
if monitor.json.counters["proxy.forwarded"] != 4 {
  panic("expected proxy forwarded counter")
}
if monitor.json.counters["proxy.translated"] != 2 {
  panic("expected translated proxy counter")
}
if monitor.json.latency.count != 5 {
  panic("expected latency sample count")
}
if len(routes.json.routes.defaults) != 3 {
  panic("expected default routes in admin response")
}
if requests.json.total != 5 {
  panic("expected recorded requests")
}
if requests.json.counters["requests.status.200"] != 4 {
  panic("expected request counters on admin requests")
}
if requests.json.latency.count != 5 {
  panic("expected latency summary on admin requests")
}

let foundResolved = false
let foundResponses = false
let foundRequestID = false
let foundTranslatedChat = false
let foundTranslatedResponses = false
for request in requests.json.requests {
  if request.route_name == "chat-gpt-4o" && request.resolved_model == "gpt-4o-mini" {
    foundResolved = true
  }
  if request.route_name == "responses-gpt-4.1" && request.resolved_model == "gpt-4.1-mini" {
    foundResponses = true
  }
  if request.route_name == "chat-gpt-4o-responses" && request.note == "alias:translated" {
    foundTranslatedChat = true
  }
  if request.route_name == "responses-gpt-4.1-chat" && request.note == "alias:translated" {
    foundTranslatedResponses = true
  }
  if request.request_id == okResp.header("X-Request-Id") {
    foundRequestID = true
  }
  if request.ts == null || request.duration_ms == null {
    panic("expected monitor request timing fields")
  }
}
if foundResolved != true {
  panic("expected recent request resolved model")
}
if foundResponses != true {
  panic("expected responses request record")
}
if foundTranslatedChat != true {
  panic("expected translated chat request record")
}
if foundTranslatedResponses != true {
  panic("expected translated responses request record")
}
if foundRequestID != true {
  panic("expected request id in recent request record")
}

proxy.stop(runtimeApp)
upstream.close()

io.println("== proxy smoke ==")
io.println("proxy status:", okResp.status)
io.println("proxy path:", okResp.json.path)
io.println("rewritten model:", okResp.json.model)
io.println("responses path:", responsesResp.json.path)
io.println("admin request total:", requests.json.total)
