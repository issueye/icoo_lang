let foundResolved = false
let foundResponses = false
let foundRequestID = false
let foundTranslatedChat = false
let foundTranslatedResponses = false
let foundTranslatedAnthropic = false
let foundTranslatedAnthropicResponses = false
let foundTranslatedChatFromAnthropic = false
let foundTranslatedStream = false
let foundTranslatedDirectStream = false
let foundTranslatedAnthropicStream = false
let foundTranslatedChatFromAnthropicStream = false
for request in requests.json.requests {
  if request.route_name == "chat-gpt-4o" && request.resolved_model == "gpt-4o-mini" {
    foundResolved = true
  }
  if request.route_name == "responses-gpt-4.1" && request.resolved_model == "gpt-4.1-mini" {
    foundResponses = true
  }
  if request.route_name == "chat-gpt-4o-responses" && request.note == "alias:translated" {
    foundTranslatedChat = true
  }
  if request.route_name == "responses-gpt-4.1-chat" && request.note == "alias:translated" {
    foundTranslatedResponses = true
  }
  if request.route_name == "messages-claude-responses" && request.note == "alias:translated" {
    foundTranslatedAnthropic = true
  }
  if request.route_name == "responses-sonnet" && request.note == "alias:translated" {
    foundTranslatedAnthropicResponses = true
  }
  if request.route_name == "chat-gpt-4o-anthropic" && request.note == "alias:translated" {
    foundTranslatedChatFromAnthropic = true
  }
  if request.route_name == "chat-gpt-4o-responses-stream" && request.note == "alias:stream-aggregated" {
    foundTranslatedStream = true
  }
  if request.route_name == "chat-gpt-4o-responses" && request.note == "alias:stream-translated" {
    foundTranslatedDirectStream = true
  }
  if request.route_name == "messages-claude-responses" && request.note == "alias:stream-translated-anthropic" {
    foundTranslatedAnthropicStream = true
  }
  if request.route_name == "chat-gpt-4o-anthropic" && request.note == "alias:stream-translated-chat" {
    foundTranslatedChatFromAnthropicStream = true
  }
  if request.request_id == okResp.header("X-Request-Id") {
    foundRequestID = true
  }
  if request.ts == null || request.duration_ms == null {
    panic("expected monitor request timing fields")
  }
}
if foundResolved != true {
  panic("expected recent request resolved model")
}
if foundResponses != true {
  panic("expected responses request record")
}
if foundTranslatedChat != true {
  panic("expected translated chat request record")
}
if foundTranslatedResponses != true {
  panic("expected translated responses request record")
}
if foundTranslatedAnthropic != true {
  panic("expected translated anthropic request record")
}
if foundTranslatedAnthropicResponses != true {
  panic("expected translated anthropic responses request record")
}
if foundTranslatedChatFromAnthropic != true {
  panic("expected chat from anthropic request record")
}
if foundTranslatedStream != true {
  panic("expected translated stream request record")
}
if foundTranslatedDirectStream != true {
  panic("expected translated direct stream request record")
}
if foundTranslatedAnthropicStream != true {
  panic("expected translated anthropic stream request record")
}
if foundTranslatedChatFromAnthropicStream != true {
  panic("expected chat from anthropic stream request record")
}
if foundRequestID != true {
  panic("expected request id in recent request record")
}

let overview = client.getJSON(runtimeApp.server.url + "/api/overview")
let stateSnapshot = client.getJSON(runtimeApp.server.url + "/api/state")
let traffic = client.getJSON(runtimeApp.server.url + "/api/traffic?limit=3&page=1")
let trafficWithMirror = client.getJSON(runtimeApp.server.url + "/api/traffic?limit=3&page=1&request_id=" + okResp.header("X-Request-Id"))
let trafficMirror = client.getJSON(runtimeApp.server.url + "/api/traffic/mirror?request_id=" + okResp.header("X-Request-Id"))
let trafficEvents = client.getJSON(runtimeApp.server.url + "/api/traffic/events")

if overview.json.catalog.endpoints != 3 {
  panic("expected api overview endpoint count")
}
if overview.json.catalog.settings != 3 {
  panic("expected api overview seeded settings count")
}
if overview.json.runtime.reloadCount != 0 {
  panic("expected api overview initial reload count")
}
if stateSnapshot.json.config.catalogPath != catalogPath {
  panic("expected api state catalog path")
}
if stateSnapshot.json.config.eventLimit != 60 {
  panic("expected api state event limit")
}
if stateSnapshot.json.runtime.catalogCache.endpointCount != 3 {
  panic("expected api state catalog cache endpoint count")
}
if stateSnapshot.json.runtime.catalogCache.aliasCount != 11 {
  panic("expected api state catalog cache alias count")
}
if stateSnapshot.json.runtime.supplierHealthPath != "/" {
  panic("expected api state supplier health path")
}
if traffic.json.total != 14 {
  panic("expected api traffic total")
}
if len(traffic.json.items) != 3 {
  panic("expected api traffic page size")
}
if traffic.json.stats.count != 14 {
  panic("expected api traffic stats count")
}
if traffic.json.stats.statuses["200"] != 13 {
  panic("expected api traffic 200 status stats")
}
if traffic.json.stats.statuses["401"] != 1 {
  panic("expected api traffic 401 status stats")
}
if traffic.json.stats.usage.total_tokens <= 0 {
  panic("expected api traffic usage stats")
}
if traffic.json.eventCount <= 0 {
  panic("expected api traffic event count")
}
if len(traffic.json.recentEvents) == 0 {
  panic("expected api traffic recent events")
}
if traffic.json.store.mirrorCount != 14 {
  panic("expected api traffic mirror count")
}
if trafficWithMirror.json.mirror == null {
  panic("expected api traffic request mirror")
}
if trafficMirror.json.mirror.request_id != okResp.header("X-Request-Id") {
  panic("expected api traffic mirror request id")
}
if trafficMirror.json.mirror.route_name != "chat-gpt-4o" {
  panic("expected api traffic mirror route name")
}
if trafficMirror.json.mirror.downstream_request.headers.Authorization != "[REDACTED]" {
  panic("expected api traffic mirror authorization redaction")
}
if trafficMirror.json.mirror.upstream_request.body.parsedJson != true {
  panic("expected api traffic upstream request json summary")
}
if trafficMirror.json.mirror.downstream_response.body.parsedJson != true {
  panic("expected api traffic downstream response json summary")
}

let foundTrafficStartEvent = false
let foundTrafficCompleteEvent = false
for event in trafficEvents.json.items {
  let kind = object.get(event, "kind")
  let requestID = object.get(event, "request_id")
  if kind == "proxy.request.start" && requestID == okResp.header("X-Request-Id") {
    foundTrafficStartEvent = true
  }
  if kind == "proxy.response.complete" {
    foundTrafficCompleteEvent = true
  }
}
if foundTrafficStartEvent != true {
  panic("expected api traffic start event")
}
if foundTrafficCompleteEvent != true {
  panic("expected api traffic completion event")
}

