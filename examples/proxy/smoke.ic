let requests = client.getJSON(runtimeApp.server.url + "/admin/requests")
let monitor = client.getJSON(runtimeApp.server.url + "/admin/monitor")
let suppliers = client.getJSON(runtimeApp.server.url + "/admin/suppliers/health")
let catalogInfo = client.getJSON(runtimeApp.server.url + "/admin/catalog")
let endpoints = client.getJSON(runtimeApp.server.url + "/admin/endpoints")
let aliases = client.getJSON(runtimeApp.server.url + "/admin/model-aliases")
let authKeys = client.getJSON(runtimeApp.server.url + "/admin/auth-keys")
let routePolicies = client.getJSON(runtimeApp.server.url + "/admin/route-policies")
let history = client.getJSON(runtimeApp.server.url + "/admin/history?limit=5&page=1")
let translatedHistory = client.getJSON(runtimeApp.server.url + "/admin/history?route_name=messages-claude-responses")

