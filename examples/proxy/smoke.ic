import std.fs as fs
import std.io as io
import std.json as json
import std.net.http.client as client
import std.net.http.server as server
import std.net.sse.client as sseClient
import std.object as object
import std.os as os
import std.time as time
import "./src/main.ic" as proxy

fn safeRemove(path) {
  if fs.exists(path) != true {
    return null
  }

  try {
    fs.remove(path)
  } catch err {
    return null
  }

  return null
}

let historyPath = fs.join(os.tempDir(), "icoo_proxy_smoke_history.sqlite")
let catalogPath = fs.join(os.tempDir(), "icoo_proxy_smoke_catalog.sqlite")
safeRemove(historyPath)
safeRemove(catalogPath)

let upstream = server.listen({
  addr: "127.0.0.1:0",
  handler: fn(req, res) {
    let payload = object.get(req, "json")
    let model = null
    if payload != null {
      model = payload.model
    }

    if req.path == "/openai/chat/completions" {
      return {
        json: {
          id: "chatcmpl-upstream",
          object: "chat.completion",
          path: req.path,
          method: req.method,
          model: model,
          requestId: req.requestId,
          route: req.header("X-Proxy-Route"),
          forwardedRequestId: req.header("X-Request-Id"),
          auth: req.header("X-Proxy-Auth"),
          choices: [
            {
              index: 0,
              message: {
                role: "assistant",
                content: "chat:" + model
              },
              finish_reason: "stop"
            }
          ],
          usage: {
            prompt_tokens: 11,
            completion_tokens: 7,
            total_tokens: 18
          }
        }
      }
    }

    if req.path == "/openai/responses" {
      if object.get(payload, "stream", false) == true {
        let firstInput = null
        let rawInput = object.get(payload, "input")
        if typeOf(rawInput) == "array" && len(rawInput) > 0 {
          firstInput = rawInput[0]
        }
        let firstInputContent = ""
        if typeOf(firstInput) == "object" {
          firstInputContent = object.get(firstInput, "content", "")
        }

        if firstInputContent == "tool stream" {
          let responseCreated = json.encode({
            type: "response.created",
            response: {
              id: "resp-upstream-tool-stream",
              object: "response",
              model: model,
              status: "in_progress"
            }
          })
          let toolAdded = json.encode({
            type: "response.output_item.added",
            item_id: "fc_1",
            output_index: 0,
            item: {
              id: "fc_1",
              type: "function_call",
              call_id: "call_1",
              name: "weather"
            }
          })
          let toolArgumentsDelta1 = json.encode({
            type: "response.function_call_arguments.delta",
            item_id: "fc_1",
            output_index: 0,
            delta: "{\"city\":"
          })
          let toolArgumentsDelta2 = json.encode({
            type: "response.function_call_arguments.delta",
            item_id: "fc_1",
            output_index: 0,
            delta: "\"Paris\"}"
          })
          let responseCompleted = json.encode({
            type: "response.completed",
            response: {
              id: "resp-upstream-tool-stream",
              object: "response",
              model: model,
              status: "completed"
            }
          })

          res.setHeader("Content-Type", "text/event-stream")
          res.sse({
            event: "response.created",
            data: responseCreated
          })
          res.sse({
            event: "response.output_item.added",
            data: toolAdded
          })
          res.sse({
            event: "response.function_call_arguments.delta",
            data: toolArgumentsDelta1
          })
          res.sse({
            event: "response.function_call_arguments.delta",
            data: toolArgumentsDelta2
          })
          res.sse({
            event: "response.completed",
            data: responseCompleted
          })
          return res.sse("[DONE]")
        }

        let responseCreated = json.encode({
          type: "response.created",
          response: {
            id: "resp-upstream-stream",
            object: "response",
            model: model,
            status: "in_progress"
          }
        })
        let responseDelta = json.encode({
          type: "response.output_text.delta",
          item_id: "msg-upstream-stream",
          output_index: 0,
          content_index: 0,
          delta: "stream:" + model
        })
        let responseTextDone = json.encode({
          type: "response.output_text.done",
          item_id: "msg-upstream-stream",
          output_index: 0,
          content_index: 0,
          text: "stream:" + model
        })
        let responseCompleted = json.encode({
          type: "response.completed",
          response: {
            id: "resp-upstream-stream",
            object: "response",
            model: model,
            status: "completed",
            usage: {
              input_tokens: 17,
              output_tokens: 6,
              total_tokens: 23
            }
          }
        })

        res.setHeader("Content-Type", "text/event-stream")
        res.sse({
          event: "response.created",
          data: responseCreated
        })
        res.sse({
          event: "response.output_text.delta",
          data: responseDelta
        })
        res.sse({
          event: "response.output_text.done",
          data: responseTextDone
        })
        res.sse({
          event: "response.completed",
          data: responseCompleted
        })
        return res.sse("[DONE]")
      }

      let responseText = "response:" + model
      if req.header("X-Proxy-Route") == "messages-claude-responses" {
        if object.get(payload, "max_output_tokens") != 64 {
          return {
            status: 400,
            json: {
              error: "unexpected_max_output_tokens"
            }
          }
        }
        responseText = "response:" + model + ":" + object.get(payload, "instructions", "") + ":" + object.get(payload.input[0], "content", "")
      }

      return {
        json: {
          id: "resp-upstream",
          object: "response",
          path: req.path,
          method: req.method,
          model: model,
          status: "completed",
          requestId: req.requestId,
          route: req.header("X-Proxy-Route"),
          forwardedRequestId: req.header("X-Request-Id"),
          auth: req.header("X-Proxy-Auth"),
          output: [
            {
              id: "msg-upstream",
              type: "message",
              role: "assistant",
              content: [
                {
                  type: "output_text",
                  text: responseText
                }
              ]
            }
          ],
          usage: {
            input_tokens: 13,
            output_tokens: 5,
            total_tokens: 18
          }
        }
      }
    }

    if req.path == "/anthropic/messages" {
      let anthropicText = "anthropic:" + model
      let anthropicInputTokens = 19
      let anthropicOutputTokens = 8
      let anthropicSystem = object.get(payload, "system", "")
      let anthropicUserContent = ""
      let anthropicMessages = object.get(payload, "messages")
      if typeOf(anthropicMessages) == "array" && len(anthropicMessages) > 0 {
        anthropicUserContent = object.get(anthropicMessages[0], "content", "")
      }

      if object.get(payload, "stream", false) == true {
        let anthropicStreamText = "anthropic-stream:" + model
        if req.header("X-Proxy-Route") == "chat-gpt-4o-anthropic" {
          if object.get(payload, "max_tokens") != 72 {
            return {
              status: 400,
              json: {
                error: "unexpected_chat_max_tokens"
              }
            }
          }
          anthropicStreamText = "anthropic-stream:" + model + ":" + anthropicSystem + ":" + anthropicUserContent
        }

        // This branch simulates Anthropic tool-use SSE so the proxy smoke test
        // covers the hardest translation path: tool_use -> tool_calls.
        if req.header("X-Proxy-Route") == "chat-gpt-4o-anthropic" && anthropicUserContent == "anthropic tool stream" {
          let toolMessageStart = json.encode({
            type: "message_start",
            message: {
              id: "msg-upstream-tool-stream",
              type: "message",
              role: "assistant",
              model: model,
              usage: {
                input_tokens: 29,
                output_tokens: 0
              }
            }
          })
          let toolContentStart = json.encode({
            type: "content_block_start",
            index: 0,
            content_block: {
              type: "tool_use",
              id: "anthropic-call-1",
              name: "weather",
              input: {}
            }
          })
          let toolContentDelta1 = json.encode({
            type: "content_block_delta",
            index: 0,
            delta: {
              type: "input_json_delta",
              partial_json: "{\"city\":"
            }
          })
          let toolContentDelta2 = json.encode({
            type: "content_block_delta",
            index: 0,
            delta: {
              type: "input_json_delta",
              partial_json: "\"Paris\"}"
            }
          })
          let toolContentStop = json.encode({
            type: "content_block_stop",
            index: 0
          })
          let toolMessageDelta = json.encode({
            type: "message_delta",
            delta: {
              stop_reason: "tool_use"
            },
            usage: {
              input_tokens: 29,
              output_tokens: 4
            }
          })
          let toolMessageStop = json.encode({
            type: "message_stop"
          })

          res.setHeader("Content-Type", "text/event-stream")
          res.sse({
            event: "message_start",
            data: toolMessageStart
          })
          res.sse({
            event: "content_block_start",
            data: toolContentStart
          })
          res.sse({
            event: "content_block_delta",
            data: toolContentDelta1
          })
          res.sse({
            event: "content_block_delta",
            data: toolContentDelta2
          })
          res.sse({
            event: "content_block_stop",
            data: toolContentStop
          })
          res.sse({
            event: "message_delta",
            data: toolMessageDelta
          })
          res.sse({
            event: "message_stop",
            data: toolMessageStop
          })
          return res.sse("[DONE]")
        }

        let messageStart = json.encode({
          type: "message_start",
          message: {
            id: "msg-upstream-stream",
            type: "message",
            role: "assistant",
            model: model,
            usage: {
              input_tokens: 23,
              output_tokens: 0
            }
          }
        })
        let contentStart = json.encode({
          type: "content_block_start",
          index: 0,
          content_block: {
            type: "text",
            text: ""
          }
        })
        let contentDelta = json.encode({
          type: "content_block_delta",
          index: 0,
          delta: {
            type: "text_delta",
            text: anthropicStreamText
          }
        })
        let contentStop = json.encode({
          type: "content_block_stop",
          index: 0
        })
        let messageDelta = json.encode({
          type: "message_delta",
          delta: {
            stop_reason: "end_turn"
          },
          usage: {
            input_tokens: 23,
            output_tokens: 9
          }
        })
        let messageStop = json.encode({
          type: "message_stop"
        })

        res.setHeader("Content-Type", "text/event-stream")
        res.sse({
          event: "message_start",
          data: messageStart
        })
        res.sse({
          event: "content_block_start",
          data: contentStart
        })
        res.sse({
          event: "content_block_delta",
          data: contentDelta
        })
        res.sse({
          event: "content_block_stop",
          data: contentStop
        })
        res.sse({
          event: "message_delta",
          data: messageDelta
        })
        res.sse({
          event: "message_stop",
          data: messageStop
        })
        return res.sse("[DONE]")
      }

      if req.header("X-Proxy-Route") == "responses-sonnet" {
        if object.get(payload, "max_tokens") != 96 {
          return {
            status: 400,
            json: {
              error: "unexpected_max_tokens"
            }
          }
        }
        anthropicText = "anthropic:" + model + ":" + anthropicSystem + ":" + anthropicUserContent
      }
      if req.header("X-Proxy-Route") == "chat-gpt-4o-anthropic" {
        if object.get(payload, "max_tokens") != 72 {
          return {
            status: 400,
            json: {
              error: "unexpected_chat_max_tokens"
            }
          }
        }
        anthropicText = "anthropic:" + model + ":" + anthropicSystem + ":" + anthropicUserContent
        anthropicInputTokens = 23
        anthropicOutputTokens = 9
      }

      return {
        json: {
          id: "msg-upstream",
          type: "message",
          path: req.path,
          method: req.method,
          model: model,
          role: "assistant",
          requestId: req.requestId,
          route: req.header("X-Proxy-Route"),
          forwardedRequestId: req.header("X-Request-Id"),
          auth: req.header("X-Proxy-Auth"),
          content: [
            {
              type: "text",
              text: anthropicText
            }
          ],
          stop_reason: "end_turn",
          usage: {
            input_tokens: anthropicInputTokens,
            output_tokens: anthropicOutputTokens
          }
        }
      }
    }

    return {
      json: {
        ok: true,
        path: req.path,
        method: req.method,
        model: model,
        requestId: req.requestId,
        route: req.header("X-Proxy-Route"),
        forwardedRequestId: req.header("X-Request-Id"),
        auth: req.header("X-Proxy-Auth")
      }
    }
  }
})

let runtimeApp = proxy.start({
  listenAddr: "127.0.0.1:0",
  upstreamBaseUrl: upstream.url,
  apiKeys: ["demo-key"],
  recentLimit: 20,
  catalogPath: catalogPath,
  historyPath: historyPath,
  historyLimit: 20
})

let okResp = client.requestJSON({
  url: runtimeApp.server.url + "/v1/chat/completions",
  method: "POST",
  headers: {
    Authorization: "Bearer demo-key"
  },
  json: {
    model: "gpt-4o",
    messages: [
      {
        role: "user",
        content: "hello"
      }
    ]
  }
})

if okResp.status != 200 {
  panic("expected proxied request to succeed")
}
if okResp.json.path != "/openai/chat/completions" {
  panic("expected upstream path rewrite")
}
if okResp.json.model != "gpt-4o-mini" {
  panic("expected alias model rewrite")
}
if okResp.json.route != "chat-gpt-4o" {
  panic("expected alias route selection")
}
if okResp.header("X-Request-Id") == null || okResp.header("X-Request-Id") == "" {
  panic("expected proxy response request id header")
}
if okResp.json.forwardedRequestId != okResp.header("X-Request-Id") {
  panic("expected forwarded request id")
}
if okResp.json.requestId != okResp.header("X-Request-Id") {
  panic("expected upstream request id to match response header")
}

let responsesResp = client.requestJSON({
  url: runtimeApp.server.url + "/v1/responses",
  method: "POST",
  headers: {
    Authorization: "Bearer demo-key"
  },
  json: {
    model: "gpt-4.1",
    input: "hello responses"
  }
})

if responsesResp.status != 200 {
  panic("expected responses request to succeed")
}
if responsesResp.json.path != "/openai/responses" {
  panic("expected responses upstream path rewrite")
}
if responsesResp.json.model != "gpt-4.1-mini" {
  panic("expected responses alias model rewrite")
}
if responsesResp.json.route != "responses-gpt-4.1" {
  panic("expected responses alias route selection")
}

let translatedChat = client.requestJSON({
  url: runtimeApp.server.url + "/v1/chat/completions",
  method: "POST",
  headers: {
    Authorization: "Bearer demo-key"
  },
  json: {
    model: "gpt-4o-responses",
    messages: [
      {
        role: "system",
        content: "be concise"
      },
      {
        role: "user",
        content: "translate me"
      }
    ]
  }
})

if translatedChat.status != 200 {
  panic("expected translated chat request to succeed")
}
if translatedChat.json.object != "chat.completion" {
  panic("expected translated chat response shape")
}
if translatedChat.json.choices[0].message.content != "response:gpt-4.1-mini" {
  panic("expected translated chat response content")
}
if translatedChat.json.usage.prompt_tokens != 13 || translatedChat.json.usage.completion_tokens != 5 {
  panic("expected translated chat usage mapping")
}

let translatedResponses = client.requestJSON({
  url: runtimeApp.server.url + "/v1/responses",
  method: "POST",
  headers: {
    Authorization: "Bearer demo-key"
  },
  json: {
    model: "gpt-4.1-chat",
    input: "translate back"
  }
})

if translatedResponses.status != 200 {
  panic("expected translated responses request to succeed")
}
if translatedResponses.json.object != "response" {
  panic("expected translated responses response shape")
}
if translatedResponses.json.output[0].content[0].text != "chat:gpt-4o-mini" {
  panic("expected translated responses response content")
}
if translatedResponses.json.usage.input_tokens != 11 || translatedResponses.json.usage.output_tokens != 7 {
  panic("expected translated responses usage mapping")
}

let translatedAnthropic = client.requestJSON({
  url: runtimeApp.server.url + "/v1/messages",
  method: "POST",
  headers: {
    Authorization: "Bearer demo-key"
  },
  json: {
    model: "claude-responses",
    system: "be terse",
    max_tokens: 64,
    messages: [
      {
        role: "user",
        content: "hello claude bridge"
      }
    ]
  }
})

if translatedAnthropic.status != 200 {
  panic("expected translated anthropic request to succeed")
}
if translatedAnthropic.json.type != "message" {
  panic("expected translated anthropic response shape")
}
if translatedAnthropic.json.content[0].text != "response:gpt-4.1-mini:be terse:hello claude bridge" {
  panic("expected translated anthropic response content")
}
if translatedAnthropic.json.usage.input_tokens != 13 || translatedAnthropic.json.usage.output_tokens != 5 {
  panic("expected translated anthropic usage mapping")
}

let translatedAnthropicResponses = client.requestJSON({
  url: runtimeApp.server.url + "/v1/responses",
  method: "POST",
  headers: {
    Authorization: "Bearer demo-key"
  },
  json: {
    model: "responses-sonnet",
    instructions: "reply warmly",
    max_output_tokens: 96,
    input: "hello responses bridge"
  }
})

if translatedAnthropicResponses.status != 200 {
  panic("expected responses to anthropic request to succeed")
}
if translatedAnthropicResponses.json.object != "response" {
  panic("expected responses to anthropic response shape")
}
if translatedAnthropicResponses.json.output[0].content[0].text != "anthropic:claude-3-5-sonnet:reply warmly:hello responses bridge" {
  panic("expected responses to anthropic response content")
}
if translatedAnthropicResponses.json.usage.input_tokens != 19 || translatedAnthropicResponses.json.usage.output_tokens != 8 {
  panic("expected responses to anthropic usage mapping")
}

let translatedChatFromAnthropic = client.requestJSON({
  url: runtimeApp.server.url + "/v1/chat/completions",
  method: "POST",
  headers: {
    Authorization: "Bearer demo-key"
  },
  json: {
    model: "gpt-4o-anthropic",
    max_tokens: 72,
    messages: [
      {
        role: "system",
        content: "chat with claude"
      },
      {
        role: "user",
        content: "hello anthropic chat"
      }
    ]
  }
})

if translatedChatFromAnthropic.status != 200 {
  panic("expected chat from anthropic request to succeed")
}
if translatedChatFromAnthropic.json.object != "chat.completion" {
  panic("expected chat from anthropic response shape")
}
if translatedChatFromAnthropic.json.choices[0].message.content != "anthropic:claude-3-5-sonnet:chat with claude:hello anthropic chat" {
  panic("expected chat from anthropic response content")
}
if translatedChatFromAnthropic.json.usage.prompt_tokens != 23 || translatedChatFromAnthropic.json.usage.completion_tokens != 9 {
  panic("expected chat from anthropic usage mapping")
}

let translatedStreamAggregated = client.requestJSON({
  url: runtimeApp.server.url + "/v1/chat/completions",
  method: "POST",
  headers: {
    Authorization: "Bearer demo-key"
  },
  json: {
    model: "gpt-4o-responses-stream",
    messages: [
      {
        role: "user",
        content: "aggregate stream"
      }
    ]
  }
})

if translatedStreamAggregated.status != 200 {
  panic("expected translated stream aggregation request to succeed")
}
if translatedStreamAggregated.json.object != "chat.completion" {
  panic("expected translated aggregated response shape")
}
if translatedStreamAggregated.json.choices[0].message.content != "stream:gpt-4.1-mini" {
  panic("expected translated aggregated response content")
}
if translatedStreamAggregated.json.usage.prompt_tokens != 17 || translatedStreamAggregated.json.usage.completion_tokens != 6 {
  panic("expected translated aggregated usage mapping")
}

let translatedStreamClient = sseClient.connect({
  url: runtimeApp.server.url + "/v1/chat/completions",
  method: "POST",
  headers: {
    Authorization: "Bearer demo-key",
    "Content-Type": "application/json"
  },
  body: json.encode({
    model: "gpt-4o-responses",
    stream: true,
    messages: [
      {
        role: "user",
        content: "translate stream"
      }
    ]
  })
})

if translatedStreamClient.status != 200 {
  panic("expected translated stream request to succeed")
}

let streamRoleEvent = translatedStreamClient.read()
let streamTextEvent = translatedStreamClient.read()
let streamFinishEvent = translatedStreamClient.read()
let streamDoneEvent = translatedStreamClient.read()
translatedStreamClient.close()

let streamRoleChunk = json.decode(streamRoleEvent.data)
let streamTextChunk = json.decode(streamTextEvent.data)
let streamFinishChunk = json.decode(streamFinishEvent.data)

if streamRoleChunk.object != "chat.completion.chunk" {
  panic("expected stream role chunk shape")
}
if streamRoleChunk.choices[0].delta.role != "assistant" {
  panic("expected stream role chunk assistant delta")
}
if streamTextChunk.choices[0].delta.content != "stream:gpt-4.1-mini" {
  panic("expected stream text chunk content")
}
if streamFinishChunk.choices[0].finish_reason != "stop" {
  panic("expected stream finish reason")
}
if streamDoneEvent.data != "[DONE]" {
  panic("expected stream done marker")
}

let translatedToolStreamClient = sseClient.connect({
  url: runtimeApp.server.url + "/v1/chat/completions",
  method: "POST",
  headers: {
    Authorization: "Bearer demo-key",
    "Content-Type": "application/json"
  },
  body: json.encode({
    model: "gpt-4o-responses",
    stream: true,
    messages: [
      {
        role: "user",
        content: "tool stream"
      }
    ]
  })
})

if translatedToolStreamClient.status != 200 {
  panic("expected translated tool stream request to succeed")
}

let toolRoleEvent = translatedToolStreamClient.read()
let toolStartEvent = translatedToolStreamClient.read()
let toolArgEvent1 = translatedToolStreamClient.read()
let toolArgEvent2 = translatedToolStreamClient.read()
let toolFinishEvent = translatedToolStreamClient.read()
let toolDoneEvent = translatedToolStreamClient.read()
translatedToolStreamClient.close()

let toolRoleChunk = json.decode(toolRoleEvent.data)
let toolStartChunk = json.decode(toolStartEvent.data)
let toolArgChunk1 = json.decode(toolArgEvent1.data)
let toolArgChunk2 = json.decode(toolArgEvent2.data)
let toolFinishChunk = json.decode(toolFinishEvent.data)

if toolRoleChunk.choices[0].delta.role != "assistant" {
  panic("expected tool stream role chunk assistant delta")
}
if toolStartChunk.choices[0].delta.tool_calls[0].id != "call_1" {
  panic("expected tool stream call id")
}
if toolStartChunk.choices[0].delta.tool_calls[0].type != "function" {
  panic("expected tool stream call type")
}
if toolStartChunk.choices[0].delta.tool_calls[0].function.name != "weather" {
  panic("expected tool stream function name")
}
if toolStartChunk.choices[0].delta.tool_calls[0].function.arguments != "" {
  panic("expected tool stream initial arguments")
}
if toolArgChunk1.choices[0].delta.tool_calls[0].function.arguments != "{\"city\":" {
  panic("expected tool stream first arguments delta")
}
if toolArgChunk2.choices[0].delta.tool_calls[0].function.arguments != "\"Paris\"}" {
  panic("expected tool stream second arguments delta")
}
if toolFinishChunk.choices[0].finish_reason != "tool_calls" {
  panic("expected tool stream finish reason")
}
if toolDoneEvent.data != "[DONE]" {
  panic("expected tool stream done marker")
}

let anthropicStreamClient = sseClient.connect({
  url: runtimeApp.server.url + "/v1/messages",
  method: "POST",
  headers: {
    Authorization: "Bearer demo-key",
    "Content-Type": "application/json"
  },
  body: json.encode({
    model: "claude-responses",
    stream: true,
    max_tokens: 64,
    messages: [
      {
        role: "user",
        content: "anthropic stream"
      }
    ]
  })
})

if anthropicStreamClient.status != 200 {
  panic("expected anthropic translated stream request to succeed")
}

let anthropicMessageStartEvent = anthropicStreamClient.read()
let anthropicContentStartEvent = anthropicStreamClient.read()
let anthropicContentDeltaEvent = anthropicStreamClient.read()
let anthropicContentStopEvent = anthropicStreamClient.read()
let anthropicMessageDeltaEvent = anthropicStreamClient.read()
let anthropicMessageStopEvent = anthropicStreamClient.read()
anthropicStreamClient.close()

let anthropicMessageStart = json.decode(anthropicMessageStartEvent.data)
let anthropicContentStart = json.decode(anthropicContentStartEvent.data)
let anthropicContentDelta = json.decode(anthropicContentDeltaEvent.data)
let anthropicContentStop = json.decode(anthropicContentStopEvent.data)
let anthropicMessageDelta = json.decode(anthropicMessageDeltaEvent.data)
let anthropicMessageStop = json.decode(anthropicMessageStopEvent.data)

if anthropicMessageStartEvent.event != "message_start" {
  panic("expected anthropic message_start event")
}
if anthropicMessageStart.message.role != "assistant" {
  panic("expected anthropic message role")
}
if anthropicContentStartEvent.event != "content_block_start" {
  panic("expected anthropic content_block_start event")
}
if anthropicContentStart.content_block.type != "text" {
  panic("expected anthropic text content block")
}
if anthropicContentDeltaEvent.event != "content_block_delta" {
  panic("expected anthropic content_block_delta event")
}
if anthropicContentDelta.delta.text != "stream:gpt-4.1-mini" {
  panic("expected anthropic stream text delta")
}
if anthropicContentStopEvent.event != "content_block_stop" {
  panic("expected anthropic content_block_stop event")
}
if anthropicMessageDeltaEvent.event != "message_delta" {
  panic("expected anthropic message_delta event")
}
if anthropicMessageDelta.delta.stop_reason != "end_turn" {
  panic("expected anthropic stop reason")
}
if anthropicMessageDelta.usage.input_tokens != 17 || anthropicMessageDelta.usage.output_tokens != 6 {
  panic("expected anthropic stream usage mapping")
}
if anthropicMessageStopEvent.event != "message_stop" {
  panic("expected anthropic message_stop event")
}
if anthropicMessageStop.type != "message_stop" {
  panic("expected anthropic message_stop payload")
}

let chatFromAnthropicStreamClient = sseClient.connect({
  url: runtimeApp.server.url + "/v1/chat/completions",
  method: "POST",
  headers: {
    Authorization: "Bearer demo-key",
    "Content-Type": "application/json"
  },
  body: json.encode({
    model: "gpt-4o-anthropic",
    stream: true,
    max_tokens: 72,
    messages: [
      {
        role: "system",
        content: "stream with claude"
      },
      {
        role: "user",
        content: "hello anthropic stream"
      }
    ]
  })
})

if chatFromAnthropicStreamClient.status != 200 {
  panic("expected chat from anthropic stream request to succeed")
}

let chatFromAnthropicRoleEvent = chatFromAnthropicStreamClient.read()
let chatFromAnthropicTextEvent = chatFromAnthropicStreamClient.read()
let chatFromAnthropicFinishEvent = chatFromAnthropicStreamClient.read()
let chatFromAnthropicDoneEvent = chatFromAnthropicStreamClient.read()
chatFromAnthropicStreamClient.close()

let chatFromAnthropicRoleChunk = json.decode(chatFromAnthropicRoleEvent.data)
let chatFromAnthropicTextChunk = json.decode(chatFromAnthropicTextEvent.data)
let chatFromAnthropicFinishChunk = json.decode(chatFromAnthropicFinishEvent.data)

if chatFromAnthropicRoleChunk.choices[0].delta.role != "assistant" {
  panic("expected chat from anthropic stream role chunk")
}
if chatFromAnthropicTextChunk.choices[0].delta.content != "anthropic-stream:claude-3-5-sonnet:stream with claude:hello anthropic stream" {
  panic("expected chat from anthropic stream content")
}
if chatFromAnthropicFinishChunk.choices[0].finish_reason != "stop" {
  panic("expected chat from anthropic stream finish reason")
}
if chatFromAnthropicDoneEvent.data != "[DONE]" {
  panic("expected chat from anthropic stream done marker")
}

let chatFromAnthropicToolStreamClient = sseClient.connect({
  url: runtimeApp.server.url + "/v1/chat/completions",
  method: "POST",
  headers: {
    Authorization: "Bearer demo-key",
    "Content-Type": "application/json"
  },
  body: json.encode({
    model: "gpt-4o-anthropic",
    stream: true,
    max_tokens: 72,
    messages: [
      {
        role: "user",
        content: "anthropic tool stream"
      }
    ]
  })
})

if chatFromAnthropicToolStreamClient.status != 200 {
  panic("expected chat from anthropic tool stream request to succeed")
}

let chatFromAnthropicToolRoleEvent = chatFromAnthropicToolStreamClient.read()
let chatFromAnthropicToolStartEvent = chatFromAnthropicToolStreamClient.read()
let chatFromAnthropicToolArgEvent1 = chatFromAnthropicToolStreamClient.read()
let chatFromAnthropicToolArgEvent2 = chatFromAnthropicToolStreamClient.read()
let chatFromAnthropicToolFinishEvent = chatFromAnthropicToolStreamClient.read()
let chatFromAnthropicToolDoneEvent = chatFromAnthropicToolStreamClient.read()
chatFromAnthropicToolStreamClient.close()

let chatFromAnthropicToolRoleChunk = json.decode(chatFromAnthropicToolRoleEvent.data)
let chatFromAnthropicToolStartChunk = json.decode(chatFromAnthropicToolStartEvent.data)
let chatFromAnthropicToolArgChunk1 = json.decode(chatFromAnthropicToolArgEvent1.data)
let chatFromAnthropicToolArgChunk2 = json.decode(chatFromAnthropicToolArgEvent2.data)
let chatFromAnthropicToolFinishChunk = json.decode(chatFromAnthropicToolFinishEvent.data)

if chatFromAnthropicToolRoleChunk.choices[0].delta.role != "assistant" {
  panic("expected chat from anthropic tool stream role chunk")
}
if chatFromAnthropicToolStartChunk.choices[0].delta.tool_calls[0].id != "anthropic-call-1" {
  panic("expected chat from anthropic tool call id")
}
if chatFromAnthropicToolStartChunk.choices[0].delta.tool_calls[0].type != "function" {
  panic("expected chat from anthropic tool call type")
}
if chatFromAnthropicToolStartChunk.choices[0].delta.tool_calls[0].function.name != "weather" {
  panic("expected chat from anthropic tool function name")
}
if chatFromAnthropicToolStartChunk.choices[0].delta.tool_calls[0].function.arguments != "" {
  panic("expected chat from anthropic initial tool arguments")
}
if chatFromAnthropicToolArgChunk1.choices[0].delta.tool_calls[0].function.arguments != "{\"city\":" {
  panic("expected chat from anthropic first tool arguments delta")
}
if chatFromAnthropicToolArgChunk2.choices[0].delta.tool_calls[0].function.arguments != "\"Paris\"}" {
  panic("expected chat from anthropic second tool arguments delta")
}
if chatFromAnthropicToolFinishChunk.choices[0].finish_reason != "tool_calls" {
  panic("expected chat from anthropic tool finish reason")
}
if chatFromAnthropicToolDoneEvent.data != "[DONE]" {
  panic("expected chat from anthropic tool done marker")
}

time.sleep(50)

