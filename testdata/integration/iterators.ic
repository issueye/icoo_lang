let text = "ab"
let out = ""

for ch in text {
  out = out + ch
}

println(out)

let obj = {b: 2, a: 1}
let keys = ""

for key in obj {
  keys = keys + key
}

println(keys)

let iter = [1, 2, 3].iter()
let sum = 0

for item in iter {
  sum = sum + item
}

println(sum)

let custom = {
  label: "fallback",
  iter: fn() {
    return ["x", "y"].iter()
  }
}
let customOut = ""

for item in custom {
  customOut = customOut + item
}

println(customOut)
